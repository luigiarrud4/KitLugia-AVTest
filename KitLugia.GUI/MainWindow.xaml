<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="KitLugia.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:KitLugia.GUI.Controls"
        xmlns:local="clr-namespace:KitLugia.GUI"
        mc:Ignorable="d"
        Title="Kit Lugia - Gold Edition" Height="750" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackground}" Foreground="White"
        ResizeMode="CanResizeWithGrip"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" GlassFrameThickness="0" CornerRadius="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <local:TaskStatusConverter x:Key="TaskStatusConverter"/>
        <local:DurationConverter x:Key="DurationConverter"/>
        <local:StackCountVisibilityConverter x:Key="StackCountVisibilityConverter"/>
    </Window.Resources>

    <Border BorderBrush="{StaticResource AccentColor}" BorderThickness="1">
        <Grid>
            <!-- DIVIS&#xC3;O VERTICAL: CONTE&#xDA;DO EM CIMA, CONSOLE EM BAIXO -->
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <!-- App Principal -->
                <RowDefinition Height="Auto"/>
                <!-- Console (Expans&#xED;vel) -->
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- &#x1F4CD; ANIMA&#xC7;&#xC3;O 21: Splash Screen de Intro (fade-in + scale + move + fade-out) - MainWindow.xaml linha ~42-80 -->
            <!-- SPLASH SCREEN DE INTRO -->
            <Border x:Name="SplashScreen"
                    Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                    Panel.ZIndex="99999"
                    Visibility="Visible"
                    Opacity="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1" x:Name="SplashGradient">
                        <GradientStop Color="#0A0A0A" Offset="0"/>
                        <GradientStop Color="#1A1A1A" Offset="0.5"/>
                        <GradientStop Color="#0A0A0A" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <!-- Part&#xED;culas de fundo -->
                    <Ellipse x:Name="Particle1" Width="10" Height="10" Fill="#FFD700" Opacity="0" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="100,100,0,0">
                        <Ellipse.RenderTransform>
                            <TranslateTransform X="0" Y="0"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <Ellipse x:Name="Particle2" Width="15" Height="15" Fill="#FFD700" Opacity="0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,150,100,0">
                        <Ellipse.RenderTransform>
                            <TranslateTransform X="0" Y="0"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <Ellipse x:Name="Particle3" Width="8" Height="8" Fill="#FFD700" Opacity="0" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="150,0,0,100">
                        <Ellipse.RenderTransform>
                            <TranslateTransform X="0" Y="0"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <Ellipse x:Name="Particle4" Width="12" Height="12" Fill="#FFD700" Opacity="0" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,120,120">
                        <Ellipse.RenderTransform>
                            <TranslateTransform X="0" Y="0"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <Ellipse x:Name="Particle5" Width="6" Height="6" Fill="#FFD700" Opacity="0" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,80,0,0">
                        <Ellipse.RenderTransform>
                            <TranslateTransform X="0" Y="0"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <Ellipse x:Name="Particle6" Width="10" Height="10" Fill="#FFD700" Opacity="0" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,80">
                        <Ellipse.RenderTransform>
                            <TranslateTransform X="0" Y="0"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>

                    <StackPanel x:Name="SplashLogo" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                        <StackPanel.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="SplashScale" ScaleX="0.5" ScaleY="0.5" CenterX="0.5" CenterY="0.5"/>
                                <TranslateTransform x:Name="SplashTranslate" X="0" Y="0"/>
                            </TransformGroup>
                        </StackPanel.RenderTransform>
                        <TextBlock x:Name="SplashText"
                                   Text="KIT LUGIA"
                                   FontSize="72"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentColor}"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect x:Name="SplashGlow" Color="#FFD700" BlurRadius="30" ShadowDepth="0" Opacity="0.6"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock x:Name="SplashSubtext"
                                   Text="ULTIMATE PERFORMANCE"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   Foreground="#808080"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Margin="0,10,0,0"
                                   Opacity="0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ========================================================= -->
            <!-- &#xC1;REA DE BOT&#xD5;ES SUPERIORES (Direita) -->
            <!-- ========================================================= -->
            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top"
                        WindowChrome.IsHitTestVisibleInChrome="True" Margin="0,1,1,0" Panel.ZIndex="9999">

                <!-- BOT&#xC3;O GOODBYEDPI (WIFI) -->
                <Button x:Name="BtnGoodbyeDPI" Width="40" Height="32" Click="BtnGoodbyeDPI_Click" MouseRightButtonDown="BtnGoodbyeDPI_MouseRightButtonDown"
                        Background="Transparent" BorderThickness="0" Margin="0,0,0,0" Cursor="Hand"
                        ToolTip="GoodbyeDPI - Contorno de DPI (Cinza=Desligado, Amarelo=Ativo)&#x0a;Bot&#xE3;o direito para configura&#xE7;&#xF5;es">
                    <Button.ContextMenu>
                        <ContextMenu x:Name="GoodbyeDPIContextMenu">
                            <MenuItem Header="&#x1F4F6; GoodbyeDPI - Configura&#xE7;&#xF5;es" Foreground="#FFD700" FontWeight="Bold" IsEnabled="False"/>
                            <Separator/>
                            <MenuItem Header="&#x1F30D; Modo: Qualquer Pa&#xED;s (-2) &#x2139;&#xFE0F;" x:Name="MenuModeAny" Click="GoodbyeDPI_ModeAny_Click" 
                                      ToolTip="Modo padr&#xE3;o que funciona em qualquer pa&#xED;s. Contorna DPI globalmente."/>
                            <MenuItem Header="&#x1F1F7;&#x1F1FA; Modo: R&#xFA;ssia (-1) &#x2139;&#xFE0F;" x:Name="MenuModeRussia" Click="GoodbyeDPI_ModeRussia_Click" 
                                      ToolTip="Modo espec&#xED;fico para contornar bloqueios de DPI russos."/>
                            <MenuItem Header="&#x1F1FA;&#x1F1F8; Modo: EUA (-3) &#x2139;&#xFE0F;" x:Name="MenuModeUSA" Click="GoodbyeDPI_ModeUSA_Click" 
                                      ToolTip="Modo espec&#xED;fico para contornar bloqueios de DPI dos EUA."/>
                            <Separator/>
                            <MenuItem Header="&#x1F500; Fragmenta&#xE7;&#xE3;o: Ativada (-a) &#x2139;&#xFE0F;" x:Name="MenuFragmentationOn" Click="GoodbyeDPI_FragmentationOn_Click" 
                                      ToolTip="Fragmenta pacotes TLS para evitar detec&#xE7;&#xE3;o por DPI. Recomendado."/>
                            <MenuItem Header="&#x1F500; Fragmenta&#xE7;&#xE3;o: Desativada &#x2139;&#xFE0F;" x:Name="MenuFragmentationOff" Click="GoodbyeDPI_FragmentationOff_Click" 
                                      ToolTip="Desativa fragmenta&#xE7;&#xE3;o de pacotes. Pode ser necess&#xE1;rio se houver problemas de conex&#xE3;o."/>
                            <Separator/>
                            <MenuItem Header="&#x1F310; DNS Redirection: Ativado (-d) &#x2139;&#xFE0F;" x:Name="MenuDNSOn" Click="GoodbyeDPI_DNSOn_Click" 
                                      ToolTip="Redireciona DNS para evitar bloqueios de DNS. Use se sites n&#xE3;o carregarem."/>
                            <MenuItem Header="&#x1F310; DNS Redirection: Desativado &#x2139;&#xFE0F;" x:Name="MenuDNSOff" Click="GoodbyeDPI_DNSOff_Click" 
                                      ToolTip="Usa DNS normal. Recomendado se o DNS redirecionado causar problemas."/>
                            <Separator/>
                            <MenuItem Header="&#x1F680; Iniciar Automaticamente" x:Name="MenuAutoStart" Click="GoodbyeDPI_AutoStart_Click" 
                                      ToolTip="Inicia o GoodbyeDPI automaticamente ao abrir o KitLugia." IsCheckable="True"
                                      Style="{StaticResource ImportantMenuItemStyle}"/>
                            <Separator/>
                            <MenuItem Header="&#x1F504; Restaurar Padr&#xF5;es" Click="GoodbyeDPI_RestoreDefaults_Click" 
                                      ToolTip="Restaura todas as configura&#xE7;&#xF5;es para os valores padr&#xE3;o."/>
                            <Separator/>
                            <MenuItem Header="&#x2139;&#xFE0F; Sobre GoodbyeDPI" Click="GoodbyeDPI_About_Click" 
                                      ToolTip="Informa&#xE7;&#xF5;es sobre o GoodbyeDPI e configura&#xE7;&#xF5;es atuais."/>
                        </ContextMenu>
                    </Button.ContextMenu>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="4" RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <Grid>
                                    <TextBlock x:Name="wifiIcon" Text="&#x1F4F6;" 
                                               Foreground="#808080" FontWeight="Normal"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="bdr"
                                                               Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                               To="1.1" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetName="bdr"
                                                               Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                               To="1.1" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="bdr"
                                                               Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                               To="1" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetName="bdr"
                                                               Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                               To="1" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                    <Setter TargetName="bdr" Property="Background" Value="#22FFD700"/>
                                </Trigger>
                                <DataTrigger Binding="{Binding GoodbyeDPIActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                    <Setter TargetName="wifiIcon" Property="Foreground" Value="#FFD700"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- BOT&#xC3;O INTEGRIDADE (ESCUDO) -->
                <RadioButton x:Name="BtnIntegrity" GroupName="Menu" Tag="&#x1F9F0;" Content="Integridade do Sistema"
                             Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"
                             ToolTip="Scanner de Integridade do Sistema"/>

                <!-- BOT&#xC3;O MONITOR DE SEGUNDO PLANO -->
                <Button x:Name="BtnBackgroundMonitor" Width="40" Height="32" Click="BtnBackgroundMonitor_Click"
                        Background="Transparent" BorderThickness="0" Margin="0,0,0,0" Cursor="Hand"
                        ToolTip="Monitor de Tarefas em Segundo Plano">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="4" RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <Grid>
                                    <TextBlock x:Name="monitorIcon" Text="&#x2699;&#xFE0F;" Foreground="#FFD700" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14">
                                        <TextBlock.RenderTransform>
                                            <ScaleTransform x:Name="monitorIconScale" CenterX="7" CenterY="7" ScaleX="1" ScaleY="1"/>
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                    <!-- BADGE (CONTADOR - vermelho com texto branco) -->
                                    <Border x:Name="TaskBadge" Background="#FF4444" CornerRadius="10" MinWidth="20" Height="20"
                                            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,2,2,0"
                                            Visibility="Collapsed">
                                        <Border.RenderTransform>
                                            <ScaleTransform x:Name="TaskBadgeScale" CenterX="10" CenterY="10" ScaleX="1" ScaleY="1"/>
                                        </Border.RenderTransform>
                                        <TextBlock x:Name="TxtTaskCount" Text="0" Foreground="White" FontSize="11" FontWeight="Bold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" Padding="5,0"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="bdr"
                                                               Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                               To="1.1" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetName="bdr"
                                                               Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                               To="1.1" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="bdr"
                                                               Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                               To="1" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetName="bdr"
                                                               Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                               To="1" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                    <Setter TargetName="bdr" Property="Background" Value="#22FFD700"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- BOT&#xC3;O ATUALIZA&#xC7;&#xC3;O (REFRESH) -->
                <Button x:Name="BtnUpdate" Width="40" Height="32" Click="BtnUpdate_Click"
                        Background="Transparent" BorderThickness="0" Margin="0,0,0,0" Cursor="Hand"
                        ToolTip="Verificar Atualiza&#xE7;&#xF5;es">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="4" RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <TextBlock x:Name="refreshIcon" Text="&#x21BB;" Foreground="#2196F3" FontWeight="Bold" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform CenterX="9" CenterY="9"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="bdr"
                                                               Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                               To="1.1" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetName="bdr"
                                                               Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                               To="1.1" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="bdr"
                                                               Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                               To="1" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetName="bdr"
                                                               Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                               To="1" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                    <Setter TargetName="bdr" Property="Background" Value="#222196F3"/>
                                    <Setter TargetName="refreshIcon" Property="Foreground" Value="#FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- BOT&#xC3;O DO CONSOLE (>_) -->
                <Button x:Name="BtnConsole" Width="40" Height="32" Click="BtnConsole_Click"
                        Background="Transparent" BorderThickness="0" Margin="0,0,0,0" Cursor="Hand"
                        ToolTip="Abrir/Fechar Terminal">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="4" RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <TextBlock Text=">_" Foreground="#00FF00" FontWeight="Bold" FontFamily="Consolas" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="bdr"
                                                               Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                               To="1.1" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetName="bdr"
                                                               Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                               To="1.1" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="bdr"
                                                               Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                               To="1" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetName="bdr"
                                                               Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                               To="1" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                    <Setter TargetName="bdr" Property="Background" Value="#2200FF00"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- BOT&#xC3;O DE NOTIFICA&#xC7;&#xD5;ES (SINO + CONTADOR) -->
                <Button x:Name="BtnNotifications" Width="46" Height="32" Click="BtnNotifications_Click"
                        Background="Transparent" BorderThickness="0" Margin="0,0,5,0" Cursor="Hand"
                        ToolTip="Hist&#xF3;rico de Notifica&#xE7;&#xF5;es">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="4" RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <Grid>
                                    <TextBlock Text="&#x1F514;" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>

                                    <!-- BADGE (CONTADOR VERMELHO) -->
                                    <Border x:Name="Badge" Background="#FF4444" CornerRadius="7" MinWidth="14" Height="14" 
                                            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,6,10,0"
                                            Visibility="Collapsed">
                                        <!-- Invis&#xED;vel por padr&#xE3;o -->
                                        <TextBlock x:Name="TxtBadgeCount" Text="0" Foreground="White" FontSize="9" FontWeight="Bold" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" Padding="2,0"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="bdr"
                                                               Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                               To="1.1" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetName="bdr"
                                                               Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                               To="1.1" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="bdr"
                                                               Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                               To="1" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetName="bdr"
                                                               Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                               To="1" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                    <Setter TargetName="bdr" Property="Background" Value="#22FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- BOT&#xD5;ES DE JANELA -->
                <Button Content="&#x2212;" Width="46" Height="32" Foreground="White" Background="Transparent"
                        BorderThickness="0" Click="BtnMinimize_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bdr" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <!-- &#x1F4CD; ANIMA&#xC7;&#xC3;O 17: Transi&#xE7;&#xE3;o suave de cor no bot&#xE3;o minimizar (0.15s) - MainWindow.xaml linha ~160-178 -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetName="bdr"
                                                               Storyboard.TargetProperty="Background.Color"
                                                               To="#33FFFFFF" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetName="bdr"
                                                               Storyboard.TargetProperty="Background.Color"
                                                               To="Transparent" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="&#x25A1;" Width="46" Height="32" Foreground="White" Background="Transparent"
                        BorderThickness="0" Click="BtnMaximize_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bdr" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <!-- &#x1F4CD; ANIMA&#xC7;&#xC3;O 18: Transi&#xE7;&#xE3;o suave de cor no bot&#xE3;o maximizar (0.15s) - MainWindow.xaml linha ~179-197 -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetName="bdr"
                                                               Storyboard.TargetProperty="Background.Color"
                                                               To="#33FFFFFF" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetName="bdr"
                                                               Storyboard.TargetProperty="Background.Color"
                                                               To="Transparent" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button Content="&#x2715;" Width="46" Height="32" Foreground="White" Background="Transparent"
                        BorderThickness="0" Click="BtnClose_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bdr" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <!-- &#x1F4CD; ANIMA&#xC7;&#xC3;O 15: Transi&#xE7;&#xE3;o suave de cor no bot&#xE3;o fechar (0.15s) - MainWindow.xaml linha ~198-217 -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetName="bdr"
                                                               Storyboard.TargetProperty="Background.Color"
                                                               To="#C42B1C" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetName="bdr"
                                                               Storyboard.TargetProperty="Background.Color"
                                                               To="Transparent" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <!-- ========================================================= -->
            <!-- MENU LATERAL (ESQUERDA) -->
            <!-- ========================================================= -->
            <Border x:Name="SidebarPanel" Grid.Row="0" Grid.Column="0" Background="{StaticResource SidebarBackground}"
                    BorderThickness="0,0,1,0" BorderBrush="{StaticResource CardBorder}" Opacity="0">
                <Grid Margin="15,25">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="KIT LUGIA" FontSize="18" FontWeight="Bold" Margin="5,0,0,5" Foreground="{StaticResource AccentColor}">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#FFD700" BlurRadius="12" ShadowDepth="0" Opacity="0.5"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="U L T I M A T E   P E R F O R M A N C E" FontSize="10" Margin="5,0,0,20" Foreground="#808080" FontWeight="SemiBold"/>
                        </StackPanel>
                        <!-- Bot&#xE3;o Configura&#xE7;&#xF5;es (Engrenagem) -->
                        <Button Grid.Column="1" x:Name="BtnSettings"
                                Content="&#x2699;&#xFE0F;"
                                FontSize="16"
                                Width="36" Height="36"
                                Margin="5,0,0,0"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{StaticResource AccentColor}"
                                ToolTip="Configura&#xE7;&#xF5;es do Kit Lugia"
                                Click="BtnSettings_Click"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="6" Padding="8" RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform ScaleX="1" ScaleY="1" CenterX="0.5" CenterY="0.5"/>
                                        </Border.RenderTransform>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <!-- &#x1F4CD; ANIMA&#xC7;&#xC3;O 16: Hover com scale no bot&#xE3;o configura&#xE7;&#xF5;es (0.15s) - MainWindow.xaml linha ~232-261 -->
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="bdr"
                                                                       Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                       To="1.1" Duration="0:0:0.15"/>
                                                        <DoubleAnimation Storyboard.TargetName="bdr"
                                                                       Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                       To="1.1" Duration="0:0:0.15"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="bdr"
                                                                       Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                       To="1.0" Duration="0:0:0.15"/>
                                                        <DoubleAnimation Storyboard.TargetName="bdr"
                                                                       Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                       To="1.0" Duration="0:0:0.15"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                            <Setter TargetName="bdr" Property="Background" Value="#15FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        </Grid>

                        <!-- BARRA DE PESQUISA -->
                        <Grid Grid.Row="1" Margin="0,0,0,15">
                            <Border Background="#20FFFFFF" CornerRadius="6" Height="34" BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#x1F50D;" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="12" Foreground="{StaticResource TextSecondary}"/>

                                    <TextBlock Text="Procurar tweak..." Grid.Column="1" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" 
                                               FontSize="12" FontStyle="Italic" IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=TxtGlobalSearch}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBox x:Name="TxtGlobalSearch" Grid.Column="1" Background="Transparent" BorderThickness="0" 
                                             Foreground="White" VerticalAlignment="Center" FontSize="13" 
                                             CaretBrush="{StaticResource AccentColor}"
                                             TextChanged="TxtGlobalSearch_TextChanged"
                                             PreviewKeyDown="TxtGlobalSearch_PreviewKeyDown"/>
                                </Grid>
                            </Border>

                            <Popup x:Name="SearchPopup" PlacementTarget="{Binding ElementName=TxtGlobalSearch}" 
                                   StaysOpen="False" AllowsTransparency="True" PopupAnimation="Slide" VerticalOffset="5">
                                <Border Background="#1A1A1A" BorderBrush="{StaticResource AccentColor}" BorderThickness="1" CornerRadius="6" Width="250" MaxHeight="300">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="5" Opacity="0.8"/>
                                    </Border.Effect>
                                    <ListBox x:Name="LstSearchResults" Background="Transparent" BorderThickness="0" 
                                             Foreground="White" SelectionChanged="LstSearchResults_SelectionChanged">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="10,8"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="bdr" Background="Transparent" CornerRadius="4">
                                                                <ContentPresenter/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="bdr" Property="Background" Value="#33FFD700"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource AccentColor}"/>
                                                    <TextBlock Text="{Binding Description}" FontSize="10" Foreground="#AAA" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Popup>
                        </Grid>

                    <!-- ITENS DE MENU -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Hidden">
                        <StackPanel>
                            <RadioButton x:Name="BtnDashboard" GroupName="Menu" Tag="&#x1F3E0;" Content="Sistema (In&#xED;cio)" IsChecked="True" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>
                            <RadioButton x:Name="BtnTweaks"    GroupName="Menu" Tag="&#x26A1;" Content="Desempenho" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>
                            <RadioButton x:Name="BtnApps"      GroupName="Menu" Tag="&#x1F4F1;" Content="Aplicativos" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>
                            <RadioButton x:Name="BtnStorage"   GroupName="Menu" Tag="&#x1F4BF;" Content="Armazenamento" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>
                            <RadioButton x:Name="BtnPartitions" GroupName="Menu" Tag="&#x1F4BD;" Content="Gerenciar Discos" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>
                            <RadioButton x:Name="BtnNetwork"   GroupName="Menu" Tag="&#x1F310;" Content="Rede e Internet" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>
                            <RadioButton x:Name="BtnGames"     GroupName="Menu" Tag="&#x1F3AE;" Content="Jogos" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>
                            <RadioButton x:Name="BtnDrivers"   GroupName="Menu" Tag="&#x1F4BE;" Content="Drivers" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>
                            <RadioButton x:Name="BtnRepairs"   GroupName="Menu" Tag="&#x1F527;" Content="Reparos AIO" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>
                            <RadioButton x:Name="BtnServices"  GroupName="Menu" Tag="&#x1F6E1;&#xFE0F;" Content="Servi&#xE7;os" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- RODAP&#xC9; DO MENU (SOBRE + MONITOR) -->
                    <StackPanel Grid.Row="3">
                        <Separator Background="{StaticResource CardBorder}" Margin="0,10" Opacity="0.5"/>
                        <RadioButton x:Name="BtnTray" GroupName="Menu" Tag="&#x1F514;" Content="&#x1F4E1; Monitor RAM (Tray)" 
                                     Style="{StaticResource NavButtonStyle}" 
                                     Foreground="{StaticResource TextMuted}"
                                     Click="NavButton_Click"
                                     ToolTip="Configura&#xE7;&#xF5;es do &#xED;cone na bandeja e monitor de RAM"/>
                        <!-- BOT&#xC3;O GAMEBOOST PRO (ANTIGO SOBRE) -->
                        <RadioButton x:Name="BtnGameBoost" GroupName="Menu" Tag="&#x1F680;" Content="GameBoost Pro" 
                                     Style="{StaticResource NavButtonStyle}" 
                                     Foreground="{StaticResource AccentColor}"
                                     Click="NavButton_Click"
                                     ToolTip="GameBoost Inteligente - Algoritmo ProBalance Style"/>
                        
                        <!-- BOT&#xC3;O DIAGN&#xD3;STICO -->
                        <RadioButton x:Name="BtnDiagnostic" GroupName="Menu" Tag="&#x1F52C;" Content="Diagn&#xF3;stico (Debug)" 
                                     Style="{StaticResource NavButtonStyle}" 
                                     Foreground="#FF4444"
                                     Click="NavButton_Click"
                                     ToolTip="Diagn&#xF3;stico interno - Monitorar timers e leaks"/>
                        <!-- Stutter removido da sidebar — acessível via barra de busca -->

                    </StackPanel>
                </Grid>
            </Border>

            <!-- ========================================================= -->
            <!-- CONTE&#xDA;DO PRINCIPAL (DIREITA) -->
            <!-- ========================================================= -->
            <!-- &#x1F4CD; ANIMA&#xC7;&#xC3;O 5: Fade-in ao navegar entre p&#xE1;ginas (0.25s) - MainWindow.xaml linha ~357 -->
            <Frame x:Name="MainFrame" Grid.Row="0" Grid.Column="1" NavigationUIVisibility="Hidden" Background="Transparent" Margin="0,32,0,0" Panel.ZIndex="1" Navigated="MainFrame_Navigated" Opacity="0">
                <Frame.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1" CenterX="0.5" CenterY="0.5"/>
                </Frame.RenderTransform>
            </Frame>

            <!-- TOASTS (Notifica&#xE7;&#xF5;es Flutuantes) -->
            <StackPanel x:Name="ToastContainer"
                        Grid.Row="0" Grid.Column="1"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Right"
                        Margin="0,40,20,0"
                        Panel.ZIndex="99998"
                        Background="{x:Null}"/>

            <!-- NOTIFICA&#xC7;&#xC3;O DE A&#xC7;&#xC3;O (Update, etc.) -->
            <StackPanel x:Name="ActionNotificationContainer"
                        Grid.Row="0" Grid.Column="1"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Right"
                        Margin="0,40,20,0"
                        Panel.ZIndex="99997"
                        Background="{x:Null}"/>

            <!-- &#x1F525; INDICADOR DE TAREFAS EM SEGUNDO PLANO -->
            <Border x:Name="BackgroundTaskIndicator"
                    Grid.Row="0" Grid.Column="1"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Right"
                    Margin="0,80,20,0"
                    Panel.ZIndex="25001"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12,8"
                    Width="300"
                    Visibility="Collapsed"
                    Opacity="0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="BorderBrush" Value="#80333333"/>
                        <Setter Property="Background">
                            <Setter.Value>
                                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                    <GradientStop Color="#CC2A2A2A" Offset="0"/>
                                    <GradientStop Color="#802A2A2A" Offset="1"/>
                                </LinearGradientBrush>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="5" Opacity="0.5"/>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <!-- &#x1F4CD; ANIMA&#xC7;&#xC3;O 14: Fade-in do BackgroundTaskIndicator (0.3s) - MainWindow.xaml linha ~373-410 -->
                            <Trigger Property="Visibility" Value="Visible">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                           From="0" To="1" Duration="0:0:0.3">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Spinner Animado + ícones de resultado -->
                    <controls:TaskStatusIndicator x:Name="TaskStatusIcon"
                                                  Grid.Column="0"
                                                  Margin="0,0,8,0"
                                                  VerticalAlignment="Center"/>

                    <!-- Texto + ProgressBar -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="BackgroundTaskCount"
                                   Text="0 tarefas em execu&#xE7;&#xE3;o"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock x:Name="BackgroundTaskPages"
                                   Text=""
                                   FontSize="9"
                                   Foreground="#888888"
                                   Margin="0,1,0,0"/>
                        <!-- ⬇️ NOVO: Barra de progresso para tarefas com percentual reportado -->
                        <ProgressBar x:Name="BackgroundTaskProgressBar"
                                     Height="3"
                                     Margin="0,4,0,0"
                                     Foreground="#FFD700"
                                     Background="#20FFFFFF"
                                     BorderThickness="0"
                                     Visibility="Collapsed"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="0"/>
                    </StackPanel>

                    <!-- Bot&#xE3;o Fechar -->
                    <Button x:Name="CloseBackgroundTaskIndicator"
                            Grid.Column="2"
                            Content="&#x2715;"
                            FontSize="11"
                            Foreground="#888888"
                            Background="Transparent"
                            BorderThickness="0"
                            Margin="5,0,8,0"
                            Cursor="Hand"
                            Padding="4"
                            Click="CloseBackgroundTaskIndicator_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="4" Padding="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bdr" Property="Background" Value="#15FFFFFF"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- ========================================================= -->
            <!-- PAIN&#xC9;IS FLUTUANTES (Sobreposi&#xE7;&#xF5;es) -->
            <!-- ========================================================= -->

            <!-- Monitor de Tarefas em Segundo Plano -->
            <Border x:Name="BackgroundMonitorPanel" Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="2"
                    Panel.ZIndex="20000" Visibility="Collapsed"
                    Background="#88000000">
                <Border Background="#DD1A1A1A" BorderBrush="{StaticResource AccentColor}" BorderThickness="2"
                        CornerRadius="12" Width="650" MaxHeight="550"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Padding="20">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="30" ShadowDepth="10" Opacity="0.8"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Cabe&#xE7;alho -->
                        <Grid Grid.Row="0" Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="&#x2699;&#xFE0F; Monitor de Tarefas em Segundo Plano" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentColor}"/>
                                <TextBlock x:Name="MonitorSubtitle" Text="Nenhuma tarefa em execu&#xE7;&#xE3;o" FontSize="12" Foreground="#888" Margin="0,5,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="&#x2715;" Width="32" Height="32" Background="Transparent" BorderThickness="0"
                                    Foreground="#FFD700" Cursor="Hand" Click="CloseBackgroundMonitor_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bdr" Property="Background" Value="#15FFFFFF"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <!-- Lista de Tarefas -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="BackgroundTasksList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DataTemplate.Resources>
                                            <Style TargetType="TextBlock" x:Key="TaskStatusIconStyle">
                                                <Setter Property="Foreground" Value="#FFD700"/>
                                                <Setter Property="FontSize" Value="20"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                        <Setter Property="Foreground" Value="#C42B1C"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                        <Setter Property="Foreground" Value="#888888"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                            <Style TargetType="Border" x:Key="TaskStatusBadgeStyle">
                                                <Setter Property="Background" Value="#33FFD700"/>
                                                <Setter Property="BorderBrush" Value="#FFD700"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="MinWidth" Value="100"/>
                                                <Setter Property="MinHeight" Value="28"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                        <Setter Property="Background" Value="#334CAF50"/>
                                                        <Setter Property="BorderBrush" Value="#4CAF50"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                        <Setter Property="Background" Value="#33C42B1C"/>
                                                        <Setter Property="BorderBrush" Value="#C42B1C"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                        <Setter Property="Background" Value="#22888888"/>
                                                        <Setter Property="BorderBrush" Value="#888888"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                            <Style TargetType="TextBlock" x:Key="TaskStatusTextStyle">
                                                <Setter Property="Foreground" Value="#FFD700"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="TextAlignment" Value="Center"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                        <Setter Property="Foreground" Value="#C42B1C"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                        <Setter Property="Foreground" Value="#888888"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataTemplate.Resources>
                                        <Border CornerRadius="8" BorderThickness="1" BorderBrush="#333"
                                                Padding="18,14" Margin="0,0,0,12">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#66222222"/>
                                                    <Style.Triggers>
                                                        <!-- Tarefas conclu&#xED;das ainda mais transparentes -->
                                                        <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                            <Setter Property="Background" Value="#22222222"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                            <Setter Property="Background" Value="#22222222"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                            <Setter Property="Background" Value="#22222222"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- &#xCD;cone de Status com Badge de Stack -->
                                                <Grid Grid.Column="0" Margin="0,0,14,0">
                                                    <TextBlock Text="&#x2699;&#xFE0F;" VerticalAlignment="Center" Style="{StaticResource TaskStatusIconStyle}" x:Name="TaskIcon"/>
                                                    <!-- Badge de Stack Count (estilo igual notifica&#xE7;&#xF5;es) -->
                                                    <Border x:Name="StackBadge" Background="#40FFFFFF" CornerRadius="10"
                                                            Height="20" MinWidth="20" Margin="0,-6,-6,0" VerticalAlignment="Top" HorizontalAlignment="Right"
                                                            Visibility="{Binding StackCount, Converter={StaticResource StackCountVisibilityConverter}}">
                                                        <Border.RenderTransform>
                                                            <ScaleTransform x:Name="StackBadgeScale" CenterX="10" CenterY="10" ScaleX="1" ScaleY="1"/>
                                                        </Border.RenderTransform>
                                                        <TextBlock x:Name="StackCountText" Text="{Binding StackCount, StringFormat='x{0}'}" Foreground="White" FontSize="11" FontWeight="Bold"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" Padding="5,0"/>
                                                    </Border>
                                                </Grid>

                                                <!-- Informa&#xE7;&#xF5;es da Tarefa -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding TaskName}" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                                    <TextBlock Text="{Binding PageName}" FontSize="11" Foreground="#AAA" Margin="0,3,0,0"/>
                                                    <TextBlock FontSize="11" Foreground="#888" Margin="0,3,0,0">
                                                        <Run Text="In&#xED;cio: "/>
                                                        <Run Text="{Binding StartTime, StringFormat='{}{0:HH:mm:ss}'}"/>
                                                    </TextBlock>
                                                    <TextBlock FontSize="11" Foreground="#888" Margin="0,3,0,0">
                                                        <Run Text="Dura&#xE7;&#xE3;o: "/>
                                                        <Run Text="{Binding Duration, Converter={StaticResource DurationConverter}, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- Status Badge -->
                                                <Border Grid.Column="2" CornerRadius="6" Padding="12,6" Style="{StaticResource TaskStatusBadgeStyle}" VerticalAlignment="Center">
                                                    <TextBlock Style="{StaticResource TaskStatusTextStyle}"
                                                               Text="{Binding Status, Converter={StaticResource TaskStatusConverter}}"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Rodap&#xE9; -->
                        <StackPanel Grid.Row="2" Margin="0,15,0,0">
                            <Separator Background="#333" Margin="0,0,0,10"/>
                            <Button Content="Limpar Hist&#xF3;rico" Height="35" Background="#333" Foreground="White"
                                    BorderThickness="0" Cursor="Hand" Click="ClearCompletedTasks_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="6" Padding="15,0">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bdr" Property="Background" Value="#444"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Border>

            <!-- Container de Toasts de Tarefas em Segundo Plano -->
            <StackPanel x:Name="BackgroundTaskToasts" Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="2"
                        Panel.ZIndex="25000"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,80,10,0"
                        Orientation="Vertical"/>

            <!-- Central de Notifica&#xE7;&#xF5;es (Sino) -->
            <controls:NotificationCenter x:Name="NotifPanel" Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="2"
                                         Panel.ZIndex="20000" Visibility="Collapsed"/>

            <!-- Modal Overlay (Di&#xE1;logos) -->
            <Grid x:Name="OverlayContainer" Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="2" 
                  Panel.ZIndex="10000" Visibility="Collapsed" Background="#CC000000">
                <Border x:Name="OverlayConfirm" Background="{StaticResource CardBackground}" BorderBrush="{StaticResource AccentColor}" 
                        BorderThickness="1" CornerRadius="15" Width="450" VerticalAlignment="Center" HorizontalAlignment="Center" 
                        Padding="30" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="CONFIRMA&#xC7;&#xC3;O" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentColor}" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtConfirmMessage" Text="Deseja continuar?" Foreground="White" FontSize="14" Margin="0,0,0,30" TextAlignment="Center" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="N&#xC3;O" Click="BtnConfirmNo_Click" Style="{StaticResource SecondaryButtonStyle}" Width="120" Height="40" Margin="0,0,15,0"/>
                            <Button Content="SIM" Click="BtnConfirmYes_Click" Style="{StaticResource GoldButtonStyle}" Width="120" Height="40" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ========================================================= -->
            <!-- LOADING OVERLAY -->
            <!-- ========================================================= -->
            <controls:LoadingOverlay x:Name="LoadingOverlay" Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="2" 
                                   Visibility="Collapsed" Panel.ZIndex="99999"/>

            <!-- ========================================================= -->
            <!-- CONSOLE GLOBAL (Terminal no Rodap&#xE9;) -->
            <!-- ========================================================= -->
            <!-- Fica na Row 1, ocupa toda a largura (ColumnSpan 2), Altura definida no controle (200) -->
            <controls:GlobalConsole x:Name="GlobalConsolePanel" 
                                    Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                    Visibility="Collapsed" 
                                    Height="180" 
                                    Panel.ZIndex="15000"/>

            <!-- ========================================================= -->
            <!-- TERMINAL INTERATIVO (LEGACY MODE) -->
            <!-- ========================================================= -->
            <controls:InteractiveTerminal x:Name="LegacyTerminalPanel"
                                          Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="2"
                                          Visibility="Collapsed"
                                          Panel.ZIndex="30000"
                                          Width="950" Height="650"
                                          HorizontalAlignment="Center" VerticalAlignment="Center">
                <controls:InteractiveTerminal.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="50" ShadowDepth="10" Opacity="0.8"/>
                </controls:InteractiveTerminal.Effect>
            </controls:InteractiveTerminal>

        </Grid>
    </Border>
</Window>