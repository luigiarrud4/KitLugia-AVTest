<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="KitLugia.GUI.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Sistema"
      TextElement.FontFamily="Segoe UI Variable Display, Segoe UI, Segoe UI Emoji, Segoe UI Symbol, Arial">

    <Page.Resources>
        <ControlTemplate x:Key="GameBoostComboBoxToggleButton" TargetType="{x:Type ToggleButton}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="36" />
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" CornerRadius="5" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" />
                <Path x:Name="Arrow" Grid.Column="1" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M0,0 L5,5 L10,0" IsHitTestVisible="False"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#2A2A2A" />
                    <Setter TargetName="Border" Property="BorderBrush" Value="#666666" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="DarkComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#222222"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton Name="ToggleButton" Template="{StaticResource GameBoostComboBoxToggleButton}" Grid.Column="2" Focusable="false" IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Cursor="Hand"/>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="10,0,30,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide" StaysOpen="False">
                                <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#222222" BorderThickness="1" BorderBrush="#444444" CornerRadius="5"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#222"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#333"/>
                    <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#444"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InfoButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Help"/>
            <Setter Property="ToolTipService.InitialShowDelay" Value="0"/>
            <Setter Property="ToolTipService.ShowDuration" Value="20000"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40,30,40,50" MaxWidth="850" HorizontalAlignment="Left">

                <!-- T&#xCD;TULO -->
                <TextBlock Text="Sistema" FontSize="36" FontWeight="SemiBold" Margin="0,0,0,25" Foreground="{StaticResource TextPrimary}"/>

                <!-- BANNER INFORMATIVO (INFO PC) -->
                <Border Background="{StaticResource CardBackground}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,25" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Imagem PC -->
                        <TextBlock Text="&#x1F4BB;" FontSize="48" VerticalAlignment="Center" Margin="0,0,20,0"/>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtPCName" Text="DESKTOP-NAME" FontSize="20" FontWeight="Bold"/>
                            <TextBlock x:Name="TxtSpecs" Text="Carregando informa&#xE7;&#xF5;es..." FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,3,0,0" TextWrapping="Wrap"/>
                            <TextBlock Text="Kit Lugia - Ativo" FontSize="12" Foreground="{StaticResource AccentColor}" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- === NOVA SE&#xC7;&#xC3;O: A&#xC7;&#xD5;ES DE 1-CLIQUE === -->
                <TextBlock Text="Otimiza&#xE7;&#xE3;o Inteligente (1-Clique)" FontSize="16" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,15" FontWeight="SemiBold"/>

                <Grid Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- BOT&#xC3;O 1: OTIMIZA&#xC7;&#xC3;O INTELIGENTE (VERDE) -->
                    <Button Grid.Column="0" Height="90" Click="BtnOpenQuickMenu_Click" Cursor="Hand" ToolTip="Abre o menu de personaliza&#xE7;&#xE3;o da otimiza&#xE7;&#xE3;o inteligente.">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bdr" Background="#104CAF50" BorderBrush="#334CAF50" BorderThickness="1" CornerRadius="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- &#xCD;cone -->
                                        <Border Background="#154CAF50" CornerRadius="10,0,0,10">
                                            <TextBlock Text="&#x1F680;" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Texto -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0">
                                            <TextBlock Text="OTIMIZA&#xC7;&#xC3;O INTELIGENTE" FontWeight="Bold" Foreground="White" FontSize="14"/>
                                            <TextBlock Text="Personalizar &amp; Aplicar" Foreground="#81C784" FontSize="12" FontWeight="Bold" Margin="0,2,0,0"/>
                                            <TextBlock Text="Escolha sua GPU e n&#xED;vel de VRAM dedicada." Foreground="#999" FontSize="10" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bdr" Property="Background" Value="#254CAF50"/>
                                        <Setter TargetName="bdr" Property="BorderBrush" Value="#4CAF50"/>
                                        <Setter TargetName="bdr" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#4CAF50" BlurRadius="15" Opacity="0.3" ShadowDepth="0"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- BOT&#xC3;O 2: REVERTER / NORMAL (VERMELHO) -->
                    <Button Grid.Column="2" Height="90" Click="BtnRevertNormal_Click" Cursor="Hand" ToolTip="Remove todas as otimiza&#xE7;&#xF5;es aplicadas e volta ao padr&#xE3;o do Windows.">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bdr" Background="#10F44336" BorderBrush="#33F44336" BorderThickness="1" CornerRadius="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- &#xCD;cone -->
                                        <Border Background="#15F44336" CornerRadius="10,0,0,10">
                                            <TextBlock Text="&#x21A9;&#xFE0F;" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Texto -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0">
                                            <TextBlock Text="REVERTER / NORMAL" FontWeight="Bold" Foreground="White" FontSize="14"/>
                                            <TextBlock Text="Restaurar Padr&#xF5;es" Foreground="#E57373" FontSize="12" FontWeight="Bold" Margin="0,2,0,0"/>
                                            <TextBlock Text="Remove VRAM, Tweaks e Planos de Energia." Foreground="#999" FontSize="10" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bdr" Property="Background" Value="#25F44336"/>
                                        <Setter TargetName="bdr" Property="BorderBrush" Value="#F44336"/>
                                        <Setter TargetName="bdr" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#F44336" BlurRadius="15" Opacity="0.3" ShadowDepth="0"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
                

                
                <!-- === SE&#xC7;&#xC3;O: GAMING LATENCY PROFILE === -->
                <TextBlock Text="Gaming Latency Profile (Baixa Lat&#xEA;ncia)" FontSize="16" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,15" FontWeight="SemiBold"/>

                <Grid Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- BOT&#xC3;O 1: GAMING LATENCY PROFILE (DOURO/&#xC2;MBAR) -->
                    <Button Grid.Column="0" Height="90" Click="BtnOpenLatencyMenu_Click" Cursor="Hand" ToolTip="Abre o menu de otimiza&#xE7;&#xE3;o de lat&#xEA;ncia para gaming (estilo Khorvie)">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bdr" Background="#10FFD700" BorderBrush="#33FFD700" BorderThickness="1" CornerRadius="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- &#xCD;cone -->
                                        <Border Background="#15FFD700" CornerRadius="10,0,0,10">
                                            <TextBlock Text="&#x26A1;" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Texto -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0">
                                            <TextBlock Text="GAMING LATENCY" FontWeight="Bold" Foreground="White" FontSize="14"/>
                                            <TextBlock Text="Baixa Lat&#xEA;ncia" Foreground="#FFD700" FontSize="12" FontWeight="Bold" Margin="0,2,0,0"/>
                                            <TextBlock Text="Otimiza DPC/ISR, timers e input para m&#xED;nima lat&#xEA;ncia." Foreground="#999" FontSize="10" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bdr" Property="Background" Value="#25FFD700"/>
                                        <Setter TargetName="bdr" Property="BorderBrush" Value="#FFD700"/>
                                        <Setter TargetName="bdr" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#FFD700" BlurRadius="15" Opacity="0.3" ShadowDepth="0"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- BOT&#xC3;O 2: REVERTER LATENCY (CINZA) -->
                    <Button Grid.Column="2" Height="90" Click="BtnRevertLatency_Click" Cursor="Hand" ToolTip="Remove todas as otimiza&#xE7;&#xF5;es de lat&#xEA;ncia e volta ao padr&#xE3;o do Windows.">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bdr" Background="#10666666" BorderBrush="#33666666" BorderThickness="1" CornerRadius="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- &#xCD;cone -->
                                        <Border Background="#15666666" CornerRadius="10,0,0,10">
                                            <TextBlock Text="&#x21A9;&#xFE0F;" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Texto -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0">
                                            <TextBlock Text="REVERTER LATENCY" FontWeight="Bold" Foreground="White" FontSize="14"/>
                                            <TextBlock Text="Padr&#xE3;o Windows" Foreground="#999" FontSize="12" FontWeight="Bold" Margin="0,2,0,0"/>
                                            <TextBlock Text="Restaura Win32Priority, Core Parking e timers." Foreground="#999" FontSize="10" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bdr" Property="Background" Value="#25666666"/>
                                        <Setter TargetName="bdr" Property="BorderBrush" Value="#666666"/>
                                        <Setter TargetName="bdr" Property="Effect">
                                            <Setter.Value>
                                                <DropShadowEffect Color="#666666" BlurRadius="15" Opacity="0.3" ShadowDepth="0"/>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
                
                <!-- A LISTA DE CART&#xD5;ES (NAVEGA&#xC7;&#xC3;O COMPLETA) -->
                <TextBlock Text="Gerenciamento do Sistema" FontSize="16" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10" FontWeight="SemiBold"/>

                <!-- OTIMIZACAO E PERFORMANCE -->
                <TextBlock Text="Performance e Otimiza&#xE7;&#xE3;o" FontSize="12" Foreground="{StaticResource AccentColor}" Margin="0,10,0,5" FontWeight="SemiBold"/>

                <Button Style="{StaticResource SettingsCardStyle}" Tag="&#x26A1;" 
                    Content="Otimiza&#xE7;&#xF5;es Avan&#xE7;adas"
                    ToolTip="Gerenciar otimiza&#xE7;&#xF5;es de registro, prioridade de CPU e servi&#xE7;os"
                    Click="BtnGoToTweaks_Click"/>

                <Button Style="{StaticResource SettingsCardStyle}" Tag="&#x1F4BF;" 
                    Content="Armazenamento e Limpeza"
                    ToolTip="Limpar arquivos tempor&#xE1;rios, shaders e bloatware"
                    Click="BtnGoToCleanup_Click"/>

                <Button Style="{StaticResource SettingsCardStyle}" Tag="&#x1F4F1;" 
                    Content="Bloatware e Aplicativos"
                    ToolTip="Remover aplicativos desnecess&#xE1;rios do Windows"
                    Click="BtnGoToBloatware_Click"/>

                <Button Style="{StaticResource SettingsCardStyle}" Tag="&#x1F680;" 
                    Content="GameBoost Pro"
                    ToolTip="Otimiza&#xE7;&#xE3;o inteligente de processos em tempo real"
                    Click="BtnGoToGameBoost_Click"/>

                <Button Style="{StaticResource SettingsCardStyle}" Tag="&#x1F3AE;" 
                    Content="Games e Modo Jogo"
                    ToolTip="Configura&#xE7;&#xF5;es de jogos e otimiza&#xE7;&#xF5;es para games"
                    Click="BtnGoToGames_Click"/>

                <Button Style="{StaticResource SettingsCardStyle}" Tag="&#x1F4CB;" 
                    Content="Ferramentas de Sistema"
                    ToolTip="SFC, DISM, limpeza de caches, rede, BCDedit, servi&#xE7;os e manuten&#xE7;&#xE3;o"
                    Click="BtnGoToExmTweaks_Click"/>

                <!-- SISTEMA E REPAROS -->
                <TextBlock Text="Sistema e Reparos" FontSize="12" Foreground="{StaticResource AccentColor}" Margin="0,15,0,5" FontWeight="SemiBold"/>

                <Button Style="{StaticResource SettingsCardStyle}" Tag="&#x1F4C0;" 
                    Content="ISO Editor (Winhance)"
                    ToolTip="Editor de ISO Profissional - Montagem, Debloat, Features e Redu&#xE7;&#xE3;o de Tamanho"
                    Click="BtnGoToIsoEditor_Click"/>

                <Button Style="{StaticResource SettingsCardStyle}" Tag="&#x1F4BD;" 
                    Content="Gerenciador de Discos"
                    ToolTip="Gerenciador de parti&#xE7;&#xF5;es e discos"
                    Click="BtnGoToPartitions_Click"/>

                <Button Style="{StaticResource SettingsCardStyle}" Tag="&#x1F4E6;" 
                    Content="Consertar Windows via ISO Montada"
                    ToolTip="Monta uma ISO do Windows 11 e repara o sistema via DISM + SFC diretamente da imagem montada. Essencial quando o component store est&#xE1; corrompido."
                    Click="BtnConsertarViaIso_Click"/>

                <Button Style="{StaticResource SettingsCardStyle}" Tag="&#x1F4BB;" 
                    Content="WinBoot (Instala&#xE7;&#xE3;o Windows)"
                    ToolTip="Instala&#xE7;&#xE3;o local do Windows sem USB - ISO, Parti&#xE7;&#xE3;o e WinBoot"
                    Click="BtnGoToWinBoot_Click"/>

                <Button Style="{StaticResource SettingsCardStyle}" Tag="&#x26A1;" 
                    Content="Instala&#xE7;&#xE3;o R&#xE1;pida (Quick Install)"
                    ToolTip="Selecione uma ISO, uma parti&#xE7;&#xE3;o e instale o Windows diretamente com DISM"
                    Click="BtnGoToQuickInstall_Click"/>

                <Button Style="{StaticResource SettingsCardStyle}" Tag="&#x1F4BF;" 
                    Content="Rufus (Pendrive Boot&#xE1;vel)"
                    ToolTip="Criar pendrives boot&#xE1;veis a partir de ISOs (Windows, Linux, WinPE)"
                    Click="BtnGoToRufus_Click"/>

                <Button Style="{StaticResource SettingsCardStyle}" Tag="&#x1F527;" 
                    Content="Reparos do Sistema"
                    ToolTip="Ferramentas de reparo do Windows"
                    Click="BtnGoToRepairs_Click"/>

                <Button Style="{StaticResource SettingsCardStyle}" Tag="&#x1F4BE;" 
                    Content="Drivers do Sistema"
                    ToolTip="Gerenciamento e atualiza&#xE7;&#xE3;o de drivers"
                    Click="BtnGoToDrivers_Click"/>

                <!-- REDE E INTERNET -->
                <TextBlock Text="Rede e Conectividade" FontSize="12" Foreground="{StaticResource AccentColor}" Margin="0,15,0,5" FontWeight="SemiBold"/>

                <Button Style="{StaticResource SettingsCardStyle}" Tag="&#x1F310;" 
                    Content="Otimizador de Rede (Ping)"
                    ToolTip="Ajustes de DNS, TCP/IP e Adaptador para menor lat&#xEA;ncia"
                    Click="BtnGoToNetwork_Click"/>

                <!-- PRIVACIDADE E SEGURANCA -->
                <TextBlock Text="Privacidade e Seguran&#xE7;a" FontSize="12" Foreground="{StaticResource AccentColor}" Margin="0,15,0,5" FontWeight="SemiBold"/>

                <Button Style="{StaticResource SettingsCardStyle}" Tag="&#x1F512;" 
                    Content="Privacidade e Telemetria (O&amp;O ShutUp10)"
                    ToolTip="Desativar Telemetria, Defender e controle de privacidade completo"
                    Click="BtnGoToPrivacy_Click"/>

                
                <Button Style="{StaticResource SettingsCardStyle}" Tag="&#x1F510;" 
                    Content="Seguran&#xE7;a do Sistema"
                    ToolTip="Verificar status de seguran&#xE7;a e configura&#xE7;&#xF5;es de prote&#xE7;&#xE3;o"
                    Click="BtnGoToSecurity_Click"/>

                <Button Style="{StaticResource SettingsCardStyle}" Tag="&#x1F9F0;" 
                    Content="Integridade do Sistema (Scan)"
                    ToolTip="Verificar arquivos de sistema, DISM e reparos"
                    Click="BtnGoToIntegrity_Click"/>

                <!-- ATIVACAO E CONFIGURACOES -->
                <TextBlock Text="Ativa&#xE7;&#xE3;o e Configura&#xE7;&#xF5;es" FontSize="12" Foreground="{StaticResource AccentColor}" Margin="0,15,0,5" FontWeight="SemiBold"/>

                <Button Style="{StaticResource SettingsCardStyle}" Tag="&#x1F511;" 
                    Content="Microsoft Activation Scripts"
                    ToolTip="Verificar status de ativa&#xE7;&#xE3;o do Windows e Office"
                    Click="BtnGoToActivation_Click"/>

                <Button Style="{StaticResource SettingsCardStyle}" Tag="&#x1F514;" 
                    Content="Configura&#xE7;&#xF5;es do TrayIcon"
                    ToolTip="Configurar &#xED;cone da bandeja, RAM e GameBoost"
                    Click="BtnGoToTraySettings_Click"/>

                <Button Style="{StaticResource SettingsCardStyle}" Tag="&#x1F504;" 
                    Content="Atualiza&#xE7;&#xF5;es do Kit Lugia"
                    ToolTip="Verificar e instalar atualiza&#xE7;&#xF5;es do aplicativo"
                    Click="BtnGoToUpdate_Click"/>

                <!-- EXTRAS -->
                <TextBlock Text="Extras" FontSize="12" Foreground="{StaticResource AccentColor}" Margin="0,15,0,5" FontWeight="SemiBold"/>

                <Button Style="{StaticResource SettingsCardStyle}" Tag="&#x1F5A5;&#xFE0F;" 
                    Content="Tela e Cores (Screen)"
                    ToolTip="Configura&#xE7;&#xF5;es de tela, resolu&#xE7;&#xE3;o e cores"
                    Click="BtnGoToScreen_Click"/>

                <Button Style="{StaticResource SettingsCardStyle}" Tag="&#x1F50B;" 
                    Content="Gerenciador de Planos de Energia"
                    ToolTip="Gerenciar planos de energia, Bitsum Highest Performance e Ultimate Performance"
                    Click="BtnGoToPowerPlans_Click"/>

                <TextBlock Text="Utilit&#xE1;rios" FontSize="12" Foreground="{StaticResource AccentColor}" Margin="0,15,0,5" FontWeight="SemiBold"/>

                <Button Style="{StaticResource SettingsCardStyle}" Tag="&#x1F3B5;" 
                    Content="WinTune Optimizations"
                    ToolTip="Otimiza&#xE7;&#xF5;es avan&#xE7;adas do WinTune"
                    Click="BtnGoToWinTune_Click"/>

                <Button Style="{StaticResource SettingsCardStyle}" Tag="&#x2702;&#xFE0F;"
                    Content="Shrink &amp; Recovery (UEFI)"
                    ToolTip="Reduzir partição e criar ambiente de recuperação UEFI com rEFInd + Alpine"
                    Click="BtnGoToShrink_Click"/>

            </StackPanel>
        </ScrollViewer>

        <!-- OVERLAY: MENU DE SELE&#xC7;&#xC3;O R&#xC1;PIDA -->
        <Grid x:Name="OverlayQuickMenu" Visibility="Collapsed" Background="#CC000000">
            <Border Width="820" VerticalAlignment="Center" HorizontalAlignment="Center" 
                    Background="#1E1E1E" BorderBrush="#333" BorderThickness="1" CornerRadius="12" MaxHeight="680">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Configurar Otimiza&#xE7;&#xE3;o" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ===== COLUNA ESQUERDA: MENU ORIGINAL ===== -->
                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Adaptador de V&#xED;deo (GPU):" Foreground="#AAA" FontSize="12" Margin="0,0,0,5"/>
                                <ComboBox x:Name="CmbGpu" Height="30" Margin="0,0,0,10">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="White" Padding="5"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <TextBlock Text="VRAM Dedicada (Segment Size):" Foreground="#AAA" FontSize="12" Margin="0,0,0,5"/>
                                <ComboBox x:Name="CmbVram" Height="30" Margin="0,0,0,10">
                                    <ComboBoxItem Content="Padr&#xE3;o (Autom&#xE1;tico)" IsSelected="True" Foreground="White"/>
                                    <ComboBoxItem Content="256 MB" Foreground="White"/>
                                    <ComboBoxItem Content="512 MB" Foreground="White"/>
                                    <ComboBoxItem Content="1024 MB (1GB)" Foreground="White"/>
                                    <ComboBoxItem Content="2048 MB (2GB)" Foreground="White"/>
                                    <ComboBoxItem Content="4096 MB (4GB)" Foreground="White"/>
                                </ComboBox>

