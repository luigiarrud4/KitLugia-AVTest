                                        <TextBlock Text="ℹ️" FontSize="12" Foreground="#FFD700" Opacity="0.6"/>
                                    </Button>
                                </StackPanel>
                            </CheckBox>
                            <CheckBox x:Name="ChkDisableMSDefender" Margin="0,5" Foreground="{StaticResource TextPrimary}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Desativar Microsoft Defender" VerticalAlignment="Center" IsHitTestVisible="False"/>
                                    <Button Style="{StaticResource InfoButtonStyle}">
                                        <Button.ToolTip>
                                            <ToolTip>
                                                <StackPanel>
                                                    <TextBlock Text="Desativa Microsoft Defender" FontWeight="Bold" Foreground="#FF6B6B" TextWrapping="Wrap"/>
                                                    <TextBlock Text="✓ Prós: Melhora performance, reduz uso de recursos" TextWrapping="Wrap"/>
                                                    <TextBlock Text="✗ Contras: Remove proteção antivírus nativa" TextWrapping="Wrap"/>
                                                    <TextBlock Text="⚠️ Riscos: MUITO ALTO - sistema fica vulnerável" TextWrapping="Wrap"/>
                                                    <TextBlock Text="💡 Recomendação: NÃO RECOMENDADO - use outro AV primeiro" TextWrapping="Wrap"/>
                                                </StackPanel>
                                            </ToolTip>
                                        </Button.ToolTip>
                                        <TextBlock Text="ℹ️" FontSize="12" Foreground="#FFD700" Opacity="0.6"/>
                                    </Button>
                                </StackPanel>
                            </CheckBox>
                        </StackPanel>
                </TabItem>
            </TabControl>

            <!-- BOTÕES DE AÇÃO -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Aplicar Selecionados" Width="150" Height="35" Margin="0,0,10,0" 
                        Background="{StaticResource AccentColor}" Foreground="Black" FontWeight="Bold"
                        Click="BtnApplyWinTune_Click" Cursor="Hand"/>
                <Button Content="Reverter Tudo" Width="120" Height="35" 
                        Background="#222" Foreground="White" BorderBrush="#444" BorderThickness="1"
                        Click="BtnRevertWinTune_Click" Cursor="Hand"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
