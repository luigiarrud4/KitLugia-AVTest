<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="KitLugia.GUI.Pages.NetworkPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Rede e Internet"
      TextElement.FontFamily="Segoe UI Variable Display, Segoe UI, Segoe UI Emoji, Segoe UI Symbol, Arial">

    <Page.Resources>
        <!-- TEMPLATE CUSTOMIZADO COM CHECKMARK -->
        <ControlTemplate x:Key="DnsButtonTemplate" TargetType="Button">
            <Border x:Name="bdr" Background="#222" CornerRadius="8" BorderThickness="1" BorderBrush="#333" Padding="10">
                <Grid>
                    <ContentPresenter VerticalAlignment="Center"
                                      TextElement.FontFamily="Segoe UI Variable Display, Segoe UI, Segoe UI Emoji, Segoe UI Symbol, Arial"/>
                    <Border x:Name="CheckBadge" Width="26" Height="26" HorizontalAlignment="Right" VerticalAlignment="Top" 
                            Background="{DynamicResource AccentColor}" CornerRadius="0,7,0,13" Margin="-10,-10,-10,-10"
                            Visibility="Collapsed">
                        <TextBlock Text="&#x2713;" Foreground="Black" FontWeight="Bold" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,0,0,3"/>
                    </Border>
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="bdr" Property="Background" Value="#2A2A2A"/>
                    <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                </Trigger>
                <Trigger Property="Tag" Value="Selected">
                    <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                    <Setter TargetName="bdr" Property="BorderThickness" Value="2"/>
                    <Setter TargetName="CheckBadge" Property="Visibility" Value="Visible"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="{x:Type ToggleButton}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="30" />
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" CornerRadius="4" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" />
                <Path x:Name="Arrow" Grid.Column="1" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M0,0 L4,4 L8,0" IsHitTestVisible="False"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#333333" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="DarkComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton Name="ToggleButton" Template="{DynamicResource ComboBoxToggleButton}" Grid.Column="2" Focusable="false" IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"/>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="10,0,30,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#1A1A1A" BorderThickness="1" BorderBrush="#444444"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30,30,30,50" MaxWidth="900">

            <TextBlock Text="Rede e Lat&#xEA;ncia" FontSize="32" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="White"/>
            <TextBlock Text="Otimiza&#xE7;&#xF5;es de conex&#xE3;o para jogos e navega&#xE7;&#xE3;o mais r&#xE1;pida." Foreground="#A0A0A0" Margin="0,0,0,30"/>

            <!-- SEÇÃO 1: DNS RÁPIDO -->
            <TextBlock Text="Gerenciador de DNS" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnCloudflare" Grid.Column="0" Height="100" Click="BtnDnsCloudflare_Click" Template="{StaticResource DnsButtonTemplate}">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="1.1.1.1" FontWeight="Bold" FontSize="18" Foreground="#F48120" HorizontalAlignment="Center"/>
                        <TextBlock Text="Cloudflare DNS" FontWeight="Bold" FontSize="12" Foreground="White" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        <TextBlock Text="Melhor velocidade" FontSize="10" Foreground="#808080" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnGoogle" Grid.Column="2" Height="100" Click="BtnDnsGoogle_Click" Template="{StaticResource DnsButtonTemplate}">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="8.8.8.8" FontWeight="Bold" FontSize="18" Foreground="#4285F4" HorizontalAlignment="Center"/>
                        <TextBlock Text="Google Public DNS" FontWeight="Bold" FontSize="12" Foreground="White" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        <TextBlock Text="Maior estabilidade" FontSize="10" Foreground="#808080" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnDhcp" Grid.Column="4" Height="100" Click="BtnDnsReset_Click" Template="{StaticResource DnsButtonTemplate}">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="AUTO" FontWeight="Bold" FontSize="18" Foreground="{StaticResource AccentColor}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Padr&#xE3;o (DHCP)" FontWeight="Bold" FontSize="12" Foreground="White" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        <TextBlock Text="Definido pelo roteador" FontSize="10" Foreground="#808080" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <StackPanel Orientation="Horizontal" Margin="5,0,0,10" HorizontalAlignment="Right">
                <TextBlock Text="Servidor DNS em uso:" Foreground="#888" Margin="0,0,10,0" FontStyle="Italic"/>
                <TextBlock x:Name="TxtCurrentDnsIp" Text="Verificando..." Foreground="#AAAAAA" FontWeight="SemiBold"/>
            </StackPanel>

            <!-- SEÇÃO 1.5: CONTROLE DO ADAPTADOR (LIGAR/DESLIGAR/RESTART) -->
            <Border Background="{StaticResource CardBackground}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="8" Margin="0,5,0,25">
                <StackPanel>
                    <TextBlock Text="&#x1F4E1; Controle do Adaptador" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentColor}" Margin="20,15,20,5"/>
                    <TextBlock Text="Ligue, desligue ou reinicie o adaptador de rede para resolver problemas de conex&#xE3;o." FontSize="12" Foreground="#808080" Margin="20,0,20,10"/>
                    <Separator Background="{StaticResource CardBorder}"/>
                    <TextBlock x:Name="TxtSelectedAdapterForControl" Text="Selecione um adaptador acima" FontSize="13" Foreground="#808080" Margin="20,10,20,0"/>
                    <Grid Margin="20,10,20,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnEnableAdapter" Grid.Column="0" Height="55" Cursor="Hand" Click="BtnEnableAdapter_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="cardBorder" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="8" RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Border.RenderTransform>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="cardBorder" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.02" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetName="cardBorder" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.02" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="cardBorder" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetName="cardBorder" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                            <Setter TargetName="cardBorder" Property="Background" Value="{DynamicResource CardHover}"/>
                                            <Setter TargetName="cardBorder" Property="BorderBrush" Value="#6CCB5F"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="cardBorder" Property="Background" Value="#6CCB5F"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="&#x25B6; Ligar" FontSize="15" FontWeight="Bold" Foreground="#6CCB5F" HorizontalAlignment="Center"/>
                                <TextBlock Text="Ativar adaptador" FontSize="10" Foreground="#808080" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnDisableAdapter" Grid.Column="2" Height="55" Cursor="Hand" Click="BtnDisableAdapter_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="cardBorder" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="8" RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Border.RenderTransform>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="cardBorder" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.02" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetName="cardBorder" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.02" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="cardBorder" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetName="cardBorder" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                            <Setter TargetName="cardBorder" Property="Background" Value="{DynamicResource CardHover}"/>
                                            <Setter TargetName="cardBorder" Property="BorderBrush" Value="#F44336"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="cardBorder" Property="Background" Value="#F44336"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="&#x25A0; Desligar" FontSize="15" FontWeight="Bold" Foreground="#F44336" HorizontalAlignment="Center"/>
                                <TextBlock Text="Desativar adaptador" FontSize="10" Foreground="#808080" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnRestartAdapter" Grid.Column="4" Height="55" Cursor="Hand" Click="BtnRestartAdapter_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="cardBorder" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="8" RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                        </Border.RenderTransform>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="cardBorder" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.02" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetName="cardBorder" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.02" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="cardBorder" Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetName="cardBorder" Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.15">
                                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                            <Setter TargetName="cardBorder" Property="Background" Value="{DynamicResource CardHover}"/>
                                            <Setter TargetName="cardBorder" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="cardBorder" Property="Background" Value="{DynamicResource AccentColor}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="&#x1F504; Reiniciar" FontSize="15" FontWeight="Bold" Foreground="{StaticResource AccentColor}" HorizontalAlignment="Center"/>
                                <TextBlock Text="Desliga e liga (2s)" FontSize="10" Foreground="#808080" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- SEÇÃO 2: TCP/IP GLOBAL -->
            <TextBlock Text="TCP/IP Global" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,10,0,15"/>
            <Border Background="{StaticResource CardBackground}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="8">
                <StackPanel>

                    <!-- CTCP -->
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" HorizontalAlignment="Center" VerticalAlignment="Center" Width="30" Height="30" Cursor="Help" Margin="0,0,10,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                            <Button.ToolTip>
                                <ToolTip Content="CTCP (Compound TCP) &#xE9; um algoritmo de controle de congestionamento do Windows otimizado para redes de alta lat&#xEA;ncia.&#x0a;&#x0a;&#x2705; Benef&#xED;cios:&#x0a;&#x2022; Melhor throughput em redes com alta lat&#xEA;ncia&#x0a;&#x2022; Otimizado para jogos online e VoIP&#x0a;&#x2022; Reduz perda de pacotes&#x0a;&#x2022; Melhor estabilidade de conex&#xE3;o&#x0a;&#x0a;&#x274C; Poss&#xED;veis desvantagens:&#x0a;&#x2022; Pode aumentar uso de CPU levemente&#x0a;&#x2022; Em redes muito r&#xE1;pidas, ganho pode ser menor&#x0a;&#x0a;&#x1F3AF; Recomendado para: Jogos online, streaming, videoconfer&#xEA;ncia, redes com alta lat&#xEA;ncia&#x0a;&#x0a;&#x26A0;&#xFE0F; N&#xE3;o recomendado para: Redes extremamente r&#xE1;pidas (lat&#xEA;ncia j&#xE1; muito baixa)"/>
                            </Button.ToolTip>
                            <TextBlock Text="&#x2139;&#xFE0F;" FontSize="16" Foreground="{StaticResource AccentColor}" Opacity="0.6"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="CTCP (Compound TCP)" FontSize="15" Foreground="White"/>
                            <TextBlock Text="Algoritmo de congestionamento otimizado para jogos e VoIP." FontSize="12" Foreground="#808080" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusCTCP" Text="Desativado" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="#808080" FontWeight="SemiBold"/>
                        <CheckBox x:Name="ChkCTCP" Grid.Column="3" Style="{StaticResource ToggleSwitchStyle}" Click="ChkCTCP_Click"/>
                    </Grid>

                    <Separator Background="{StaticResource CardBorder}"/>

                    <!-- RSS -->
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" HorizontalAlignment="Center" VerticalAlignment="Center" Width="30" Height="30" Cursor="Help" Margin="0,0,10,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                            <Button.ToolTip>
                                <ToolTip Content="RSS (Receive Side Scaling) distribui o processamento de pacotes de rede entre m&#xFA;ltiplos n&#xFA;cleos da CPU.&#x0a;&#x0a;&#x2705; Benef&#xED;cios:&#x0a;&#x2022; Melhor utiliza&#xE7;&#xE3;o de CPUs multi-core&#x0a;&#x2022; Aumenta throughput de rede&#x0a;&#x2022; Reduz carga em um &#xFA;nico core&#x0a;&#x2022; Melhor performance em redes de alta velocidade&#x0a;&#x0a;&#x274C; Poss&#xED;veis desvantagens:&#x0a;&#x2022; Requer CPU com 4+ n&#xFA;cleos para benef&#xED;cio real&#x0a;&#x2022; Pode aumentar consumo de energia&#x0a;&#x2022; Em CPUs de 2 n&#xFA;cleos, benef&#xED;cio &#xE9; m&#xED;nimo&#x0a;&#x0a;&#x1F3AF; Recomendado para: CPUs com 4+ cores, alta largura de banda, servidores, gaming&#x0a;&#x0a;&#x26A0;&#xFE0F; N&#xE3;o recomendado para: CPUs de 2 n&#xFA;cleos ou menos, laptops com bateria fraca"/>
                            </Button.ToolTip>
                            <TextBlock Text="&#x2139;&#xFE0F;" FontSize="16" Foreground="{StaticResource AccentColor}" Opacity="0.6"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="RSS (Receive Side Scaling)" FontSize="15" Foreground="White"/>
                            <TextBlock Text="Distribui processamento de rede entre m&#xFA;ltiplos cores CPU." FontSize="12" Foreground="#808080" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusRSS" Text="Desativado" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="#808080" FontWeight="SemiBold"/>
                        <CheckBox x:Name="ChkRSS" Grid.Column="3" Style="{StaticResource ToggleSwitchStyle}" Click="ChkRSS_Click"/>
                    </Grid>

                    <Separator Background="{StaticResource CardBorder}"/>

                    <!-- TaskOffload -->
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" HorizontalAlignment="Center" VerticalAlignment="Center" Width="30" Height="30" Cursor="Help" Margin="0,0,10,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                            <Button.ToolTip>
                                <ToolTip Content="Task Offload permite que a placa de rede (NIC) processe tarefas como checksum e segmenta&#xE7;&#xE3;o em vez da CPU.&#x0a;&#x0a;&#x2705; Benef&#xED;cios:&#x0a;&#x2022; Reduz carga da CPU significativamente&#x0a;&#x2022; Melhor performance geral do sistema&#x0a;&#x2022; Menor consumo de energia em alguns casos&#x0a;&#x2022; Acelera processamento de pacotes&#x0a;&#x0a;&#x274C; Poss&#xED;veis desvantagens:&#x0a;&#x2022; Requer placa de rede moderna com suporte&#x0a;&#x2022; Pode causar problemas em placas antigas&#x0a;&#x2022; Alguns drivers podem ter bugs&#x0a;&#x0a;&#x1F3AF; Recomendado para: Placas de rede modernas (Intel, Realtek), CPUs mais antigas, laptops&#x0a;&#x0a;&#x26A0;&#xFE0F; N&#xE3;o recomendado para: Placas de rede muito antigas, drivers inst&#xE1;veis, servidores espec&#xED;ficos"/>
                            </Button.ToolTip>
                            <TextBlock Text="&#x2139;&#xFE0F;" FontSize="16" Foreground="{StaticResource AccentColor}" Opacity="0.6"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Task Offload" FontSize="15" Foreground="White"/>
                            <TextBlock Text="Permite que a NIC processe tarefas de rede (reduz carga CPU)." FontSize="12" Foreground="#808080" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusTaskOffload" Text="Desativado" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="#808080" FontWeight="SemiBold"/>
                        <CheckBox x:Name="ChkTaskOffload" Grid.Column="3" Style="{StaticResource ToggleSwitchStyle}" Click="ChkTaskOffload_Click"/>
                    </Grid>

                    <Separator Background="{StaticResource CardBorder}"/>

                    <!-- Network Throttling -->
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
