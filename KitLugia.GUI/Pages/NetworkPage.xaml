                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" HorizontalAlignment="Center" VerticalAlignment="Center" Width="30" Height="30" Cursor="Help" Margin="0,0,10,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                            <Button.ToolTip>
                                <ToolTip Content="Interrupt Moderation agrupa interrup&#xE7;&#xF5;es de rede para reduzir carga da CPU, mas aumenta lat&#xEA;ncia.&#x0a;&#x0a;&#x2705; Benef&#xED;cios ao desativar:&#x0a;&#x2022; Reduz lat&#xEA;ncia (ping mais baixo)&#x0a;&#x2022; Melhor responsividade em jogos&#x0a;&#x2022; Melhor para jogos competitivos&#x0a;&#x2022; Resposta mais r&#xE1;pida em tempo real&#x0a;&#x0a;&#x274C; Poss&#xED;veis desvantagens ao desativar:&#x0a;&#x2022; Aumenta uso da CPU ligeiramente&#x0a;&#x2022; Mais interrup&#xE7;&#xF5;es por segundo&#x0a;&#x2022; Pode afetar bateria em laptops&#x0a;&#x0a;&#x1F3AF; Recomendado para: Jogos competitivos (FPS, MOBA), baixa lat&#xEA;ncia, desktops&#x0a;&#x0a;&#x26A0;&#xFE0F; N&#xE3;o recomendado para: Laptops com bateria fraca, CPUs muito antigas, servidores&#x0a;&#x26A0;&#xFE0F; Aplicado ao adaptador de rede selecionado"/>
                            </Button.ToolTip>
                            <TextBlock Text="&#x2139;&#xFE0F;" FontSize="16" Foreground="{StaticResource AccentColor}" Opacity="0.6"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Interrupt Moderation" FontSize="15" Foreground="White"/>
                            <TextBlock Text="Desabilitar reduz lat&#xEA;ncia (melhor para gaming)." FontSize="12" Foreground="#808080" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusInterruptModeration" Text="Ativo" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="#808080" FontWeight="SemiBold"/>
                        <CheckBox x:Name="ChkInterruptModeration" Grid.Column="3" Style="{StaticResource ToggleSwitchStyle}" Click="ChkInterruptModeration_Click"/>
                    </Grid>

                    <Separator Background="{StaticResource CardBorder}"/>

                    <!-- Nagle's Algorithm -->
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" HorizontalAlignment="Center" VerticalAlignment="Center" Width="30" Height="30" Cursor="Help" Margin="0,0,10,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                            <Button.ToolTip>
                                <ToolTip Content="Nagle's Algorithm agrupa pequenos pacotes para reduzir overhead de rede, mas aumenta lat&#xEA;ncia.&#x0a;&#x0a;&#x2705; Benef&#xED;cios ao desativar:&#x0a;&#x2022; Pacotes s&#xE3;o enviados imediatamente&#x0a;&#x2022; Reduz lat&#xEA;ncia significativamente (50-100ms)&#x0a;&#x2022; Melhor para jogos em tempo real&#x0a;&#x2022; Resposta mais r&#xE1;pida em aplica&#xE7;&#xF5;es interativas&#x0a;&#x0a;&#x274C; Poss&#xED;veis desvantagens ao desativar:&#x0a;&#x2022; Aumenta overhead de rede (mais pacotes)&#x0a;&#x2022; Pode aumentar uso de banda levemente&#x0a;&#x2022; Menos eficiente para transfer&#xEA;ncias grandes&#x0a;&#x0a;&#x1F3AF; Recomendado para: Jogos FPS, MOBA, aplica&#xE7;&#xF5;es de baixa lat&#xEA;ncia, VoIP, streaming&#x0a;&#x0a;&#x26A0;&#xFE0F; N&#xE3;o recomendado para: Transfer&#xEA;ncias de arquivos grandes, servidores de arquivos&#x0a;&#x26A0;&#xFE0F; Aplicado a todas as interfaces de rede"/>
                            </Button.ToolTip>
                            <TextBlock Text="&#x2139;&#xFE0F;" FontSize="16" Foreground="{StaticResource AccentColor}" Opacity="0.6"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Nagle's Algorithm" FontSize="15" Foreground="White"/>
                            <TextBlock Text="Desabilitar para envio imediato de pacotes (reduz lat&#xEA;ncia)." FontSize="12" Foreground="#808080" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusNagle" Text="Ativo" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="#808080" FontWeight="SemiBold"/>
                        <CheckBox x:Name="ChkNagle" Grid.Column="3" Style="{StaticResource ToggleSwitchStyle}" Click="ChkNagle_Click"/>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- SEÇÃO 4: REGISTRY TWEAKS -->
            <TextBlock Text="Registry Tweaks Avan&#xE7;ados" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,30,0,15"/>
            <Border Background="{StaticResource CardBackground}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="8">
                <StackPanel>

                    <!-- TCP Registry Tweaks -->
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" HorizontalAlignment="Center" VerticalAlignment="Center" Width="30" Height="30" Cursor="Help" Margin="0,0,10,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                            <Button.ToolTip>
                                <ToolTip Content="TCP Registry Tweaks ajusta par&#xE2;metros avan&#xE7;ados do TCP no registro do Windows.&#x0a;&#x0a;&#x2705; Benef&#xED;cios:&#x0a;&#x2022; Window Scaling (janelas TCP maiores - at&#xE9; 1GB)&#x0a;&#x2022; MaxUserPort (65534 portas dispon&#xED;veis)&#x0a;&#x2022; TcpTimedWaitDelay (libera portas em 30s)&#x0a;&#x2022; DefaultTTL (64 hops otimizado)&#x0a;&#x2022; ARP Cache (cache maior - menos queries)&#x0a;&#x2022; TCP Ack Frequency (respostas mais r&#xE1;pidas)&#x0a;&#x2022; TCP No Delay (desabilita atrasos de Nagle)&#x0a;&#x0a;&#x274C; Poss&#xED;veis desvantagens:&#x0a;&#x2022; Modifica&#xE7;&#xF5;es no registro do sistema&#x0a;&#x2022; Requer reinicializa&#xE7;&#xE3;o para alguns tweaks&#x0a;&#x2022; Pode n&#xE3;o funcionar em todas as redes&#x0a;&#x0a;&#x1F3AF; Recomendado para: Gaming, alta performance de rede, servidores, redes modernas&#x0a;&#x0a;&#x26A0;&#xFE0F; N&#xE3;o recomendado para: Redes corporativas com pol&#xED;ticas restritivas, sistemas cr&#xED;ticos sem backup"/>
                            </Button.ToolTip>
                            <TextBlock Text="&#x2139;&#xFE0F;" FontSize="16" Foreground="{StaticResource AccentColor}" Opacity="0.6"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="TCP Registry Tweaks" FontSize="15" Foreground="White"/>
                            <TextBlock Text="Window Scaling, Max Ports, TTL, ARP Cache e outros." FontSize="12" Foreground="#808080" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusTcpRegistry" Text="Desativado" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="#808080" FontWeight="SemiBold"/>
                        <CheckBox x:Name="ChkTcpRegistry" Grid.Column="3" Style="{StaticResource ToggleSwitchStyle}" Click="ChkTcpRegistry_Click"/>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- LIMPAR CACHE DNS -->
            <Button Content="&#x1F6BF;  Flush DNS (Limpar Cache de Resolu&#xE7;&#xE3;o)" 
                    Margin="0,30,0,0" Height="50"
                    Style="{StaticResource SettingsCardStyle}"
                    ToolTip="Resolve problemas de conex&#xE3;o ao carregar sites."
                    Tag="&#x2699;&#xFE0F;"
                    Click="BtnFlushDns_Click"/>

            <!-- RESETAR PILHA DE REDE -->
            <Button Content="&#x1F504;  Resetar Pilha de Rede (Netsh Reset)" 
                    Margin="0,15,0,0" Height="50"
                    Style="{StaticResource SettingsCardStyle}"
                    ToolTip="Restaura todas as configura&#xE7;&#xF5;es de rede para o padr&#xE3;o do Windows."
                    Tag="&#x2699;&#xFE0F;"
                    Click="BtnResetNetwork_Click"/>

        </StackPanel>
    </ScrollViewer>
</Page>
