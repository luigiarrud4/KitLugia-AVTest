<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="KitLugia.GUI.Pages.RepairsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      Title="Central de Reparos"
      TextElement.FontFamily="Segoe UI Variable Display, Segoe UI, Segoe UI Emoji, Segoe UI Symbol, Arial"
      d:DesignHeight="700" d:DesignWidth="1100">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- T&#xED;tulo -->
            <RowDefinition Height="Auto"/>
            <!-- Busca -->
            <RowDefinition Height="*"/>
            <!-- Principal -->
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Central AIO de Reparos" FontSize="32" FontWeight="SemiBold" Foreground="White">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#FFD700" BlurRadius="20" Opacity="0.15" ShadowDepth="0"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock Text="Solu&#xE7;&#xF5;es autom&#xE1;ticas estilo 'FixWin' para corrigir problemas do sistema." Foreground="#999" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- BUSCA -->
        <Border Grid.Row="1" Background="#15FFFFFF" CornerRadius="8" Height="45" Margin="0,25,0,25" BorderBrush="#404040" BorderThickness="1" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="11*"/>
                    <ColumnDefinition Width="483*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="&#x1F50D;" VerticalAlignment="Center" HorizontalAlignment="Left" Foreground="#888" FontSize="16" Width="27" Margin="13,0,0,0"/>

                <TextBlock Text="Buscar reparo (ex: wifi, som, update)..." 
                           Foreground="#606060" VerticalAlignment="Center" 
                           IsHitTestVisible="False" FontStyle="Italic" FontSize="14" Margin="43,0,43,0" Grid.ColumnSpan="3">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Text, ElementName=TxtFilter}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBox x:Name="TxtFilter" Background="Transparent" BorderThickness="0" 
                         Foreground="White" VerticalAlignment="Center" FontSize="16" 
                         Padding="0,0,10,0" CaretBrush="{StaticResource AccentColor}"
                         TextChanged="TxtFilter_TextChanged" Margin="43,0,12,0" Grid.ColumnSpan="3"/>
            </Grid>
        </Border>

        <!-- AREA PRINCIPAL -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- COLUNA ESQUERDA (Menu) -->
            <Border Background="#121212" CornerRadius="8" Margin="0,0,20,0" BorderBrush="#333" BorderThickness="1" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border BorderBrush="#333" BorderThickness="0,0,0,1" Padding="15">
                        <TextBlock Text="CATEGORIAS" Foreground="#777" FontWeight="Bold" FontSize="12"/>
                    </Border>

                    <ListBox Grid.Row="1" x:Name="LstCategories" Background="Transparent" BorderThickness="0" 
                             SelectionChanged="LstCategories_SelectionChanged" Foreground="#DDD"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled" Padding="5">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="15,10"/>
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="bdr" Background="Transparent" CornerRadius="6">
                                                <Grid>
                                                    <Rectangle x:Name="Indicator" Width="4" HorizontalAlignment="Left" RadiusX="2" RadiusY="2"
                                                               Fill="{StaticResource AccentColor}" Visibility="Collapsed" Height="20"/>
                                                    <ContentPresenter Margin="{TemplateBinding Padding}"/>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="bdr" Property="Background" Value="#15FFD700"/>
                                                    <Setter TargetName="Indicator" Property="Visibility" Value="Visible"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Trigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <ColorAnimation Storyboard.TargetName="bdr" Storyboard.TargetProperty="Background.Color" To="#25FFFFFF" Duration="0:0:0.15">
                                                                    <ColorAnimation.EasingFunction>
                                                                        <CubicEase EasingMode="EaseOut"/>
                                                                    </ColorAnimation.EasingFunction>
                                                                </ColorAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.EnterActions>
                                                    <Trigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <ColorAnimation Storyboard.TargetName="bdr" Storyboard.TargetProperty="Background.Color" To="Transparent" Duration="0:0:0.15">
                                                                    <ColorAnimation.EasingFunction>
                                                                        <CubicEase EasingMode="EaseOut"/>
                                                                    </ColorAnimation.EasingFunction>
                                                                </ColorAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.ExitActions>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>
            </Border>

            <!-- COLUNA DIREITA (Cart&#xF5;es + Diagn&#xF3;stico) -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Cart&#xF5;es de Reparos -->
                <ListBox Grid.Row="0" x:Name="ItemsRepairs"
                         VirtualizingPanel.IsVirtualizing="True"
                         VirtualizingPanel.VirtualizationMode="Recycling"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Background="Transparent" BorderThickness="0"
                         Padding="0,0,10,0">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                            <!-- LARGURA 460px -->
                            <Button Click="BtnRunRepair_Click" Tag="{Binding}"
                                    Width="460" MinHeight="100" Margin="0,0,15,15"
                                    Cursor="Hand" Background="Transparent" BorderThickness="0"
                                    HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="cardBorder" Background="{StaticResource CardBackground}" 
                                                BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="8"
                                                Padding="15">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- &#xCD;CONE -->
                                                <Border Background="#20FFD700" CornerRadius="12" Width="48" Height="48" 
                                                        VerticalAlignment="Top" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding Icon}" FontSize="24" HorizontalAlignment="Center" 
                                                               VerticalAlignment="Center" FontFamily="Segoe UI Emoji"/>
                                                </Border>

                                                <!-- CONTE&#xDA;DO -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="10,0,0,0">
                                                    <!-- Nome -->
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="White" FontSize="15" 
                                                               TextTrimming="CharacterEllipsis"/>

                                                    <!-- Descri&#xE7;&#xE3;o -->
                                                    <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#AAAAAA" 
                                                               TextWrapping="Wrap" Margin="0,5,0,0"/>

                                                    <!-- TAGS -->
                                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                        <Border Background="#33C42B1C" CornerRadius="4" Padding="6,2" Margin="0,0,6,0">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsDangerous}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="&#x26A0;&#xFE0F; Avan&#xE7;ado" FontSize="10" Foreground="#FF8A80" FontWeight="Bold"/>
                                                        </Border>

                                                        <Border Background="#25FFFFFF" CornerRadius="4" Padding="6,2">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSlow}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="&#x23F3; Janela Externa" FontSize="10" Foreground="#EEE" FontWeight="Bold"/>
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- TRIGGERS -->
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="cardBorder" Property="Background" Value="{StaticResource CardHover}"/>
                                                <Setter TargetName="cardBorder" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                                <Setter TargetName="cardBorder" Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#FFD700" BlurRadius="12" ShadowDepth="0" Opacity="0.15"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="cardBorder" Property="Opacity" Value="0.6"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            </Grid>
        </Grid>
    </Grid>
</Page>
