<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="KitLugia.GUI.Pages.SecurityPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Seguran&#xE7;a"
      TextElement.FontFamily="Segoe UI Variable Display, Segoe UI, Segoe UI Emoji, Segoe UI Symbol, Arial">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30" MaxWidth="950">

            <!-- Cabe&#xE7;alho -->
            <StackPanel Margin="0,0,0,25">
                <TextBlock Text="Seguran&#xE7;a do Sistema" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                <TextBlock Text="Gerencie prote&#xE7;&#xF5;es do Windows. Altera&#xE7;&#xF5;es cr&#xED;ticas exigem reinicializa&#xE7;&#xE3;o." 
                           Foreground="{StaticResource TextSecondary}" Margin="0,6,0,0"/>
            </StackPanel>

            <!-- Score de Seguran&#xE7;a -->
            <Border Background="{StaticResource CardBackground}" BorderBrush="{StaticResource CardBorder}" 
                    BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,20" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="&#x1F6E1;&#xFE0F; Score de Seguran&#xE7;a" FontSize="16" FontWeight="Bold" 
                                   Foreground="{StaticResource AccentColor}" Margin="0,0,0,6"/>
                        <TextBlock x:Name="TxtSecurityScore" Text="Calculando..." FontSize="13" 
                                   Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>
                    <Button Grid.Column="1" Content="&#x1F504; Atualizar" Style="{StaticResource SecondaryButtonStyle}" 
                            Width="110" Height="36" Click="BtnRefresh_Click"/>
                </Grid>
            </Border>

            <!-- Card: Prote&#xE7;&#xE3;o em Tempo Real -->
            <Border Background="{StaticResource CardBackground}" BorderBrush="{StaticResource CardBorder}" 
                    BorderThickness="1" CornerRadius="8" Padding="22" Margin="0,0,0,16" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="&#x1F510;" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="Prote&#xE7;&#xE3;o em Tempo Real" FontSize="16" FontWeight="Bold" 
                                       Foreground="{StaticResource AccentColor}"/>
                            <TextBlock Text="Controle o Windows Defender e prote&#xE7;&#xF5;es ativas." 
                                       FontSize="12" Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Windows Defender -->
                    <Border Background="#1A1A1A" CornerRadius="6" Padding="14,10" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Windows Defender (Antiv&#xED;rus)" FontSize="13" FontWeight="SemiBold" 
                                           Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock x:Name="TxtDefenderStatus" Text="Verificando..." FontSize="11" 
                                           Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="ChkDefender" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" 
                                      Click="ChkDefender_Click" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Prote&#xE7;&#xE3;o em Tempo Real -->
                    <Border Background="#1A1A1A" CornerRadius="6" Padding="14,10" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Prote&#xE7;&#xE3;o em Tempo Real" FontSize="13" FontWeight="SemiBold" 
                                           Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="Monitora arquivos e processos continuamente." FontSize="11" 
                                           Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="ChkRealtimeProtection" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" 
                                      Click="ChkRealtimeProtection_Click" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- VBS / Virtualiza&#xE7;&#xE3;o -->
                    <Border Background="#1A1A1A" CornerRadius="6" Padding="14,10" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="VBS &#x2014; Seguran&#xE7;a Baseada em Virtualiza&#xE7;&#xE3;o" FontSize="13" FontWeight="SemiBold" 
                                           Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="&#x26A0;&#xFE0F; Desativar aumenta FPS em jogos mas reduz seguran&#xE7;a. Requer reinicializa&#xE7;&#xE3;o." 
                                           FontSize="11" Foreground="#FFA500" Margin="0,2,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                            <CheckBox x:Name="ChkVBS" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" 
                                      Click="ChkVBS_Click" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- SmartScreen -->
                    <Border Background="#1A1A1A" CornerRadius="6" Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="SmartScreen (Filtro de Sites/Apps)" FontSize="13" FontWeight="SemiBold" 
                                           Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="Bloqueia downloads e sites maliciosos conhecidos." FontSize="11" 
                                           Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="ChkSmartScreen" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" 
                                      Click="ChkSmartScreen_Click" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Card: Firewall e Rede -->
            <Border Background="{StaticResource CardBackground}" BorderBrush="{StaticResource CardBorder}" 
                    BorderThickness="1" CornerRadius="8" Padding="22" Margin="0,0,0,16" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="&#x1F9F1;" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="Firewall e Rede" FontSize="16" FontWeight="Bold" 
                                       Foreground="{StaticResource AccentColor}"/>
                            <TextBlock Text="Controle o firewall e prote&#xE7;&#xF5;es de rede." 
                                       FontSize="12" Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Firewall -->
                    <Border Background="#1A1A1A" CornerRadius="6" Padding="14,10" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Firewall do Windows" FontSize="13" FontWeight="SemiBold" 
                                           Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock x:Name="TxtFirewallStatus" Text="Verificando..." FontSize="11" 
                                           Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="ChkFirewall" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" 
                                      Click="ChkFirewall_Click" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Registro Remoto -->
                    <Border Background="#1A1A1A" CornerRadius="6" Padding="14,10" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Registro Remoto (Remote Registry)" FontSize="13" FontWeight="SemiBold" 
                                           Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="Permite acesso remoto ao registro. Recomendado: Desativado." FontSize="11" 
                                           Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="ChkRemoteRegistry" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" 
                                      Click="ChkRemoteRegistry_Click" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- &#xC1;rea de Trabalho Remota -->
                    <Border Background="#1A1A1A" CornerRadius="6" Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="&#xC1;rea de Trabalho Remota (RDP)" FontSize="13" FontWeight="SemiBold" 
                                           Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="Permite controle remoto do PC. Desative se n&#xE3;o usar." FontSize="11" 
                                           Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="ChkRDP" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" 
                                      Click="ChkRDP_Click" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Card: Privacidade e Telemetria -->
            <Border Background="{StaticResource CardBackground}" BorderBrush="{StaticResource CardBorder}" 
                    BorderThickness="1" CornerRadius="8" Padding="22" Margin="0,0,0,16" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="&#x1F441;&#xFE0F;" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="Privacidade e Telemetria" FontSize="16" FontWeight="Bold" 
                                       Foreground="{StaticResource AccentColor}"/>
                            <TextBlock Text="Controle quais dados o Windows envia para a Microsoft." 
                                       FontSize="12" Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Telemetria -->
                    <Border Background="#1A1A1A" CornerRadius="6" Padding="14,10" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Telemetria (Dados de Diagn&#xF3;stico)" FontSize="13" FontWeight="SemiBold" 
                                           Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="Envia dados de uso para a Microsoft. Recomendado: Desativado." FontSize="11" 
                                           Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="ChkTelemetry" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" 
                                      Click="ChkTelemetry_Click" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Hist&#xF3;rico de Atividades -->
                    <Border Background="#1A1A1A" CornerRadius="6" Padding="14,10" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Hist&#xF3;rico de Atividades (Timeline)" FontSize="13" FontWeight="SemiBold" 
                                           Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="Registra apps e arquivos abertos. Recomendado: Desativado." FontSize="11" 
                                           Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="ChkActivityHistory" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" 
                                      Click="ChkActivityHistory_Click" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- ID de Publicidade -->
                    <Border Background="#1A1A1A" CornerRadius="6" Padding="14,10" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="ID de Publicidade (Rastreamento de An&#xFA;ncios)" FontSize="13" FontWeight="SemiBold" 
                                           Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="Permite que apps rastreiem seu comportamento para an&#xFA;ncios." FontSize="11" 
                                           Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="ChkAdID" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" 
                                      Click="ChkAdID_Click" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Localiza&#xE7;&#xE3;o -->
                    <Border Background="#1A1A1A" CornerRadius="6" Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Servi&#xE7;os de Localiza&#xE7;&#xE3;o" FontSize="13" FontWeight="SemiBold" 
                                           Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="Permite que apps acessem sua localiza&#xE7;&#xE3;o geogr&#xE1;fica." FontSize="11" 
                                           Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="ChkLocation" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" 
                                      Click="ChkLocation_Click" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Card: UAC -->
            <Border Background="{StaticResource CardBackground}" BorderBrush="{StaticResource CardBorder}" 
                    BorderThickness="1" CornerRadius="8" Padding="22" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="&#x1F511;" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel>
                            <TextBlock Text="Controle de Conta de Usu&#xE1;rio (UAC)" FontSize="16" FontWeight="Bold" 
                                       Foreground="{StaticResource AccentColor}"/>
                            <TextBlock Text="N&#xED;vel de prote&#xE7;&#xE3;o contra altera&#xE7;&#xF5;es n&#xE3;o autorizadas." 
                                       FontSize="12" Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="TxtUACLevel" Text="N&#xED;vel atual: Verificando..." FontSize="13" 
                                       Foreground="{StaticResource TextPrimary}" Margin="0,0,0,4"/>
                            <TextBlock Text="Recomendado: Notificar sempre (n&#xED;vel m&#xE1;ximo)." FontSize="11" 
                                       Foreground="{StaticResource TextMuted}"/>
                        </StackPanel>
                        <ComboBox x:Name="CmbUACLevel" Grid.Column="1" Height="36" VerticalAlignment="Center"
                                  Background="{StaticResource CardBackground}"
                                  Foreground="{StaticResource TextPrimary}"
                                  BorderBrush="{StaticResource CardBorder}"
                                  SelectionChanged="CmbUACLevel_SelectionChanged">
                            <ComboBoxItem Content="Sempre Notificar (M&#xE1;ximo)" Tag="2"
                                          Foreground="{StaticResource TextPrimary}"
                                          Background="{StaticResource CardBackground}"/>
                            <ComboBoxItem Content="Notificar Mudan&#xE7;as de Apps" Tag="1"
                                          Foreground="{StaticResource TextPrimary}"
                                          Background="{StaticResource CardBackground}"/>
                            <ComboBoxItem Content="Notificar Sem Escurecer" Tag="0"
                                          Foreground="{StaticResource TextPrimary}"
                                          Background="{StaticResource CardBackground}"/>
                            <ComboBoxItem Content="Nunca Notificar (Desativado)" Tag="-1"
                                          Foreground="{StaticResource TextPrimary}"
                                          Background="{StaticResource CardBackground}"/>
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
