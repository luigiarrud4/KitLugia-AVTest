<Page x:Class="KitLugia.GUI.Pages.ShrinkPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="900"
      Title="Shrink Partição — KitLugia"
      TextElement.FontFamily="Segoe UI Variable Display, Segoe UI, Segoe UI Emoji, Segoe UI Symbol, Arial"
      Background="{StaticResource WindowBackground}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="&#x2702;&#xFE0F; Shrink &amp; Recovery" FontSize="28" FontWeight="Bold" Foreground="{StaticResource AccentColor}"/>
            <TextBlock Text="Reduzir partição e criar ambiente de recuperação UEFI" FontSize="14" Foreground="{StaticResource TextMuted}" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Main Content -->
        <Border Grid.Row="1" Background="{StaticResource CardBackground}" CornerRadius="10" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Style="{StaticResource CardStyle}" Padding="25">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Config -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="&#x2699;&#xFE0F; CONFIGURAÇÃO" FontSize="16" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,15"/>

                    <TextBlock Text="Partição para reduzir:" FontSize="12" Foreground="#CCC" Margin="0,0,0,5"/>
                    <ComboBox x:Name="ComboPartitions" Height="32" Margin="0,0,0,12" DisplayMemberPath="DisplayText"/>

                    <TextBlock Text="Tamanho do shrink (MB):" FontSize="12" Foreground="#CCC" Margin="0,0,0,5"/>
                    <TextBox x:Name="TxtShrinkSize" Text="4096" Height="32" Margin="0,0,0,5"
                             Foreground="White" Background="#2B2B2B" BorderBrush="#444" BorderThickness="1"
                             VerticalContentAlignment="Center" Padding="8,0"/>
                    <TextBlock Text="Mínimo 1024 MB (1GB). O espaço será usado para criar a partição KITLUGIA." FontSize="10" Foreground="#888" Margin="0,0,0,12"/>

                    <CheckBox x:Name="ChkEmergencyPreBoot" Content="&#x26A1; Emergency Pre-Boot (Alpine + rEFInd)"
                              Foreground="#E0E0E0" FontSize="12" IsChecked="True" Margin="0,5,0,5"
                              Checked="ChkEmergencyPreBoot_Checked" Unchecked="ChkEmergencyPreBoot_Unchecked"/>

                    <TextBlock x:Name="TxtEmergencyWarning" Text="&#x26A0;&#xFE0F; O sistema será reiniciado automaticamente. Salve seu trabalho antes de continuar."
                               FontSize="11" Foreground="#FFA726" TextWrapping="Wrap" Visibility="Visible" Margin="15,5,0,15"/>

                    <Button x:Name="BtnExecute" Content="&#x25B6; EXECUTAR SHRINK" Height="40" FontSize="14" FontWeight="Bold"
                            Style="{StaticResource GoldButtonStyle}" Margin="0,10,0,0"
                            Click="BtnExecute_Click"/>

                    <!-- Status -->
                    <Border Background="#2B2B2B" CornerRadius="6" Padding="12" Margin="0,15,0,0" BorderBrush="#444" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="&#x1F4CB; STATUS" FontSize="11" Foreground="#AAA" Margin="0,0,0,5"/>
                            <TextBlock x:Name="TxtStatus" Text="Pronto." FontSize="13" Foreground="#E0E0E0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- RIGHT: Log -->
                <Border Grid.Column="2" Background="#1A1A1A" CornerRadius="8" BorderBrush="#333" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="&#x1F4DD; LOG" FontSize="11" Foreground="#AAA" Margin="10,8,10,5"/>
                        <ScrollViewer Grid.Row="1" Margin="5" x:Name="LogScroll">
                            <TextBox x:Name="TxtLog" IsReadOnly="True" FontFamily="Consolas" FontSize="10"
                                     Foreground="#0F0" Background="#111" BorderThickness="0"
                                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                     AcceptsReturn="True"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Bottom overlay -->
        <Grid x:Name="OverlayBusy" Grid.RowSpan="3" Background="#CC000000" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtProgressStatus" Text="Processando..." FontSize="16" Foreground="White" Margin="0,10,0,0"/>
                <ProgressBar x:Name="ProgressBar" Width="300" Height="6" Margin="0,10,0,0" IsIndeterminate="True"
                             Foreground="{StaticResource AccentColor}" Background="#333"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
