                            <ComboBoxItem Content="High (Prioridade alta para carregamentos)" Background="#2D2D2D" Foreground="White"/>
                            <ComboBoxItem Content="Critical (M&#xE1;xima - use com cautela)" Background="#2D2D2D" Foreground="White"/>
                        </ComboBox>
                        
                        <!-- Page Priority -->
                        <TextBlock Text="&#x1F4C4; Page Priority (Mem&#xF3;ria Virtual):" Foreground="#DDD" Margin="0,0,0,5"/>
                        <TextBlock Text="Prioridade de mem&#xF3;ria virtual quando h&#xE1; pouca RAM" 
                                   FontSize="11" Foreground="#888" Margin="0,0,0,5"/>
