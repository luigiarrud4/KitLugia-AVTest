                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25,0,0">
                            <Button x:Name="BtnSaveCustomMotor" Content="&#x1F4BE; Salvar Perfil" 
                                    Style="{StaticResource GoldButtonStyle}" Width="150" Height="45" 
                                    Margin="0,0,15,0" Click="BtnSaveCustomMotor_Click"/>
                            <Button x:Name="BtnCancelCustomMotor" Content="&#x274C; Cancelar" 
                                    Style="{StaticResource SecondaryButtonStyle}" Width="150" Height="45"
                                    Click="BtnCancelCustomMotor_Click"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- &#x1F525; OVERLAY: Confirma&#xE7;&#xE3;o de Exclus&#xE3;o -->
        <Grid x:Name="OverlayConfirmDelete" Visibility="Collapsed" Panel.ZIndex="1001" Grid.RowSpan="2">
        <Grid Background="#CC000000"/>
        <Border Width="350" Height="200" Background="#1E1E1E" BorderBrush="#DC143C" BorderThickness="2" 
                CornerRadius="10" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Margin="20" VerticalAlignment="Center">
                <TextBlock Text="&#x1F5D1;&#xFE0F; Confirmar Exclus&#xE3;o" FontSize="18" FontWeight="Bold" 
                           Foreground="#DC143C" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                <TextBlock Text="Deseja excluir o perfil:" Foreground="#DDD" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtDeleteProfileName" FontWeight="Bold" Foreground="#D4AF37" 
                           HorizontalAlignment="Center" Margin="0,5,0,20"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="BtnConfirmDelete" Content="&#x1F5D1;&#xFE0F; Excluir" 
                            Background="#DC143C" Foreground="White" Width="120" Height="40" 
                            Margin="0,0,10,0" Click="BtnConfirmDelete_Click" Style="{StaticResource GoldButtonStyle}"/>
                    <Button x:Name="BtnCancelDelete" Content="&#x274C; Cancelar" 
                            Background="#444" Foreground="White" Width="120" Height="40"
                            Click="BtnCancelDelete_Click" Style="{StaticResource SecondaryButtonStyle}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
    </Grid>
</Page>
