<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="KitLugia.GUI.Pages.GameBoostPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="GameBoost Pro"
      TextElement.FontFamily="Segoe UI Variable Display, Segoe UI, Segoe UI Emoji, Segoe UI Symbol, Arial"
      Loaded="GameBoostPage_Loaded">

    <Page.Resources>
        <ControlTemplate x:Key="GameBoostComboBoxToggleButton" TargetType="{x:Type ToggleButton}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="36" />
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" CornerRadius="5" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" />
                <Path x:Name="Arrow" Grid.Column="1" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M0,0 L5,5 L10,0" IsHitTestVisible="False"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#2A2A2A" />
                    <Setter TargetName="Border" Property="BorderBrush" Value="#666666" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="DarkComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#222222"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton Name="ToggleButton" Template="{StaticResource GameBoostComboBoxToggleButton}" Grid.Column="2" Focusable="false" IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Cursor="Hand"/>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="10,0,30,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide" StaysOpen="False">
                                <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#222222" BorderThickness="1" BorderBrush="#444444" CornerRadius="5"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#222"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#333"/>
                    <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#444"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Estilo do ToolTip (Balão de Informação) -->
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#FFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MaxWidth" Value="400"/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header Fixo -->
            <RowDefinition Height="*"/>     <!-- ScrollViewer ocupa o resto -->
        </Grid.RowDefinitions>
        
        <!-- HEADER FIXO -->
        <StackPanel Grid.Row="0" Margin="30,20,30,0">
            <TextBlock Text="&#x1F680; GameBoost Pro" FontSize="32" FontWeight="Bold" 
                       Foreground="{StaticResource AccentColor}" Margin="0,0,0,5">
                <TextBlock.Effect>
                    <DropShadowEffect Color="#FFD700" BlurRadius="10" ShadowDepth="0" Opacity="0.4"/>
                </TextBlock.Effect>
            </TextBlock>
            <TextBlock Text="Algoritmo Inteligente de Otimiza&#xE7;&#xE3;o de Processos - Inspirado no Process Lasso ProBalance" 
                       FontSize="13" Foreground="#888" Margin="0,0,0,15"/>
        </StackPanel>

        <!-- SCROLLVIEWER PARA A P&#xC1;GINA INTEIRA -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="30,0,30,30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Card 1: Status Toggle -->
                    <RowDefinition Height="Auto"/>  <!-- Card 2: Configura&#xE7;&#xF5;es do Sistema -->
                    <RowDefinition Height="Auto"/>  <!-- Card 3: Comportamento ao Fechar -->
                    <RowDefinition Height="Auto"/>  <!-- Card 4: Motor Selection -->
                    <RowDefinition Height="Auto"/>  <!-- Card 5: GameBar Presence Writer -->
                    <RowDefinition Height="Auto"/>  <!-- Conte&#xFA;do -->
                </Grid.RowDefinitions>
                
                <!-- STATUS CARD -->
                <Border Grid.Row="0" Style="{StaticResource CompactCardStyle}" Padding="25" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <Ellipse x:Name="StatusIndicator" Width="20" Height="20" Fill="#00FF00"
                                     Stroke="#FFFFFF" StrokeThickness="2" Margin="0,0,15,0">
                                <Ellipse.Effect>
                                    <DropShadowEffect x:Name="StatusGlow" Color="#00FF00" BlurRadius="15" ShadowDepth="0" Opacity="0.8"/>
                                </Ellipse.Effect>
                                <Ellipse.Triggers>
                                    <EventTrigger RoutedEvent="Ellipse.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetName="StatusGlow"
                                                               Storyboard.TargetProperty="Opacity"
                                                               From="0.3" To="1.0" Duration="0:0:1.5"/>
                                                <DoubleAnimation Storyboard.TargetName="StatusGlow"
                                                               Storyboard.TargetProperty="BlurRadius"
                                                               From="8" To="25" Duration="0:0:1.5"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Ellipse.Triggers>
                            </Ellipse>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="GameBoost Pro" FontSize="20" FontWeight="Bold" Foreground="White"/>
                            <TextBlock x:Name="TxtStatus" Text="Ativo e monitorando processos" FontSize="13" Foreground="#AAA"/>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <ToggleButton x:Name="TglGameBoost" Width="60" Height="30" 
                                          Checked="TglGameBoost_Checked" Unchecked="TglGameBoost_Unchecked">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="border" Background="#444" CornerRadius="15" BorderBrush="#666" BorderThickness="1">
                                            <Grid>
                                                <Ellipse x:Name="thumb" Fill="White" Width="24" Height="24" HorizontalAlignment="Left" Margin="2"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentColor}"/>
                                                <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                                                <Setter TargetName="thumb" Property="Margin" Value="0,0,2,0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                        </StackPanel>
                    </Grid>
                </Border>
                
                <!-- CARD 2: CONFIGURA&#xC7;&#xD5;ES DO SISTEMA -->
        <Border Grid.Row="1" Style="{StaticResource CompactCardStyle}" Padding="20" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="&#x2699;&#xFE0F; Configura&#xE7;&#xF5;es do Sistema" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                <TextBlock Text="&#xCD;cone de bandeja, inicializa&#xE7;&#xE3;o e CPU" FontSize="12" Foreground="#AAA" TextWrapping="Wrap" Margin="0,0,0,15"/>
                
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="MOSTRAR &#xCD;CONE" FontWeight="SemiBold" FontSize="13" Foreground="White"/>
                        <TextBlock Text="&#xCD;cone de bandeja na &#xE1;rea de notifica&#xE7;&#xE3;o" FontSize="11" Foreground="#888"/>
                    </StackPanel>
                    <ToggleButton x:Name="ChkTrayIcon" Grid.Column="1" Style="{StaticResource GoldToggleStyle}"
                                  Checked="ChkTrayIcon_Click" Unchecked="ChkTrayIcon_Click"/>
                </Grid>
                
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="INICIAR COM WINDOWS" FontWeight="SemiBold" FontSize="13" Foreground="White"/>
                        <TextBlock Text="Inicia automaticamente com o sistema" FontSize="11" Foreground="#888"/>
                    </StackPanel>
                    <ToggleButton x:Name="ChkStartWithWindows" Grid.Column="1" Style="{StaticResource GoldToggleStyle}"
                                  Checked="ChkStartWithWindows_Click" Unchecked="ChkStartWithWindows_Click"/>
                </Grid>
                
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="UNPARK CPU" FontWeight="SemiBold" FontSize="13" Foreground="White"/>
                        <TextBlock Text="Desparquear CPUs para menor lat&#xEA;ncia (via powercfg)" FontSize="11" Foreground="#888"/>
                        <TextBlock Text="&#x26A1; Similar ao PowerSettingsExplorer" FontSize="10" Foreground="#FFD700" Margin="0,2,0,0"/>
                    </StackPanel>
                    <ToggleButton x:Name="ChkUnparkCpu" Grid.Column="1" Style="{StaticResource GoldToggleStyle}"
                                  Checked="ChkUnparkCpu_Click" Unchecked="ChkUnparkCpu_Click"/>
                </Grid>
            </StackPanel>
        </Border>
        
        <!-- CARD 3: COMPORTAMENTO AO FECHAR -->
        <Border Grid.Row="2" Style="{StaticResource CompactCardStyle}" Padding="20" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="COMPORTAMENTO AO FECHAR" Foreground="#666" FontSize="12" FontWeight="Bold" Margin="0,0,0,15"/>
                
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Rodar em segundo plano" FontWeight="SemiBold" FontSize="13" Foreground="White"/>
                        <TextBlock Text="Minimiza ao clicar no X (mant&#xE9;m ativo)" FontSize="11" Foreground="#888"/>
                    </StackPanel>
                    <ToggleButton x:Name="ChkCloseToTray" Grid.Column="1" Style="{StaticResource GoldToggleStyle}"
                                  Checked="ChkCloseToTray_Click" Unchecked="ChkCloseToTray_Click"/>
                </Grid>
                
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="ProBalance" FontWeight="SemiBold" FontSize="13" Foreground="White"/>
                        <TextBlock Text="Gerenciamento de processos background" FontSize="11" Foreground="#888"/>
                        <TextBlock Text="&#x26A0;&#xFE0F; Inst&#xE1;vel - Em testes. Se tiver problemas, desative imediatamente." 
                                   FontSize="13" Foreground="#FF6B6B" Margin="0,3,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtProBalanceStatus" Grid.Column="1" Text="ATIVADO" 
                               FontSize="11" FontWeight="Bold" 
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ToggleButton x:Name="ChkProBalance" Grid.Column="2" Style="{StaticResource GoldToggleStyle}"
                                  Checked="ChkProBalance_Click" Unchecked="ChkProBalance_Click"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- &#x1F525; CARD 4: SELE&#xC7;&#xC3;O DE MOTOR -->
        <Border Grid.Row="3" Style="{StaticResource CompactCardStyle}" Padding="20" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="&#x1F3AE; Motor do GameBoost" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                    <TextBlock x:Name="TxtEngineDescription"
                               Text="&#x1F7E2; V1 - Original Plus: Win32PrioritySeparation + CPU/IO/Page boost (PADR&#xC3;O) - Seguro e est&#xE1;vel"
                               FontSize="12" Foreground="#AAA" Margin="0,5,0,0" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                    <ComboBox x:Name="CmbEngine" Width="220" Height="38" FontSize="13"
                              MaxDropDownHeight="150"
                              IsEnabled="True"
                              IsHitTestVisible="True"
                              Focusable="True"
                              SelectionChanged="CmbEngine_SelectionChanged"
                              Style="{StaticResource DarkComboBoxStyle}"
                              ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"
                              Cursor="Hand">
                        <ComboBoxItem Content="&#x1F7E2; V1 - Original Plus (Win32Priority)" Tag="1"/>
                        <ComboBoxItem Content="&#x1F7E1; V2 - FPS Est&#xE1;vel Plus (P-Cores+GameMode)" Tag="2"/>
                        <ComboBoxItem Content="&#x1F534; V3 - Extremo Plus (Tudo no m&#xE1;ximo)" Tag="3"/>
                        <ComboBoxItem Content="&#x1F4A5; V4 - Extreme Pro (RealTime)" Tag="4"/>
                        <ComboBoxItem Content="&#x2699;&#xFE0F; Personalizado..." Tag="custom"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- &#x1F525; CARD 5: GAMEBAR PRESENCE WRITER -->
        <Border Grid.Row="4" Style="{StaticResource CompactCardStyle}" Padding="20" Margin="0,0,0,15">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="&#x1F680; Desativar GameBarPresenceWriter.exe" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                        <TextBlock Text="&#x26A1; M&#xC9;TODO EFICAZ: Renomeia o arquivo para eliminar consumo de CPU/RAM em jogos" FontSize="11" Foreground="#FFD700" Margin="0,0,0,5"/>
                        <TextBlock Text="GameBar continua funcionando normalmente. Apenas remove o processo de background que causa drops de FPS." FontSize="11" Foreground="#AAA" TextWrapping="Wrap"/>
                    </StackPanel>
                    <ToggleButton x:Name="ChkGameBarPresenceWriter" Grid.Column="1" Style="{StaticResource GoldToggleStyle}"
                                  Checked="ChkGameBarPresenceWriter_Click" Unchecked="ChkGameBarPresenceWriter_Click"/>
                </Grid>

                <Border Background="#1A1A1A" CornerRadius="5" Padding="15" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="&#x1F4CA; Benef&#xED;cios:" FontSize="12" FontWeight="Bold" Foreground="#FFD700" Margin="0,0,0,8"/>
                        <TextBlock Text="&#x2022; Menos uso de CPU em background durante jogos" FontSize="11" Foreground="#CCC" Margin="0,0,0,4"/>
                        <TextBlock Text="&#x2022; Mais RAM dispon&#xED;vel para jogos" FontSize="11" Foreground="#CCC" Margin="0,0,0,4"/>
                        <TextBlock Text="&#x2022; FPS mais est&#xE1;veis (sem drops de 130&#x2192;30 FPS)" FontSize="11" Foreground="#CCC" Margin="0,0,0,4"/>
                        <TextBlock Text="&#x2022; Menos lat&#xEA;ncia ao alternar janelas" FontSize="11" Foreground="#CCC" Margin="0,0,0,4"/>
                        <TextBlock Text="&#x2022; Elimina telemetria de presen&#xE7;a de jogos" FontSize="11" Foreground="#CCC"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- CONTE&#xDA;DO -->
        <StackPanel Grid.Row="5" Margin="0,0,0,30">

            <!-- ALGORITMO INFO -->
            <TextBlock Text="&#x2699;&#xFE0F; Algoritmo ProBalance Style" FontSize="18" FontWeight="Bold" 
                       Foreground="White" Margin="0,0,0,15"/>
            
            <Grid Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- CARD 1 -->
                <Border Grid.Column="0" Style="{StaticResource CompactCardStyle}" Padding="20" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="&#x1F53A;" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Foreground Boost" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentColor}"
                                   TextAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock Text="App ativo recebe prioridade High automaticamente" FontSize="11" Foreground="#888"
                                   TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                
                <!-- CARD 2 -->
                <Border Grid.Column="1" Style="{StaticResource CompactCardStyle}" Padding="20" Margin="5,0,5,0">
                    <StackPanel>
                        <TextBlock Text="&#x1F53B;" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Background Throttle" FontSize="14" FontWeight="Bold" Foreground="#FF6B6B"
                                   TextAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock Text="Processos background CPU-intensive s&#xE3;o reduzidos (Below Normal)" FontSize="11" Foreground="#888"
                                   TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                
                <!-- CARD 3 -->
                <Border Grid.Column="2" Style="{StaticResource CompactCardStyle}" Padding="20" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="&#x26A1;" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Otimiza&#xE7;&#xF5;es Avan&#xE7;adas" FontSize="14" FontWeight="Bold" Foreground="#4ECDC4"
                                   TextAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock Text="EcoQoS + Thread Memory Priority + Timer Resolution (1ms)" FontSize="11" Foreground="#888"
                                   TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- PROCESSOS MONITORADOS -->
            <Border Style="{StaticResource CompactCardStyle}" Padding="25" Margin="0,0,0,20">
                <StackPanel>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="&#x1F3AE; GameBoost Ativo" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                            <TextBlock Text="Detec&#xE7;&#xE3;o autom&#xE1;tica de foreground e otimiza&#xE7;&#xE3;o" FontSize="12" Foreground="#888"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="StatusText" Text="MONITORANDO" FontSize="11" FontWeight="SemiBold" Foreground="#4CAF50"/>
                        </StackPanel>
                    </Grid>

                    <!-- Indicadores de Status -->
                    <Border Background="#1E1E1E" CornerRadius="6" Padding="16" Margin="0,10,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#x2705;" FontSize="16" Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Detec&#xE7;&#xE3;o Foreground" FontWeight="SemiBold" Foreground="#4CAF50" FontSize="12"/>
                                    <TextBlock Text="Kernel Hook - Instant&#xE2;neo e sem lag" FontSize="11" Foreground="#888"/>
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#x2705;" FontSize="16" Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Otimiza&#xE7;&#xE3;o Autom&#xE1;tica" FontWeight="SemiBold" Foreground="#4CAF50" FontSize="12"/>
                                    <TextBlock Text="Boost aplicado ao processo em foreground" FontSize="11" Foreground="#888"/>
                                </StackPanel>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="&#x2705;" FontSize="16" Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Revers&#xE3;o Autom&#xE1;tica" FontWeight="SemiBold" Foreground="#4CAF50" FontSize="12"/>
                                    <TextBlock Text="Prioridades restauradas ao sair do foreground" FontSize="11" Foreground="#888"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ESTAT&#xCD;STICAS -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>


                <Border Grid.Column="0" Style="{StaticResource CompactCardStyle}" Padding="15" Margin="0,0,8,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,5">
                            <TextBlock x:Name="TxtTotalBoosted" Text="0" FontSize="24" FontWeight="Bold"
                                       Foreground="{StaticResource AccentColor}" HorizontalAlignment="Center"/>
                            <Border Background="#DDFF9800" CornerRadius="6" Padding="8,4" HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Margin="0,-8,0,0">
                                <TextBlock Text="Em Desenvolvimento" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="Apps Otimizados" FontSize="11" Foreground="#888" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CompactCardStyle}" Padding="15" Margin="4,0,4,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,5">
                            <TextBlock x:Name="TxtThrottled" Text="0" FontSize="24" FontWeight="Bold"
                                       Foreground="#FF6B6B" HorizontalAlignment="Center"/>
                            <Border Background="#DDFF9800" CornerRadius="6" Padding="8,4" HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Margin="0,-8,0,0">
                                <TextBlock Text="Em Desenvolvimento" FontSize="10" FontWeight="SemiBold" Foreground="White"/>
                            </Border>
                        </Grid>
                        <TextBlock Text="Processos Reduzidos" FontSize="11" Foreground="#888" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CompactCardStyle}" Padding="15" Margin="4,0,4,0">
                    <StackPanel>
                        <TextBlock x:Name="TxtActiveForeground" Text="-" FontSize="24" FontWeight="Bold"
