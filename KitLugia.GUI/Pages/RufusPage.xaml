<Page x:Class="KitLugia.GUI.Pages.RufusPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Rufus"
      TextElement.FontFamily="Segoe UI Variable Display, Segoe UI, Segoe UI Emoji, Segoe UI Symbol, Arial">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Scrollable content area -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="30,20,30,10">
            <Grid MaxWidth="850">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="&#x1F4BF; Rufus — Mídia Bootável" FontSize="26" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,3"/>
                <TextBlock Grid.Row="1" Text="Formate e crie pendrives/USB bootáveis a partir de ISOs." Foreground="#999" Margin="0,0,0,16"/>

                <!-- Device + Boot Selection in one row -->
                <Grid Grid.Row="2" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Dispositivo" FontWeight="SemiBold" Foreground="#AAA" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="CboDevice" Grid.Column="1" Background="#2d2d2d" Foreground="White" BorderBrush="#444" FontSize="13" Height="34" Padding="6,0"/>
                    <Button Grid.Column="2" Content="&#x1F504;" Click="BtnRefreshDevices_Click" Width="34" Height="34" Margin="6,0,6,0" Style="{StaticResource SecondaryButtonStyle}" FontSize="15"/>
                    <TextBlock Grid.Column="3" Text="Tipo de boot" FontWeight="SemiBold" Foreground="#AAA" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="CboBootType" Grid.Column="4" Background="#2d2d2d" Foreground="White" BorderBrush="#444" FontSize="12" Height="34" Padding="6,0" Width="170" SelectedIndex="0">
                        <ComboBoxItem>Disco ou ISO</ComboBoxItem>
                        <ComboBoxItem>Imagem DD (Raw)</ComboBoxItem>
                        <ComboBoxItem>FreeDOS</ComboBoxItem>
                        <ComboBoxItem>Dual Boot (E2B)</ComboBoxItem>
                    </ComboBox>
                </Grid>

                <!-- ISO selection -->
                <Grid Grid.Row="3" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtIsoPath" IsReadOnly="True" Background="#1a1a1a" Foreground="#888" BorderBrush="#444" Padding="6,0" FontSize="12" Height="32" Text="Nenhum arquivo selecionado (opcional — formate sem ISO)"/>
                    <Button Grid.Column="1" x:Name="BtnSelect" Content="&#x1F4C2; SELECIONAR" Click="BtnSelectIso_Click" Width="110" Height="32" Margin="6,0,0,0" Style="{StaticResource GoldButtonStyle}" FontSize="11" FontWeight="Bold"/>
                </Grid>

                <!-- Partition scheme + Target + FS + Cluster -->
                <Border Grid.Row="4" Background="#161616" CornerRadius="6" Padding="10" Margin="0,0,0,6" BorderBrush="#333" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Esquema" Foreground="#AAA" FontSize="11" Margin="0,0,0,2"/>
                            <ComboBox x:Name="CboScheme" Background="#2d2d2d" Foreground="White" BorderBrush="#444" Height="30" FontSize="12">
                                <ComboBoxItem IsSelected="True">MBR</ComboBoxItem>
                                <ComboBoxItem>GPT</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="6,0,0,0">
                            <TextBlock Text="Sistema alvo" Foreground="#AAA" FontSize="11" Margin="0,0,0,2"/>
                            <ComboBox x:Name="CboTargetSystem" Background="#2d2d2d" Foreground="White" BorderBrush="#444" Height="30" FontSize="12">
                                <ComboBoxItem IsSelected="True">BIOS ou UEFI</ComboBoxItem>
                                <ComboBoxItem>Apenas UEFI</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="6,0,0,0">
                            <TextBlock Text="Sistema de arquivos" Foreground="#AAA" FontSize="11" Margin="0,0,0,2"/>
                            <ComboBox x:Name="CboFileSystem" Background="#2d2d2d" Foreground="White" BorderBrush="#444" Height="30" FontSize="12">
                                <ComboBoxItem IsSelected="True">FAT32</ComboBoxItem>
                                <ComboBoxItem>NTFS</ComboBoxItem>
                                <ComboBoxItem>exFAT</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="3" Margin="6,0,0,0">
                            <TextBlock Text="Cluster" Foreground="#AAA" FontSize="11" Margin="0,0,0,2"/>
                            <ComboBox x:Name="CboClusterSize" Background="#2d2d2d" Foreground="White" BorderBrush="#444" Height="30" FontSize="12">
                                <ComboBoxItem IsSelected="True">4096 (padrão)</ComboBoxItem>
                                <ComboBoxItem>8192</ComboBoxItem>
                                <ComboBoxItem>16384</ComboBoxItem>
                                <ComboBoxItem>32768</ComboBoxItem>
                                <ComboBoxItem>65536</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Label + Persistence row -->
                <Border Grid.Row="5" Background="#161616" CornerRadius="6" Padding="10" Margin="0,0,0,6" BorderBrush="#333" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Rótulo do volume" Foreground="#AAA" FontSize="11" Margin="0,0,0,2"/>
                            <TextBox x:Name="TxtLabel" Text="KITLUGIA" Background="#2d2d2d" Foreground="White" BorderBrush="#444" Padding="6,0" Height="30" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                            <CheckBox x:Name="ChkExtendedLabel" Content="Rótulo estendido" Foreground="#CCC" FontSize="11" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="10,0,0,0">
                            <TextBlock Text="Partição persistente (MB)" Foreground="#AAA" FontSize="11" Margin="0,0,0,2"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtPersistSize" Text="0" Background="#2d2d2d" Foreground="White" BorderBrush="#444" Padding="6,0" Height="30" FontSize="12"/>
                                <ComboBox Grid.Column="1" x:Name="CboPersistUnit" Background="#2d2d2d" Foreground="White" BorderBrush="#444" Height="30" FontSize="11" Width="48" Margin="4,0,0,0" SelectedIndex="0">
                                    <ComboBoxItem>MB</ComboBoxItem>
                                    <ComboBoxItem>GB</ComboBoxItem>
                                </ComboBox>
                            </Grid>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Windows install options (visible when Windows ISO detected) -->
                <Border x:Name="WindowsOptionsPanel" Grid.Row="6" Visibility="Collapsed" Background="#161616" CornerRadius="6" Padding="10" Margin="0,0,0,6" BorderBrush="#FFD700" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="&#x2699; Opções do Windows Setup" Foreground="{StaticResource AccentColor}" FontWeight="Bold" FontSize="12" Margin="0,0,0,8"/>

                        <WrapPanel Grid.Row="1" Margin="0,0,0,6">
                            <CheckBox x:Name="ChkBypassTPM" IsChecked="True" Content="Ignorar TPM" Foreground="#CCC" FontSize="11" Margin="0,0,10,3"/>
                            <CheckBox x:Name="ChkBypassSecureBoot" IsChecked="True" Content="Ignorar SecureBoot" Foreground="#CCC" FontSize="11" Margin="0,0,10,3"/>
                            <CheckBox x:Name="ChkBypassRAM" IsChecked="True" Content="Ignorar RAM" Foreground="#CCC" FontSize="11" Margin="0,0,10,3"/>
                            <CheckBox x:Name="ChkBypassStorage" IsChecked="True" Content="Ignorar Armazenamento" Foreground="#CCC" FontSize="11" Margin="0,0,10,3"/>
                            <CheckBox x:Name="ChkLocalAccount" IsChecked="True" Content="Conta local" Foreground="#CCC" FontSize="11" Margin="0,0,10,3"/>
                            <CheckBox x:Name="ChkDisableDataColl" IsChecked="True" Content="Desativar telemetria" Foreground="#CCC" FontSize="11" Margin="0,0,10,3"/>
                            <CheckBox x:Name="ChkDisableBitlocker" IsChecked="True" Content="Desativar BitLocker" Foreground="#CCC" FontSize="11"/>
                        </WrapPanel>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Usuário:" Foreground="#AAA" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="TxtWinUser" Text="Usuario" Grid.Column="1" Background="#2d2d2d" Foreground="White" BorderBrush="#444" Padding="6,0" Height="28" FontSize="12"/>
                            <TextBlock Grid.Column="2" Text="Senha:" Foreground="#AAA" FontSize="11" VerticalAlignment="Center" Margin="12,0,8,0"/>
                            <PasswordBox x:Name="TxtWinPass" Grid.Column="3" Background="#2d2d2d" Foreground="White" BorderBrush="#444" Padding="6,0" Height="28" FontSize="12"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Checkboxes row -->
                <WrapPanel Grid.Row="7" Margin="0,0,0,6">
                    <CheckBox x:Name="ChkQuickFormat" IsChecked="True" Content="Formatação rápida" Foreground="#CCC" FontSize="12" Margin="0,0,14,3"/>
                    <CheckBox x:Name="ChkBadBlocks" Content="Bad blocks" Foreground="#CCC" FontSize="12" Margin="0,0,6,3"/>
                    <ComboBox x:Name="CboNBPasses" Background="#2d2d2d" Foreground="White" BorderBrush="#444" Height="26" FontSize="11" Width="90" IsEnabled="False" Margin="0,0,14,3">
                        <ComboBoxItem IsSelected="True">1 passagem</ComboBoxItem>
                        <ComboBoxItem>2 passagens</ComboBoxItem>
                        <ComboBoxItem>4 passagens</ComboBoxItem>
                    </ComboBox>
                    <CheckBox x:Name="ChkOldBiosFixes" Content="Correções BIOS antigo" Foreground="#CCC" FontSize="12" Margin="0,0,14,3"/>
                    <CheckBox x:Name="ChkUefiValidation" Content="Validação UEFI" Foreground="#CCC" FontSize="12" Margin="0,0,14,3"/>
                    <CheckBox x:Name="ChkMultiBoot" Content="Multi-boot" Foreground="#CCC" FontSize="12" Margin="0,0,0,3"/>
                </WrapPanel>

                <!-- Multi-ISO panel -->
                <Border x:Name="MultiIsoPanel" Grid.Row="8" Visibility="Collapsed" Background="#161616" CornerRadius="6" Padding="10" Margin="0,0,0,6" BorderBrush="#333" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <TextBlock Text="ISOs adicionais:" Foreground="{StaticResource AccentColor}" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                            <Button Content="+ Adicionar" Click="BtnAddMultiIso_Click" Margin="10,0,0,0" Height="28" Width="85" Style="{StaticResource SecondaryButtonStyle}" FontSize="11"/>
                        </StackPanel>
                        <ListBox x:Name="ListMultiIsos" Grid.Row="1" Background="#111" BorderBrush="#333" Height="60" Foreground="#CCC" FontSize="11"/>
                    </Grid>
                </Border>

                <!-- Hash + Progress -->
                <Border x:Name="HashPanel" Grid.Row="9" Visibility="Collapsed" Background="#161616" CornerRadius="4" Padding="8" Margin="0,0,0,4" BorderBrush="#333" BorderThickness="1">
                    <TextBlock TextWrapping="Wrap"><Run Text="SHA256: " Foreground="#888" FontSize="11"/><Run x:Name="TxtHash" Text="..." Foreground="#AAA" FontSize="11" FontFamily="Consolas"/></TextBlock>
                </Border>

                <Border x:Name="ProgressPanel" Grid.Row="10" Visibility="Collapsed" Background="#161616" CornerRadius="6" Padding="10" Margin="0,0,0,6" BorderBrush="#333" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="TxtProgressStatus" Text="Preparando..." Foreground="{StaticResource AccentColor}" FontSize="13" Margin="0,0,0,4"/>
                        <ProgressBar x:Name="ProgressBar" Grid.Row="1" Height="16" Background="#333" Foreground="{StaticResource AccentColor}" BorderThickness="0" Maximum="100"/>
                        <TextBlock x:Name="TxtProgressPercent" Grid.Row="1" Text="0%" Foreground="#888" FontSize="10" HorizontalAlignment="Right" Margin="0,0,4,0" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- ═══════ FIXED BOTTOM BAR — sempre visível ═══════ -->
        <Border Grid.Row="1" Background="#1A1A1A" BorderBrush="#333" BorderThickness="0,1,0,0" Padding="30,10,30,15" Panel.ZIndex="100">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Log preview (left) -->
                <Border Grid.Column="0" Background="#0a0a0a" CornerRadius="4" BorderBrush="#333" BorderThickness="1" Height="36" Margin="0,0,15,0">
                    <Grid>
                        <TextBox x:Name="TxtLog" Background="Transparent" Foreground="#AAA" BorderThickness="0" IsReadOnly="True" Padding="6,0" FontFamily="Consolas" FontSize="10" VerticalAlignment="Center" Text="[Pronto]"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0">
                            <Button Content="Limpar" Click="BtnClearLog_Click" Height="22" FontSize="9" Width="50" Style="{StaticResource SecondaryButtonStyle}" Padding="2,0" BorderThickness="0"/>
                            <Button Content="Salvar" Click="BtnSaveLog_Click" Height="22" FontSize="9" Width="50" Margin="3,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Padding="2,0" BorderThickness="0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- START button -->
                <Button Grid.Column="1" x:Name="BtnStart" Content="&#x25B6; INICIAR" Click="BtnStart_Click" Width="140" Height="36" Style="{StaticResource GoldButtonStyle}" FontSize="13" FontWeight="Bold" IsEnabled="False"/>

                <!-- STOP button -->
                <Button Grid.Column="2" x:Name="BtnStop" Content="&#x23F9; Parar" Click="BtnStop_Click" Width="80" Height="36" Margin="8,0,0,0" Style="{StaticResource SecondaryButtonStyle}" IsEnabled="False" Foreground="#FF6F61"/>

                <!-- Extra: Format only button (no ISO needed) -->
                <Button Grid.Column="3" x:Name="BtnFormatOnly" Content="&#x1F9F9; Só formatar" Click="BtnFormatOnly_Click" Width="110" Height="36" Margin="8,0,0,0" Style="{StaticResource SecondaryButtonStyle}" FontSize="11" IsEnabled="False"/>
            </Grid>
        </Border>
    </Grid>
</Page>
