                        </Button>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Limpar Recent Items" FontSize="15" Foreground="White"/>
                            <TextBlock Text="Limpa a lista de arquivos recentes do usu&#xE1;rio." FontSize="12" Foreground="#808080" Margin="0,2,0,0"/>
