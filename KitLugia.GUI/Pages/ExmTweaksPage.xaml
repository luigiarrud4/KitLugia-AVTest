                        <Button x:Name="BtnCleanIeCache" Grid.Column="3" Content="Executar" Style="{StaticResource ActionButtonStyle}" Click="BtnCleanIeCache_Click"/>
                    </Grid>

                    <Separator Background="{StaticResource CardBorder}"/>

                    <!-- Dumps/Logs -->
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Width="30" Height="30" Cursor="Help" Margin="0,0,10,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                            <Button.ToolTip>
                                <ToolTip Content="Remove Minidumps, Windows Logs e WER (Windows Error Reporting) Reports. Libera espa&#xE7;o sem impacto no sistema."/>
                            </Button.ToolTip>
                            <TextBlock Text="&#x2139;&#xFE0F;" FontSize="16" Foreground="{StaticResource AccentColor}" Opacity="0.6"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <StackPanel Grid.Column="1">
