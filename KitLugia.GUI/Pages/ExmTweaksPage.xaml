                        <TextBlock x:Name="StatusDisableExceptionChain" Text="Verificando..." Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="Gray" FontWeight="SemiBold"/>
                        <CheckBox x:Name="ChkDisableExceptionChain" Grid.Column="3" Style="{StaticResource ToggleSwitchStyle}" Click="ChkDisableExceptionChain_Click"/>
                    </Grid>

                    <Separator Background="{StaticResource CardBorder}"/>

                    <!-- Disable CFG -->
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Width="30" Height="30" Cursor="Help" Margin="0,0,10,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                            <Button.ToolTip>
                                <ToolTip Content="Desativa Control Flow Guard (EnableCfg=0). Reduz a prote&#xE7;&#xE3;o contra exploits de mem&#xF3;ria para ganho de FPS em jogos. N&#xE3;o recomendado em m&#xE1;quinas de trabalho."/>
                            </Button.ToolTip>
                            <TextBlock Text="&#x2139;&#xFE0F;" FontSize="16" Foreground="{StaticResource AccentColor}" Opacity="0.6"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Desativar CFG (Control Flow Guard)" FontSize="15" Foreground="White"/>
                            <TextBlock Text="Desativa CFG para ganho de FPS (reduz seguran&#xE7;a)." FontSize="12" Foreground="#808080" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusDisableCfg" Text="Verificando..." Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="Gray" FontWeight="SemiBold"/>
                        <CheckBox x:Name="ChkDisableCfg" Grid.Column="3" Style="{StaticResource ToggleSwitchStyle}" Click="ChkDisableCfg_Click"/>
                    </Grid>

                    <Separator Background="{StaticResource CardBorder}"/>

                    <!-- Distribute Timers -->
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Width="30" Height="30" Cursor="Help" Margin="0,0,10,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                            <Button.ToolTip>
