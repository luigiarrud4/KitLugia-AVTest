                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Desativar Exception Chain Validation" FontSize="15" Foreground="White"/>
                            <TextBlock Text="Remove valida&#xE7;&#xE3;o de cadeia de exce&#xE7;&#xF5;es (ganho FPS marginal)." FontSize="12" Foreground="#808080" Margin="0,2,0,0"/>
