                            </Button.Template>
                        </Button>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Keyboard Data Queue (100)" FontSize="15" Foreground="White"/>
                            <TextBlock Text="Aumenta fila de dados do teclado para 100 (menos perda de input)." FontSize="12" Foreground="#808080" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusKeyboardDataQueue" Text="Verificando..." Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="Gray" FontWeight="SemiBold"/>
                        <CheckBox x:Name="ChkKeyboardDataQueue" Grid.Column="3" Style="{StaticResource ToggleSwitchStyle}" Click="ChkKeyboardDataQueue_Click"/>
                    </Grid>

                    <Separator Background="{StaticResource CardBorder}"/>

                    <!-- Mouse Data Queue -->
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Width="30" Height="30" Cursor="Help" Margin="0,0,10,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                            <Button.ToolTip>
                                <ToolTip Content="Define o tamanho da fila de dados do mouse para 100 (MouseDataQueueSize=100). Melhora a precis&#xE3;o e resposta do mouse em jogos."/>
                            </Button.ToolTip>
                            <TextBlock Text="&#x2139;&#xFE0F;" FontSize="16" Foreground="{StaticResource AccentColor}" Opacity="0.6"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Mouse Data Queue (100)" FontSize="15" Foreground="White"/>
                            <TextBlock Text="Aumenta fila de dados do mouse para 100 (maior precis&#xE3;o)." FontSize="12" Foreground="#808080" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusMouseDataQueue" Text="Verificando..." Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="Gray" FontWeight="SemiBold"/>
                        <CheckBox x:Name="ChkMouseDataQueue" Grid.Column="3" Style="{StaticResource ToggleSwitchStyle}" Click="ChkMouseDataQueue_Click"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Background="#2D2020" BorderBrush="#503030" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,20,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x26A0;&#xFE0F;" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="16"/>
                    <TextBlock Text="Altera&#xE7;&#xF5;es nestas configura&#xE7;&#xF5;es exigem que voc&#xEA; reinicie o computador para serem aplicadas pelo Windows." 
                               Foreground="#FFC0C0" VerticalAlignment="Center" FontSize="13"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
