            <!-- ====== STORAGE / MANUTENÇÃO ====== -->
            <TextBlock Text="Manuten&#xE7;&#xE3;o e Limpeza" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,30,0,15"/>
