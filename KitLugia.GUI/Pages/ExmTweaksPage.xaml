                        </Button>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Limpar Cache IE/Edge" FontSize="15" Foreground="White"/>
                            <TextBlock Text="Limpa INetCache do Internet Explorer/Edge." FontSize="12" Foreground="#808080" Margin="0,2,0,0"/>
