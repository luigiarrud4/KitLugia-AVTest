                        <Button x:Name="BtnCleanDumpsLogs" Grid.Column="3" Content="Executar" Style="{StaticResource ActionButtonStyle}" Click="BtnCleanDumpsLogs_Click"/>
                    </Grid>

                    <Separator Background="{StaticResource CardBorder}"/>

                    <!-- SFC -->
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Width="30" Height="30" Cursor="Help" Margin="0,0,10,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                            <Button.ToolTip>
                                <ToolTip Content="Executa sfc /scannow. Verifica e repara arquivos protegidos do Windows. Pode levar at&#xE9; 15 minutos. Requer administrador."/>
                            </Button.ToolTip>
                            <TextBlock Text="&#x2139;&#xFE0F;" FontSize="16" Foreground="{StaticResource AccentColor}" Opacity="0.6"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Executar SFC / ScanNow" FontSize="15" Foreground="White"/>
                            <TextBlock Text="Verifica integridade de arquivos protegidos do Windows." FontSize="12" Foreground="#808080" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusSfcScan" Text="Parado" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="Gray" FontWeight="SemiBold"/>
                        <StackPanel Grid.Column="3" Orientation="Vertical" HorizontalAlignment="Right">
                            <Button x:Name="BtnSfcScan" Content="Executar" Style="{StaticResource ActionButtonStyle}" Click="BtnSfcScan_Click"/>
                            <ProgressBar x:Name="ProgressSfc" Height="3" Width="75" Margin="0,4,0,0" Minimum="0" Maximum="100" Visibility="Collapsed" Foreground="#FFD700" Background="#333333"/>
                        </StackPanel>
                    </Grid>

                    <Separator Background="{StaticResource CardBorder}"/>

                    <!-- DISM -->
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Width="30" Height="30" Cursor="Help" Margin="0,0,10,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                            <Button.ToolTip>
                                <ToolTip Content="Executa DISM /RestoreHealth + /StartComponentCleanup /ResetBase. Repara imagem do sistema e limpa WinSxS. Pode levar at&#xE9; 30 minutos."/>
                            </Button.ToolTip>
                            <TextBlock Text="&#x2139;&#xFE0F;" FontSize="16" Foreground="{StaticResource AccentColor}" Opacity="0.6"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Executar DISM + ResetBase" FontSize="15" Foreground="White"/>
                            <TextBlock Text="Repara imagem do Windows e limpa WinSxS." FontSize="12" Foreground="#808080" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusDism" Text="Parado" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="Gray" FontWeight="SemiBold"/>
                        <StackPanel Grid.Column="3" Orientation="Vertical" HorizontalAlignment="Right">
                            <Button x:Name="BtnDism" Content="Executar" Style="{StaticResource ActionButtonStyle}" Click="BtnDism_Click"/>
                            <ProgressBar x:Name="ProgressDism" Height="3" Width="75" Margin="0,4,0,0" Minimum="0" Maximum="100" Visibility="Collapsed" Foreground="#FFD700" Background="#333333"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ====== SISTEMA E MEMÓRIA ====== -->
            <TextBlock Text="Sistema e Mem&#xF3;ria" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,30,0,15"/>
            <Border Background="{StaticResource CardBackground}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="8" Style="{StaticResource CardStyle}">
                <StackPanel>

                    <!-- Disable Prefetch/Superfetch -->
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Width="30" Height="30" Cursor="Help" Margin="0,0,10,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                            <Button.ToolTip>
                                <ToolTip Content="Define EnablePrefetcher=0 e EnableSuperfetch=0. Desativa os servi&#xE7;os de pr&#xE9;-busca e superfetch, reduzindo opera&#xE7;&#xF5;es de I/O em segundo plano em SSDs."/>
                            </Button.ToolTip>
                            <TextBlock Text="&#x2139;&#xFE0F;" FontSize="16" Foreground="{StaticResource AccentColor}" Opacity="0.6"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Desativar Prefetch/Superfetch" FontSize="15" Foreground="White"/>
                            <TextBlock Text="Desativa pr&#xE9;-busca e superfetch (EnablePrefetcher=0)." FontSize="12" Foreground="#808080" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusDisablePrefetch" Text="Verificando..." Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="Gray" FontWeight="SemiBold"/>
                        <CheckBox x:Name="ChkDisablePrefetch" Grid.Column="3" Style="{StaticResource ToggleSwitchStyle}" Click="ChkDisablePrefetch_Click"/>
                    </Grid>

                    <Separator Background="{StaticResource CardBorder}"/>

                    <!-- Large System Cache -->
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Width="30" Height="30" Cursor="Help" Margin="0,0,10,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                            <Button.ToolTip>
                                <ToolTip Content="Define LargeSystemCache=1. Faz o sistema usar mais mem&#xF3;ria RAM como cache de arquivos, melhorando desempenho em aplica&#xE7;&#xF5;es que acessam muitos arquivos."/>
                            </Button.ToolTip>
                            <TextBlock Text="&#x2139;&#xFE0F;" FontSize="16" Foreground="{StaticResource AccentColor}" Opacity="0.6"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Large System Cache" FontSize="15" Foreground="White"/>
                            <TextBlock Text="Aumenta cache de sistema para I/O de arquivos (LargeSystemCache=1)." FontSize="12" Foreground="#808080" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusLargeSystemCache" Text="Verificando..." Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="Gray" FontWeight="SemiBold"/>
                        <CheckBox x:Name="ChkLargeSystemCache" Grid.Column="3" Style="{StaticResource ToggleSwitchStyle}" Click="ChkLargeSystemCache_Click"/>
                    </Grid>

                    <Separator Background="{StaticResource CardBorder}"/>

                    <!-- Disable Paging Executive -->
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Width="30" Height="30" Cursor="Help" Margin="0,0,10,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                            <Button.ToolTip>
                                <ToolTip Content="Define DisablePagingExecutive=1. Mant&#xE9;m os drivers e c&#xF3;digo do kernel na RAM f&#xED;sica, nunca paginados para o disco. Aumenta performance mas consome mais RAM."/>
                            </Button.ToolTip>
                            <TextBlock Text="&#x2139;&#xFE0F;" FontSize="16" Foreground="{StaticResource AccentColor}" Opacity="0.6"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Desativar Paging Executive" FontSize="15" Foreground="White"/>
                            <TextBlock Text="Mant&#xE9;m kernel/drivers na RAM (DisablePagingExecutive=1)." FontSize="12" Foreground="#808080" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusDisablePagingExecutive" Text="Verificando..." Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="Gray" FontWeight="SemiBold"/>
                        <CheckBox x:Name="ChkDisablePagingExecutive" Grid.Column="3" Style="{StaticResource ToggleSwitchStyle}" Click="ChkDisablePagingExecutive_Click"/>
                    </Grid>

                    <Separator Background="{StaticResource CardBorder}"/>

                    <!-- Disable Exception Chain Validation -->
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Width="30" Height="30" Cursor="Help" Margin="0,0,10,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                            <Button.ToolTip>
                                <ToolTip Content="Desativa a valida&#xE7;&#xE3;o de cadeia de exce&#xE7;&#xF5;es do kernel (DisableExceptionChainValidation=1). Pode causar ganho marginal de FPS, reduzindo a seguran&#xE7;a."/>
                            </Button.ToolTip>
                            <TextBlock Text="&#x2139;&#xFE0F;" FontSize="16" Foreground="{StaticResource AccentColor}" Opacity="0.6"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
