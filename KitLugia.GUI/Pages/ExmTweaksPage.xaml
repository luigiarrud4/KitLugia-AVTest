<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="KitLugia.GUI.Pages.ExmTweaksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="EXM Tweaks"
      TextElement.FontFamily="Segoe UI Variable Display, Segoe UI, Segoe UI Emoji, Segoe UI Symbol, Arial">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,30,40,50" MaxWidth="900" HorizontalAlignment="Left">

            <TextBlock Text="Tweaks Avan&#xE7;ados (EXM)" FontSize="32" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="White"/>
            <TextBlock Text="Tweaks adicionais baseados no EXM Premium que n&#xE3;o est&#xE3;o no KitLugia padr&#xE3;o. Reinicializa&#xE7;&#xE3;o necess&#xE1;ria para a maioria." Foreground="#A0A0A0" Margin="0,0,0,30"/>

            <Border Background="#2D2020" BorderBrush="#503030" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x26A0;&#xFE0F;" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="16"/>
                    <TextBlock Text="Alguns tweaks usam BCDedit e modifica&#xE7;&#xF5;es profundas do sistema. Use com cautela." 
                               Foreground="#FFC0C0" VerticalAlignment="Center" FontSize="13" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- ====== REDE / TCP/IP ====== -->
            <TextBlock Text="Rede e TCP/IP" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
            <Border Background="{StaticResource CardBackground}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="8" Style="{StaticResource CardStyle}">
                <StackPanel>

                    <!-- TCP Initial RTO -->
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Width="30" Height="30" Cursor="Help" Margin="0,0,10,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                            <Button.ToolTip>
                                <ToolTip Content="Aumenta o RTO (Retransmission Timeout) inicial para 2000ms, melhorando a estabilidade em conex&#xF5;es com perda de pacotes. Padr&#xE3;o Windows: 3000ms."/>
                            </Button.ToolTip>
                            <TextBlock Text="&#x2139;&#xFE0F;" FontSize="16" Foreground="{StaticResource AccentColor}" Opacity="0.6"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="TCP Initial RTO (2000ms)" FontSize="15" Foreground="White"/>
                            <TextBlock Text="Aumenta RTO inicial para 2000ms (estabilidade)." FontSize="12" Foreground="#808080" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusTcpInitialRto" Text="Verificando..." Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="Gray" FontWeight="SemiBold"/>
                        <CheckBox x:Name="ChkTcpInitialRto" Grid.Column="3" Style="{StaticResource ToggleSwitchStyle}" Click="ChkTcpInitialRto_Click"/>
                    </Grid>

                    <Separator Background="{StaticResource CardBorder}"/>

                    <!-- TCP NonBestEffortLimit -->
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Width="30" Height="30" Cursor="Help" Margin="0,0,10,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                            <Button.ToolTip>
                                <ToolTip Content="Define NonBestEffortLimit=0 para desabilitar a limita&#xE7;&#xE3;o de QoS. Permite que aplica&#xE7;&#xF5;es usem toda a largura de banda dispon&#xED;vel sem restri&#xE7;&#xF5;es."/>
                            </Button.ToolTip>
                            <TextBlock Text="&#x2139;&#xFE0F;" FontSize="16" Foreground="{StaticResource AccentColor}" Opacity="0.6"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="TCP NonBestEffortLimit (0)" FontSize="15" Foreground="White"/>
                            <TextBlock Text="Desativa limite de QoS para melhor throughput." FontSize="12" Foreground="#808080" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusTcpNonBestEffort" Text="Verificando..." Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="Gray" FontWeight="SemiBold"/>
                        <CheckBox x:Name="ChkTcpNonBestEffort" Grid.Column="3" Style="{StaticResource ToggleSwitchStyle}" Click="ChkTcpNonBestEffort_Click"/>
                    </Grid>

                    <Separator Background="{StaticResource CardBorder}"/>

                    <!-- TCP DefaultTTL -->
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Width="30" Height="30" Cursor="Help" Margin="0,0,10,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                            <Button.ToolTip>
                                <ToolTip Content="Define o TTL (Time To Live) padr&#xE3;o para 64. Determina quantos saltos um pacote pode percorrer antes de ser descartado. 64 &#xE9; o valor ideal para a maioria das redes."/>
                            </Button.ToolTip>
                            <TextBlock Text="&#x2139;&#xFE0F;" FontSize="16" Foreground="{StaticResource AccentColor}" Opacity="0.6"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="TCP DefaultTTL (64)" FontSize="15" Foreground="White"/>
                            <TextBlock Text="Define TTL padr&#xE3;o para 64 (otimiza&#xE7;&#xE3;o de roteamento)." FontSize="12" Foreground="#808080" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusTcpDefaultTtl" Text="Verificando..." Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="Gray" FontWeight="SemiBold"/>
                        <CheckBox x:Name="ChkTcpDefaultTtl" Grid.Column="3" Style="{StaticResource ToggleSwitchStyle}" Click="ChkTcpDefaultTtl_Click"/>
                    </Grid>

                    <Separator Background="{StaticResource CardBorder}"/>

                    <!-- TCP Timestamps + Window Scale -->
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Width="30" Height="30" Cursor="Help" Margin="0,0,10,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                            <Button.ToolTip>
                                <ToolTip Content="Ativa TCP1323Opts=1 para habilitar Timestamps e Window Scaling. Melhora o throughput em conex&#xF5;es de alta lat&#xEA;ncia e longa dist&#xE2;ncia."/>
                            </Button.ToolTip>
                            <TextBlock Text="&#x2139;&#xFE0F;" FontSize="16" Foreground="{StaticResource AccentColor}" Opacity="0.6"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="TCP Timestamps + Window Scale" FontSize="15" Foreground="White"/>
                            <TextBlock Text="Ativa TCP1323Opts para melhor throughput em links de alta lat&#xEA;ncia." FontSize="12" Foreground="#808080" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusTcp1323" Text="Verificando..." Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="Gray" FontWeight="SemiBold"/>
                        <CheckBox x:Name="ChkTcp1323" Grid.Column="3" Style="{StaticResource ToggleSwitchStyle}" Click="ChkTcp1323_Click"/>
                    </Grid>

                    <Separator Background="{StaticResource CardBorder}"/>

                    <!-- TCP MaxDupAcks -->
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Width="30" Height="30" Cursor="Help" Margin="0,0,10,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                            <Button.ToolTip>
                                <ToolTip Content="Reduz o threshold de ACK duplicado para 2 (padr&#xE3;o &#xE9; 3). Permite recupera&#xE7;&#xE3;o mais r&#xE1;pida de pacotes perdidos, melhorando a estabilidade em jogos online."/>
                            </Button.ToolTip>
                            <TextBlock Text="&#x2139;&#xFE0F;" FontSize="16" Foreground="{StaticResource AccentColor}" Opacity="0.6"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="TCP MaxDupAcks (2)" FontSize="15" Foreground="White"/>
                            <TextBlock Text="Reduz threshold de ACK duplicado para recupera&#xE7;&#xE3;o mais r&#xE1;pida." FontSize="12" Foreground="#808080" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusTcpMaxDupAcks" Text="Verificando..." Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="Gray" FontWeight="SemiBold"/>
                        <CheckBox x:Name="ChkTcpMaxDupAcks" Grid.Column="3" Style="{StaticResource ToggleSwitchStyle}" Click="ChkTcpMaxDupAcks_Click"/>
                    </Grid>

                    <Separator Background="{StaticResource CardBorder}"/>

                    <!-- Desativar WSD -->
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Width="30" Height="30" Cursor="Help" Margin="0,0,10,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                            <Button.ToolTip>
                                <ToolTip Content="Desativa Web Services Discovery (WSD) no TCP/IP. Reduz tr&#xE1;fego de descoberta de rede na LAN. Recomendado para jogos online."/>
                            </Button.ToolTip>
                            <TextBlock Text="&#x2139;&#xFE0F;" FontSize="16" Foreground="{StaticResource AccentColor}" Opacity="0.6"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Desativar WebServices Discovery" FontSize="15" Foreground="White"/>
                            <TextBlock Text="Desativa WSD para reduzir tr&#xE1;fego de rede." FontSize="12" Foreground="#808080" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusDisableWsd" Text="Verificando..." Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="Gray" FontWeight="SemiBold"/>
                        <CheckBox x:Name="ChkDisableWsd" Grid.Column="3" Style="{StaticResource ToggleSwitchStyle}" Click="ChkDisableWsd_Click"/>
                    </Grid>

                    <Separator Background="{StaticResource CardBorder}"/>

                    <!-- Desativar mDNS -->
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Width="30" Height="30" Cursor="Help" Margin="0,0,10,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                            <Button.ToolTip>
                                <ToolTip Content="Desativa o servi&#xE7;o multicast DNS (mDNS). Reduz tr&#xE1;fego de descoberta de dispositivos na rede local. Pode afetar descoberta de Chromecast e AirPlay."/>
                            </Button.ToolTip>
                            <TextBlock Text="&#x2139;&#xFE0F;" FontSize="16" Foreground="{StaticResource AccentColor}" Opacity="0.6"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Desativar mDNS" FontSize="15" Foreground="White"/>
                            <TextBlock Text="Desativa servi&#xE7;o mDNS (multicast DNS)." FontSize="12" Foreground="#808080" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusDisableMdns" Text="Verificando..." Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="Gray" FontWeight="SemiBold"/>
                        <CheckBox x:Name="ChkDisableMdns" Grid.Column="3" Style="{StaticResource ToggleSwitchStyle}" Click="ChkDisableMdns_Click"/>
                    </Grid>

                    <Separator Background="{StaticResource CardBorder}"/>

                    <!-- Desativar LLTD -->
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Width="30" Height="30" Cursor="Help" Margin="0,0,10,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                            <Button.ToolTip>
                                <ToolTip Content="Desativa o Link-Layer Topology Discovery (lltdsvc). Reduz tr&#xE1;fego de manuten&#xE7;&#xE3;o de mapa de rede. Recomendado para gamers."/>
                            </Button.ToolTip>
                            <TextBlock Text="&#x2139;&#xFE0F;" FontSize="16" Foreground="{StaticResource AccentColor}" Opacity="0.6"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Desativar LLTD (lltdsvc)" FontSize="15" Foreground="White"/>
                            <TextBlock Text="Link-Layer Topology Discovery mapper service." FontSize="12" Foreground="#808080" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusDisableLltd" Text="Verificando..." Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="Gray" FontWeight="SemiBold"/>
                        <CheckBox x:Name="ChkDisableLltd" Grid.Column="3" Style="{StaticResource ToggleSwitchStyle}" Click="ChkDisableLltd_Click"/>
                    </Grid>

                    <Separator Background="{StaticResource CardBorder}"/>

                    <!-- Desativar Bandwidth Throttle -->
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Width="30" Height="30" Cursor="Help" Margin="0,0,10,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                            <Button.ToolTip>
                                <ToolTip Content="Desativa a limita&#xE7;&#xE3;o de banda do LanmanWorkstation. Permite throughput m&#xE1;ximo em transfer&#xEA;ncias de rede SMB/CIFS."/>
                            </Button.ToolTip>
                            <TextBlock Text="&#x2139;&#xFE0F;" FontSize="16" Foreground="{StaticResource AccentColor}" Opacity="0.6"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Desativar Bandwidth Throttle" FontSize="15" Foreground="White"/>
                            <TextBlock Text="Desativa limita&#xE7;&#xE3;o de banda do LanmanWorkstation." FontSize="12" Foreground="#808080" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusDisableBandwidthThrottle" Text="Verificando..." Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="Gray" FontWeight="SemiBold"/>
                        <CheckBox x:Name="ChkDisableBandwidthThrottle" Grid.Column="3" Style="{StaticResource ToggleSwitchStyle}" Click="ChkDisableBandwidthThrottle_Click"/>
                    </Grid>

                    <Separator Background="{StaticResource CardBorder}"/>

                    <!-- Limpar Cache de Rede -->
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Width="30" Height="30" Cursor="Help" Margin="0,0,10,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                            <Button.ToolTip>
                                <ToolTip Content="Executa: netsh int ip delete arpcache/destinationcache/routecache/neighbors + ipconfig /flushdns /registerdns. Limpa todo o cache de rede do Windows."/>
                            </Button.ToolTip>
                            <TextBlock Text="&#x2139;&#xFE0F;" FontSize="16" Foreground="{StaticResource AccentColor}" Opacity="0.6"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Limpar Cache de Rede" FontSize="15" Foreground="White"/>
                            <TextBlock Text="Limpa ARP, DNS, route e destination cache (netsh + ipconfig)." FontSize="12" Foreground="#808080" Margin="0,2,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusFlushNetworkCache" Text="Verificando..." Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="Gray" FontWeight="SemiBold"/>
                        <Button x:Name="BtnFlushNetworkCache" Grid.Column="3" Content="Executar" Style="{StaticResource ActionButtonStyle}" Click="BtnFlushNetworkCache_Click"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ====== BCDedit ====== -->
            <TextBlock Text="Boot Configuration (BCDedit)" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,30,0,15"/>
            <Border Background="#1A1500" BorderBrush="#805500" BorderThickness="1" CornerRadius="8">
                <StackPanel>

                    <Border Background="#332000" BorderBrush="#995500" BorderThickness="1" CornerRadius="4" Padding="15" Margin="20,20,20,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x26A0;&#xFE0F; CUIDADO:" FontWeight="Bold" Foreground="#FFAA00" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Altera&#xE7;&#xF5;es BCDedit afetam o boot do Windows. Recomendado fazer backup antes." Foreground="#DDDDDD" FontSize="13" VerticalAlignment="Center" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- x2APIC -->
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Width="30" Height="30" Cursor="Help" Margin="0,0,10,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                            <Button.ToolTip>
                                <ToolTip Content="Habilita suporte a x2APIC no boot. Melhora o gerenciamento de interrup&#xE7;&#xF5;es em sistemas com muitos n&#xFA;cleos de CPU. Requer reinicializa&#xE7;&#xE3;o."/>
                            </Button.ToolTip>
                            <TextBlock Text="&#x2139;&#xFE0F;" FontSize="16" Foreground="{StaticResource AccentColor}" Opacity="0.6"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="Transparent">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="x2APIC Policy (Enable)" FontSize="15" Foreground="White"/>
                            <TextBlock Text="Habilita suporte a x2APIC para melhor gerenciamento de interrup&#xE7;&#xF5;es." FontSize="12" Foreground="#A0A0A0" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusX2Apic" Text="Verificando..." Grid.Column="2" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="Gray" FontWeight="SemiBold"/>
                        <CheckBox x:Name="ChkX2Apic" Grid.Column="3" Style="{StaticResource ToggleSwitchStyle}" Click="ChkX2Apic_Click"/>
                    </Grid>

                    <Separator Background="#805500" Opacity="0.5"/>

                    <!-- IncreaseUserVa -->
                    <Grid Margin="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Width="30" Height="30" Cursor="Help" Margin="0,0,10,0" ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                            <Button.ToolTip>
                                <ToolTip Content="Aumenta o espa&#xE7;o de endere&#xE7;amento virtual de usu&#xE1;rio para 3072 MB (padr&#xE3;o 2048). Permite que aplica&#xE7;&#xF5;es usem mais mem&#xF3;ria virtual. Requer reinicializa&#xE7;&#xE3;o."/>
                            </Button.ToolTip>
                            <TextBlock Text="&#x2139;&#xFE0F;" FontSize="16" Foreground="{StaticResource AccentColor}" Opacity="0.6"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
