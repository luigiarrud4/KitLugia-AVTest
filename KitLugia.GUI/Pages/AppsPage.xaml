<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="KitLugia.GUI.Pages.AppsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:KitLugia.GUI.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Background="#1E1E1E"
      TextElement.FontFamily="Segoe UI Variable Display, Segoe UI, Segoe UI Emoji, Segoe UI Symbol, Arial">

    <Page.Resources>
        <!-- Estilo padrão para botões desta página (remove o chrome azul do WPF) -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bdr" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource CardHover}"/>
                                <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource AccentColor}"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bdr" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo TabItem similar ao ServicesPage -->
        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="0,0,0,3" Margin="0,0,10,0">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentColor}" />
                                <Setter Property="Foreground" Value="{DynamicResource AccentColor}" />
                                <Setter Property="FontWeight" Value="Bold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <Grid Margin="30">
        <!-- NORMAL CONTENT -->
        <Grid x:Name="NormalContent">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Gerenciador de Aplicativos" Foreground="White" FontSize="32" FontWeight="SemiBold" Margin="0,0,0,20"/>

            <TabControl x:Name="MainTabs" Grid.Row="1" Background="Transparent" BorderThickness="0">

                <!-- ABA 0: BLOATWARE (UWP) -->
                <TabItem Header="&#x1F4E6; Bloatware (UWP)">
                    <Grid Margin="0,15,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Removedor de Bloatware" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                                <TextBlock x:Name="BloatwareIconProgressText" Text="&#xCD;cones carregados: 0/0" FontSize="12" Foreground="#FFD700" Margin="15,5,0,0" FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Text="Aplicativos nativos do Windows. Gerencie instala&#xE7;&#xF5;es padr&#xE3;o." Foreground="#AAA" Margin="0,3,0,0"/>
                            <TextBox x:Name="TxtSearchBloatware" TextChanged="TxtSearchBloatware_TextChanged" 
                                     Background="#252525" Foreground="White" BorderBrush="#333" BorderThickness="1" Padding="10,8" Margin="0,10,0,0" FontSize="14"/>
                        </StackPanel>

                        <Border x:Name="BloatwareLoadingPanel" Grid.Row="1" Panel.ZIndex="99" Background="#CC000000" Visibility="Visible" CornerRadius="8">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Ellipse Width="40" Height="40" Stroke="#FFD700" StrokeThickness="3" Fill="Transparent" RenderTransformOrigin="0.5,0.5" StrokeDashArray="70 30">
                                    <Ellipse.RenderTransform>
                                        <RotateTransform x:Name="SpinnerRotateBloatware"/>
                                    </Ellipse.RenderTransform>
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:1"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <TextBlock Text="Analisando..." Foreground="White" FontSize="16" Margin="0,15,0,0"/>
                                <TextBlock x:Name="TxtBloatwareProgress" Foreground="#FFD700" FontSize="12" Margin="0,5,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Background="#181818" BorderBrush="#333" BorderThickness="1" CornerRadius="8">
                            <ListView x:Name="BloatwareList" Background="Transparent" BorderThickness="0" Foreground="White" VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Margin" Value="0,1"/>
                                        <Setter Property="Padding" Value="15,10"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListViewItem">
                                                    <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="4" Padding="0">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bdr" Property="Background" Value="#252525"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListView.ItemContainerStyle>

                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="48"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="10,0,0,0">
                                                <CheckBox.LayoutTransform>
                                                    <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                                                </CheckBox.LayoutTransform>
                                            </CheckBox>
                                            <Grid Grid.Column="1" Width="32" Height="32" Margin="8,0" VerticalAlignment="Center">
                                                <Image Source="{Binding Icon}" Width="32" Height="32" Stretch="Uniform"/>
                                                <Ellipse Width="24" Height="24" Stroke="#FFD700" StrokeThickness="2" Fill="Transparent" StrokeDashArray="4 2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Setter Property="Opacity" Value="1"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Icon}" Value="{x:Null}"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                            </Grid>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding PackageName}" FontSize="11" Foreground="#666" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <Button Grid.Column="3" Height="32" FontSize="11" Cursor="Hand" Click="BtnBloatwareAction_Click" Tag="{Binding}" Content="REMOVER">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderBrush" Value="#C42B1C"/>
                                                        <Setter Property="Foreground" Value="#FF6F61"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="bdr" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="4">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="bdr" Property="Background" Value="#C42B1C"/>
                                                                            <Setter Property="Foreground" Value="White"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                            <Button Content="☑ Selecionar Todos" Click="BtnSelectAllBloatware_Click" Height="35" Width="125"
                                    Background="#2C3E50" Foreground="White" BorderBrush="#555" BorderThickness="1" Margin="0,0,10,0" Cursor="Hand"/>
                            <Button Content="☐ Limpar Seleção" Click="BtnDeselectAllBloatware_Click" Height="35" Width="115"
                                    Background="#444" Foreground="White" BorderBrush="#555" BorderThickness="1" Margin="0,0,10,0" Cursor="Hand"/>
                            <Button Content="Remover Selecionados" Click="BtnRemoveBloatwareSelected_Click" Height="35" Width="140" 
                                    Background="#C42B1C" Foreground="White" BorderBrush="#C42B1C" BorderThickness="1" Margin="0,0,10,0" Cursor="Hand"/>
                            <Button Content="&#x1F6E1; Ponto de Restauração" Click="BtnCreateRestorePoint_Click" Height="35" Width="150" 
                                    Background="#2C3E50" Foreground="White" BorderBrush="#FFD700" BorderThickness="1" Cursor="Hand" Margin="0,0,10,0"/>
                            <Button Content="&#x1F3AF; Hunter" Click="BtnHunterMode_Click" Height="35" Width="90" 
                                    Background="#2E7D32" Foreground="White" BorderBrush="#4CAF50" BorderThickness="1" Cursor="Hand" Margin="0,0,10,0"/>
                            <Button Content="Atualizar Lista" Click="BtnRefreshBloatware_Click" Height="35" Width="120" 
                                    Background="#333" Foreground="White" BorderBrush="#FFD700" BorderThickness="1" Cursor="Hand"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- ABA 1: PROGRAMS (REGISTRY) -->
                <TabItem Header="&#x1F4BB; Programas (Registry)">
                    <Grid Margin="0,15,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Gerenciador de Programas" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                                <TextBlock x:Name="ProgramsIconProgressText" Text="&#xCD;cones carregados: 0/0" FontSize="12" Foreground="#FFD700" Margin="15,5,0,0" FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Text="Programas instalados no Windows. Gerencie instala&#xE7;&#xF5;es normais." Foreground="#AAA" Margin="0,3,0,0"/>
                            <TextBlock Text="Baseado em Bulk Crap Uninstaller (BCU) - Licen&#xE7;a Apache 2.0" Foreground="#FF6F61" FontSize="10" Margin="0,2,0,0"/>
                            <TextBox x:Name="TxtSearchPrograms" TextChanged="TxtSearchPrograms_TextChanged" 
                                     Background="#252525" Foreground="White" BorderBrush="#333" BorderThickness="1" Padding="10,8" Margin="0,10,0,0" FontSize="14"/>
                        </StackPanel>

                        <Border x:Name="ProgramsLoadingPanel" Grid.Row="1" Panel.ZIndex="99" Background="#CC000000" Visibility="Visible" CornerRadius="8">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Ellipse Width="40" Height="40" Stroke="#FFD700" StrokeThickness="3" Fill="Transparent" RenderTransformOrigin="0.5,0.5" StrokeDashArray="70 30">
                                    <Ellipse.RenderTransform>
                                        <RotateTransform x:Name="SpinnerRotatePrograms"/>
                                    </Ellipse.RenderTransform>
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:1"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <TextBlock Text="Carregando programas..." Foreground="White" FontSize="16" Margin="0,15,0,0"/>
                                <TextBlock x:Name="TxtProgramsProgress" Foreground="#FFD700" FontSize="12" Margin="0,5,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Background="#252525" BorderBrush="#333" BorderThickness="1" CornerRadius="8" Padding="10">
                            <ListView x:Name="ProgramsList" Background="Transparent" BorderThickness="0"
                                      VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Margin" Value="0,2"/>
                                        <Setter Property="Padding" Value="8"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#333"/></Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#444"/>
                                                <Setter Property="BorderBrush" Value="#FFD700"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="32"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,10,0">
                                                <CheckBox.LayoutTransform>
                                                    <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                                                </CheckBox.LayoutTransform>
                                            </CheckBox>
                                            <Grid Grid.Column="1" Width="32" Height="32" VerticalAlignment="Center">
                                                <Image Width="32" Height="32" Source="{Binding Icon}" Stretch="Uniform"/>
                                                <Ellipse Width="24" Height="24" Stroke="#FFD700" StrokeThickness="2" Fill="Transparent" StrokeDashArray="4 2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Ellipse.Style>
                                                        <Style TargetType="Ellipse">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Icon}" Value="{x:Null}"><Setter Property="Visibility" Value="Visible"/></DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Ellipse.Style>
                                                </Ellipse>
                                            </Grid>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0">
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Publisher}" FontSize="11" Foreground="#666" TextTrimming="CharacterEllipsis" Margin="0,1,0,0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="3" Text="{Binding DisplayVersion}" FontSize="11" Foreground="#555" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <Button Grid.Column="4" Height="28" FontSize="10" Cursor="Hand" Click="BtnProgramRemove_Click" Tag="{Binding}" Content="REMOVER">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderBrush" Value="#C42B1C"/>
                                                        <Setter Property="Foreground" Value="#FF6F61"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="bdr" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="4">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="bdr" Property="Background" Value="#C42B1C"/>
                                                                            <Setter Property="Foreground" Value="White"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                            <Button Content="☑ Selecionar Todos" Click="BtnSelectAllPrograms_Click" Height="35" Width="125"
                                    Background="#2C3E50" Foreground="White" BorderBrush="#555" BorderThickness="1" Margin="0,0,10,0" Cursor="Hand"/>
                            <Button Content="☐ Limpar Seleção" Click="BtnDeselectAllPrograms_Click" Height="35" Width="115"
                                    Background="#444" Foreground="White" BorderBrush="#555" BorderThickness="1" Margin="0,0,10,0" Cursor="Hand"/>
                            <Button Content="Remover Selecionados" Click="BtnRemoveProgramsSelected_Click" Height="35" Width="140" 
                                    Background="#C42B1C" Foreground="White" BorderBrush="#C42B1C" BorderThickness="1" Margin="0,0,10,0" Cursor="Hand"/>
                            <Button Content="&#x1F6E1; Ponto de Restauração" Click="BtnCreateRestorePoint_Click" Height="35" Width="150" 
                                    Background="#2C3E50" Foreground="White" BorderBrush="#FFD700" BorderThickness="1" Cursor="Hand" Margin="0,0,10,0"/>
                            <Button Content="Atualizar Lista" Click="BtnRefreshPrograms_Click" Height="35" Width="120" 
                                    Background="#333" Foreground="White" BorderBrush="#FFD700" BorderThickness="1" Cursor="Hand"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- ABA 2: PORTABLE DETECTED -->
                <TabItem Header="&#x1F4C1; Portáteis / Detectados">
                    <Grid Margin="0,15,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Aplicativos Portáteis Detectados" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                                <TextBlock x:Name="PortableIconProgressText" Text="" FontSize="12" Foreground="#FFD700" Margin="15,5,0,0" FontWeight="SemiBold"/>
                            </StackPanel>
                            <TextBlock Text="Apps em pastas locais sem registro no Windows. Podem ser removidos manualmente." Foreground="#AAA" Margin="0,3,0,0"/>
                            <TextBox x:Name="TxtSearchPortable" TextChanged="TxtSearchPortable_TextChanged" 
                                     Background="#252525" Foreground="White" BorderBrush="#333" BorderThickness="1" Padding="10,8" Margin="0,10,0,0" FontSize="14"/>
                        </StackPanel>

                        <Border x:Name="PortableLoadingPanel" Grid.Row="1" Panel.ZIndex="99" Background="#CC000000" Visibility="Visible" CornerRadius="8">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Ellipse Width="40" Height="40" Stroke="#FFD700" StrokeThickness="3" Fill="Transparent" RenderTransformOrigin="0.5,0.5" StrokeDashArray="70 30">
                                    <Ellipse.RenderTransform>
                                        <RotateTransform x:Name="SpinnerRotatePortable"/>
                                    </Ellipse.RenderTransform>
                                    <Ellipse.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)" From="0" To="360" Duration="0:0:1"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Ellipse.Triggers>
                                </Ellipse>
                                <TextBlock Text="Vasculhando pastas..." Foreground="White" FontSize="16" Margin="0,15,0,0"/>
                                <TextBlock x:Name="TxtPortableProgress" Foreground="#FFD700" FontSize="12" Margin="0,5,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Background="#252525" BorderBrush="#333" BorderThickness="1" CornerRadius="8" Padding="10">
                            <ListView x:Name="PortableList" Background="Transparent" BorderThickness="0"
                                      VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="Margin" Value="0,2"/>
                                        <Setter Property="Padding" Value="8"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#333"/></Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#444"/>
                                                <Setter Property="BorderBrush" Value="#FFD700"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="32"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,10,0">
                                                <CheckBox.LayoutTransform>
                                                    <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                                                </CheckBox.LayoutTransform>
                                            </CheckBox>
                                            <Grid Grid.Column="1" Width="32" Height="32" VerticalAlignment="Center">
                                                <Ellipse Width="24" Height="24" Stroke="#FFD700" StrokeThickness="2" Fill="Transparent" StrokeDashArray="4 2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Grid>
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding FolderPath}" FontSize="10" Foreground="#666" TextTrimming="CharacterEllipsis" Margin="0,1,0,0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="3" Text="{Binding TotalSizeFormatted}" FontSize="11" Foreground="#555" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="4" Text="{Binding ConfidenceLabel}" FontSize="11" Foreground="#555" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <Button Grid.Column="5" Height="28" FontSize="10" Cursor="Hand" Click="BtnPortableRemove_Click" Tag="{Binding}" Content="DELETAR">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Setter Property="BorderBrush" Value="#C42B1C"/>
                                                        <Setter Property="Foreground" Value="#FF6F61"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="bdr" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="4">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter TargetName="bdr" Property="Background" Value="#C42B1C"/>
                                                                            <Setter Property="Foreground" Value="White"/>
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                            <Button Content="Atualizar Lista" Click="BtnRefreshPortable_Click" Height="35" Width="120" 
                                    Background="#333" Foreground="White" BorderBrush="#FFD700" BorderThickness="1" Cursor="Hand"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- ABA 3: RESÍDUOS (leftover junk tracker) -->
                <TabItem Header="&#x2728; Resíduos" Visibility="{Binding MaxCleanupTabVisible, RelativeSource={RelativeSource AncestorType=Page}, FallbackValue=Visible}">
                    <Grid Margin="0,15,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="Resíduos Detectados" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="Arquivos e registro deixados por apps já desinstalados. Selecione os itens que deseja limpar." Foreground="#AAA" Margin="0,3,0,0"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <Border x:Name="JunkSection" Margin="0,0,0,0" Visibility="Collapsed">
                                    <StackPanel>
                                        <Border Background="#252525" CornerRadius="5" Padding="12,8" Margin="0,0,0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock x:Name="TxtMaxCleanupInfo" Text="Carregando..." FontSize="12" Foreground="#888" VerticalAlignment="Center"/>
                                                <Button Grid.Column="1" Content="Selecionar Todos" Height="30" Padding="10,0" Background="#2C3E50" Foreground="White" BorderThickness="0" FontSize="11" Cursor="Hand" Margin="0,0,6,0" Click="BtnMaxSelectAll_Click"/>
                                                <Button Grid.Column="2" x:Name="BtnMaxClean" Content="&#x1F5D1; Limpar Selecionados (0)" Height="30" Padding="14,0" Background="#C0392B" Foreground="White" BorderThickness="0" FontSize="11" FontWeight="SemiBold" Cursor="Hand" IsEnabled="False" Click="BtnMaxClean_Click"/>
                                                <Button Grid.Column="3" Content="Atualizar" Height="30" Padding="10,0" Background="#333" Foreground="White" BorderThickness="0" FontSize="11" Cursor="Hand" Margin="6,0,0,0" Click="BtnMaxRefresh_Click"/>
                                            </Grid>
                                        </Border>
                                        <ItemsControl x:Name="JunkItemsList" Background="Transparent" BorderThickness="0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,8" CornerRadius="6" Background="#1E1E1E" BorderThickness="1" BorderBrush="#4A3000">
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                            <!-- Header -->
                                                            <Border Grid.Row="0" Cursor="Hand" MouseLeftButtonUp="JunkCardHeader_Click" Padding="12,10" Background="#1E1E1E" CornerRadius="6">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="{Binding ExpandIcon}" FontSize="14" Foreground="#FFD700" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding AppName}" FontWeight="SemiBold" FontSize="14" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                                                        <TextBlock Text="{Binding DateString}" FontSize="11" Foreground="#666"/>
                                                                    </StackPanel>
                                                                    <TextBlock Grid.Column="2" Text="{Binding SelectionSummary}" FontSize="11" Foreground="#FFD700" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                                    <Button Grid.Column="3" Content="&#x1F5D1; Limpar" Height="28" FontSize="10" Padding="10,0" Background="#C0392B" Foreground="White" BorderThickness="0" Cursor="Hand" Tag="{Binding}" Click="BtnJunkClean_Click"/>
                                                                    <Button Grid.Column="4" Content="&#x2716;" Width="28" Height="28" FontSize="12" Background="Transparent" Foreground="#666" BorderThickness="0" Cursor="Hand" Tag="{Binding}" Click="BtnJunkDismiss_Click" Margin="6,0,0,0"/>
                                                                </Grid>
                                                            </Border>

                                                            <!-- Expanded: individual items -->
                                                            <Border Grid.Row="1" CornerRadius="0,0,6,6" Padding="12,0,12,10" Background="#151515" BorderBrush="#333" BorderThickness="0">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <StackPanel>
                                                                    <!-- Files header + select all -->
                                                                    <Grid Margin="0,8,0,4">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Text="Arquivos:" FontSize="12" FontWeight="SemiBold" Foreground="#AAA"/>
                                                                        <Button Grid.Column="1" Content="&#x2705; Tudo" Height="22" FontSize="9" Padding="8,0" Background="#333" Foreground="#CCC" BorderThickness="0" Cursor="Hand" Tag="{Binding}" Click="BtnJunkSelectAllFiles_Click"/>
                                                                    </Grid>
                                                                    <ItemsControl ItemsSource="{Binding Files}" Background="Transparent" BorderThickness="0">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Border Padding="4,2" Margin="0,1" CornerRadius="3" BorderThickness="1" BorderBrush="#2A2A2A" Background="#1A1A1A">
                                                                                    <Border.Style>
                                                                                        <Style TargetType="Border">
                                                                                            <Setter Property="Background" Value="#1A1A1A"/>
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding IsHeuristic}" Value="True">
                                                                                                    <Setter Property="Background" Value="#151515"/>
                                                                                                    <Setter Property="BorderBrush" Value="#2A1A1A"/>
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </Border.Style>
                                                                                    <Grid>
                                                                                        <Grid.ColumnDefinitions>
                                                                                            <ColumnDefinition Width="Auto"/>
                                                                                            <ColumnDefinition Width="Auto"/>
                                                                                            <ColumnDefinition Width="*"/>
                                                                                            <ColumnDefinition Width="Auto"/>
                                                                                        </Grid.ColumnDefinitions>
                                                                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,6,0">
                                                                                            <CheckBox.Style>
                                                                                                <Style TargetType="CheckBox">
                                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                                    <Style.Triggers>
                                                                                                        <DataTrigger Binding="{Binding CanDelete}" Value="False">
                                                                                                            <Setter Property="Visibility" Value="Hidden"/>
                                                                                                        </DataTrigger>
                                                                                                    </Style.Triggers>
                                                                                                </Style>
                                                                                            </CheckBox.Style>
                                                                                        </CheckBox>
                                                                                        <TextBlock Grid.Column="1" Text="{Binding SafetyIcon}" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" ToolTip="{Binding SafetyTooltip}"/>
                                                                                        <TextBlock Grid.Column="2" Text="{Binding Path}" FontSize="10" TextTrimming="CharacterEllipsis" VerticalAlignment="Center">
                                                                                            <TextBlock.Style>
                                                                                                <Style TargetType="TextBlock">
                                                                                                    <Setter Property="Foreground" Value="#CCC"/>
                                                                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                                                                    <Style.Triggers>
                                                                                                        <DataTrigger Binding="{Binding IsHeuristic}" Value="True">
                                                                                                            <Setter Property="Foreground" Value="#666"/>
                                                                                                            <Setter Property="FontWeight" Value="Normal"/>
                                                                                                            <Setter Property="FontStyle" Value="Italic"/>
                                                                                                        </DataTrigger>
                                                                                                    </Style.Triggers>
                                                                                                </Style>
                                                                                            </TextBlock.Style>
                                                                                        </TextBlock>
                                                                                        <TextBlock Grid.Column="3" Text=" heurístico" FontSize="9" Foreground="#C0392B" FontStyle="Italic" VerticalAlignment="Center" Margin="4,0,0,0">
                                                                                            <TextBlock.Style>
                                                                                                <Style TargetType="TextBlock">
                                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                                    <Style.Triggers>
                                                                                                        <DataTrigger Binding="{Binding IsHeuristic}" Value="True">
                                                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                                                        </DataTrigger>
                                                                                                    </Style.Triggers>
                                                                                                </Style>
                                                                                            </TextBlock.Style>
                                                                                        </TextBlock>
                                                                                    </Grid>
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>

                                                                    <!-- Registry header + select all -->
                                                                    <Grid Margin="0,10,0,4">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Text="Registro:" FontSize="12" FontWeight="SemiBold" Foreground="#AAA"/>
                                                                        <Button Grid.Column="1" Content="&#x2705; Tudo" Height="22" FontSize="9" Padding="8,0" Background="#333" Foreground="#CCC" BorderThickness="0" Cursor="Hand" Tag="{Binding}" Click="BtnJunkSelectAllReg_Click"/>
                                                                    </Grid>
                                                                    <ItemsControl ItemsSource="{Binding Registry}" Background="Transparent" BorderThickness="0">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Border Padding="4,2" Margin="0,1" CornerRadius="3" BorderThickness="1" BorderBrush="#2A2A2A" Background="#1A1A1A">
                                                                                    <Border.Style>
                                                                                        <Style TargetType="Border">
                                                                                            <Setter Property="Background" Value="#1A1A1A"/>
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding IsHeuristic}" Value="True">
                                                                                                    <Setter Property="Background" Value="#151515"/>
                                                                                                    <Setter Property="BorderBrush" Value="#2A1A1A"/>
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </Border.Style>
                                                                                    <Grid>
                                                                                        <Grid.ColumnDefinitions>
                                                                                            <ColumnDefinition Width="Auto"/>
                                                                                            <ColumnDefinition Width="Auto"/>
                                                                                            <ColumnDefinition Width="*"/>
                                                                                            <ColumnDefinition Width="Auto"/>
                                                                                        </Grid.ColumnDefinitions>
                                                                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,6,0">
                                                                                            <CheckBox.Style>
                                                                                                <Style TargetType="CheckBox">
                                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                                    <Style.Triggers>
                                                                                                        <DataTrigger Binding="{Binding CanDelete}" Value="False">
                                                                                                            <Setter Property="Visibility" Value="Hidden"/>
                                                                                                        </DataTrigger>
                                                                                                    </Style.Triggers>
                                                                                                </Style>
                                                                                            </CheckBox.Style>
                                                                                        </CheckBox>
                                                                                        <TextBlock Grid.Column="1" Text="{Binding SafetyIcon}" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0" ToolTip="{Binding SafetyTooltip}"/>
                                                                                        <TextBlock Grid.Column="2" Text="{Binding Path}" FontSize="10" TextTrimming="CharacterEllipsis" VerticalAlignment="Center">
                                                                                            <TextBlock.Style>
                                                                                                <Style TargetType="TextBlock">
                                                                                                    <Setter Property="Foreground" Value="#CCC"/>
                                                                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                                                                    <Style.Triggers>
                                                                                                        <DataTrigger Binding="{Binding IsHeuristic}" Value="True">
                                                                                                            <Setter Property="Foreground" Value="#666"/>
                                                                                                            <Setter Property="FontWeight" Value="Normal"/>
                                                                                                            <Setter Property="FontStyle" Value="Italic"/>
                                                                                                        </DataTrigger>
                                                                                                    </Style.Triggers>
                                                                                                </Style>
                                                                                            </TextBlock.Style>
                                                                                        </TextBlock>
                                                                                        <TextBlock Grid.Column="3" Text=" heurístico" FontSize="9" Foreground="#C0392B" FontStyle="Italic" VerticalAlignment="Center" Margin="4,0,0,0">
                                                                                            <TextBlock.Style>
                                                                                                <Style TargetType="TextBlock">
                                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                                    <Style.Triggers>
                                                                                                        <DataTrigger Binding="{Binding IsHeuristic}" Value="True">
                                                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                                                        </DataTrigger>
                                                                                                    </Style.Triggers>
                                                                                                </Style>
                                                                                            </TextBlock.Style>
                                                                                        </TextBlock>
                                                                                    </Grid>
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                                <Border x:Name="JunkEmptySection" Margin="0,20" Visibility="Visible">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="&#x2705; Nenhum resíduo pendente" FontSize="18" Foreground="#555" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Resíduos de apps desinstalados aparecerão aqui." FontSize="13" Foreground="#444" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <Border Grid.Row="2" Background="#252525" CornerRadius="5" Padding="12,8" Margin="0,10,0,0">
                            <TextBlock x:Name="TxtMaxCleanupStatus" Text="Pronto" FontSize="12" Foreground="#888"/>
                        </Border>
                    </Grid>
                </TabItem>
                <TabItem Header="&#x1F9F0; Extensões" Visibility="Collapsed">
                    <Grid Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#252525" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                            <WrapPanel Orientation="Horizontal">
                                <TextBlock Text="Navegadores detectados:" FontSize="12" Foreground="#888" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ItemsControl x:Name="BrowserList" ItemsSource="{Binding}" FontSize="13" VerticalAlignment="Center">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#3A3A3A" CornerRadius="4" Padding="8,4" Margin="3">
                                                <TextBlock Text="{Binding Name}" Foreground="White"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button x:Name="BtnRefreshBrowsers" Content="🔄" Width="28" Height="28"
                                        Background="#3E3E3E" Foreground="White" BorderThickness="0"
                                        Margin="8,0,0,0" Cursor="Hand" Click="BtnRefreshBrowsers_Click"
                                        ToolTip="Re-detectar navegadores"/>
                            </WrapPanel>
                        </Border>
                        <Border Grid.Row="1" Background="#252525" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                            <WrapPanel Orientation="Horizontal">
                                <TextBlock Text="Navegador origem:" FontSize="12" Foreground="#888" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox x:Name="CboSourceBrowser" Width="140" Height="28" Background="#333" Foreground="White"
                                          BorderBrush="#555" Margin="0,0,16,0"/>
                                <TextBlock Text="Navegador destino:" FontSize="12" Foreground="#888" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <ComboBox x:Name="CboTargetBrowser" Width="140" Height="28" Background="#333" Foreground="White"
                                          BorderBrush="#555" Margin="0,0,16,0"/>
                                <Button x:Name="BtnScanExtensions" Content="🔍 Scan Extensões" Height="28"
                                        Background="#2C3E50" Foreground="White" BorderThickness="0"
                                        Padding="10,0" Margin="0,0,8,0" Cursor="Hand" Click="BtnScanExtensions_Click"/>
                                <Button x:Name="BtnExportExtensions" Content="💾 Exportar" Height="28"
                                        Background="#27AE60" Foreground="White" BorderThickness="0"
                                        Padding="10,0" Margin="0,0,8,0" Cursor="Hand" Click="BtnExportExtensions_Click"
                                        IsEnabled="False"/>
                                <Button x:Name="BtnImportExtensions" Content="📂 Importar" Height="28"
                                        Background="#2980B9" Foreground="White" BorderThickness="0"
                                        Padding="10,0" Margin="0,0,8,0" Cursor="Hand" Click="BtnImportExtensions_Click"
                                        IsEnabled="False"/>
                                <Button x:Name="BtnTransferExtensions" Content="🔄 Transferir →" Height="28"
                                        Background="#8E44AD" Foreground="White" BorderThickness="0"
                                        Padding="10,0" Cursor="Hand" Click="BtnTransferExtensions_Click"
                                        IsEnabled="False"/>
                            </WrapPanel>
                        </Border>
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#1A1A1A" CornerRadius="6">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl x:Name="ExtensionsList" Margin="4">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#252525" CornerRadius="6" Padding="10,8" Margin="2,3" BorderBrush="#333" BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Width="36" Height="36" Background="#3A3A3A" CornerRadius="4" Margin="0,0,10,0" ClipToBounds="True">
                                                        <Grid>
                                                            <Image Source="{Binding IconPath}" Width="36" Height="36" Stretch="Uniform">
                                                                <Image.Style>
                                                                    <Style TargetType="Image">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IconPath}" Value="{x:Null}">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding IconPath}" Value="">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Image.Style>
                                                            </Image>
                                                            <TextBlock Text="🧩" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IconPath}" Value="{x:Null}">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding IconPath}" Value="">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </Grid>
                                                    </Border>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="#CCC"/>
                                                        <TextBlock Text="{Binding Description}" FontSize="10" Foreground="#888" TextTrimming="CharacterEllipsis" MaxHeight="28"/>
                                                        <WrapPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                            <TextBlock Text="{Binding SourceBrowser}" FontSize="10" Foreground="#666" Margin="0,0,10,0"/>
                                                            <TextBlock Text="{Binding Engine}" FontSize="10" Foreground="#666" Margin="0,0,10,0"/>
                                                            <TextBlock Text="{Binding Version}" FontSize="10" Foreground="#555"/>
                                                            <TextBlock Text="{Binding SizeFormatted}" FontSize="10" Foreground="#555" Margin="10,0,0,0"/>
                                                        </WrapPanel>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="2" Text="{Binding Id}" FontSize="9" Foreground="#555" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="100" TextAlignment="Right"/>
                                                    <Button Grid.Column="3" Content="🗑" Width="28" Height="28"
                                                            Background="#4A1C1C" Foreground="#E74C3C" BorderThickness="0"
                                                            Margin="6,0,0,0" Cursor="Hand"
                                                            Click="BtnRemoveExtension_Click"
                                                            ToolTip="Remover extensão"
                                                            CommandParameter="{Binding}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                </ScrollViewer>
                            </Border>
                            <Border Grid.Column="1" Background="#1E1E1E" CornerRadius="6" Padding="10" Margin="8,0,0,0" Width="160">
                                <StackPanel>
                                    <TextBlock Text="Resumo" FontSize="12" FontWeight="SemiBold" Foreground="#888" Margin="0,0,0,8"/>
                                    <TextBlock x:Name="TxtExtCount" Text="0 extensões" FontSize="12" Foreground="#AAA"/>
                                    <TextBlock x:Name="TxtExtTotalSize" Text="0 B" FontSize="11" Foreground="#777" Margin="0,4,0,0"/>
                                    <Rectangle Height="1" Fill="#333" Margin="0,8"/>
                                    <TextBlock x:Name="TxtExtBrowserStatus" Text="Navegador fechado ✓" FontSize="11" Foreground="#7F8C8D" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>

            </TabControl>
        </Grid>

        <!-- Overlay de confirmação não-bloqueante -->
        <Border x:Name="ConfirmOverlay" Grid.RowSpan="2" Panel.ZIndex="100" 
                Background="#CC000000" Visibility="Collapsed" CornerRadius="8">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" 
                    Background="#2A2A2A" BorderBrush="#FFD700" BorderThickness="1" CornerRadius="8" 
                    Width="450" Padding="20">
                <StackPanel>
                    <TextBlock x:Name="ConfirmTitle" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="ConfirmMessage" FontSize="13" Foreground="#CCC" Margin="0,10,0,0" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button x:Name="BtnConfirmNo" Content="Cancelar" Click="BtnConfirmNo_Click"
                                Width="100" Height="32" Margin="0,0,10,0"
                                Background="#444" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        <Button x:Name="BtnConfirmYes" Content="Sim" Click="BtnConfirmYes_Click"
                                Width="100" Height="32"
                                Background="#C42B1C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- REVIEW PANEL (Revo-style Tree) -->
        <Grid x:Name="ReviewPanel" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock x:Name="ReviewTitle" Text="Deep Cleanup" FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentColor}"/>
                <TextBlock x:Name="ReviewSubtitle" Text="Revise os resíduos encontrados após a desinstalação" FontSize="13" Foreground="#AAA" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Info bar -->
            <Border Grid.Row="1" Background="#252525" CornerRadius="5" Padding="14,10" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ReviewInfoText" FontSize="12" Foreground="#BBB" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ReviewInfoCount" Grid.Column="1" FontSize="12" Foreground="{StaticResource AccentColor}" FontWeight="Bold" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Tabs -->
            <TabControl x:Name="ReviewTabs" Grid.Row="2" Background="Transparent" BorderThickness="0">
                <TabControl.Resources>
                    <Style TargetType="TabPanel"><Setter Property="Margin" Value="0,0,0,8"/></Style>
                </TabControl.Resources>

                <TabItem Header="&#x1F4C1; Arquivos e Pastas">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="#252525" CornerRadius="4" Padding="10,6" Margin="0,0,0,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="ReviewFileCount" FontSize="12" Foreground="#888" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                <Button Grid.Column="1" Content="&#x2705; Só Deletáveis" Background="#2C3E50"
                                        Height="30" Padding="10,0" Foreground="White" BorderThickness="0" FontSize="11" FontWeight="SemiBold"
                                        Cursor="Hand" Margin="0,0,6,0" Click="BtnReviewSelectDeletableFiles_Click"/>
                                <Button x:Name="BtnReviewDeleteFiles" Grid.Column="2"
                                        Content="&#x1F5D1; Remover (0)" Background="#C0392B"
                                        Height="30" Padding="14,0" Foreground="White" BorderThickness="0" FontSize="12" FontWeight="SemiBold"
                                        Cursor="Hand" IsEnabled="False" Click="BtnReviewDeleteFiles_Click"/>
                            </Grid>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ReviewFileList">
                                <ItemsControl.Resources>
                                    <local:DepthToMarginConverter x:Key="DepthConverter"/>
                                </ItemsControl.Resources>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,4" Margin="0,1" CornerRadius="3" BorderThickness="1"
                                                BorderBrush="#3A3A3A">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#2A2A2A"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsNavigational}" Value="True">
                                                            <Setter Property="Background" Value="#1A1A1A"/>
                                                            <Setter Property="BorderBrush" Value="#2A2A2A"/>
                                                            <Setter Property="Opacity" Value="0.65"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid Margin="{Binding Depth, Converter={StaticResource DepthConverter}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          VerticalAlignment="Center" Margin="0,0,4,0">
                                                    <CheckBox.Style>
                                                        <Style TargetType="CheckBox">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                                    <Setter Property="Visibility" Value="Hidden"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsNavigational}" Value="True">
                                                                    <Setter Property="Visibility" Value="Hidden"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </CheckBox.Style>
                                                </CheckBox>
                                                <TextBlock Grid.Column="1" Text="{Binding SafetyIcon}"
                                                           FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"
                                                           ToolTip="{Binding SafetyTooltip}"/>
                                                <TextBlock Grid.Column="2" Text="{Binding IconChar}"
                                                           FontSize="14" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <TextBlock Grid.Column="3" Text="{Binding KeepIcon}"
                                                           FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"
                                                           ToolTip="{Binding KeepTooltip}" Cursor="Hand"
                                                           MouseLeftButtonUp="ToggleKeep_Click">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsNavigational}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayPath}" FontSize="13">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="White"/>
                                                                <Setter Property="FontWeight" Value="Normal"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsBold}" Value="True">
                                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsNavigational}" Value="True">
                                                                        <Setter Property="Foreground" Value="#666"/>
                                                                        <Setter Property="FontSize" Value="11"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding FullPath}" FontSize="10"
                                                               Foreground="#888"
                                                               ToolTip="{Binding FullPath}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

                <TabItem Header="&#x1F4D1; Registro">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="#252525" CornerRadius="4" Padding="10,6" Margin="0,0,0,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="ReviewRegCount" FontSize="12" Foreground="#888" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                <Button Grid.Column="1" Content="&#x2705; Só Deletáveis" Background="#2C3E50"
                                        Height="30" Padding="10,0" Foreground="White" BorderThickness="0" FontSize="11" FontWeight="SemiBold"
                                        Cursor="Hand" Margin="0,0,6,0" Click="BtnReviewSelectDeletableReg_Click"/>
                                <Button x:Name="BtnReviewDeleteReg" Grid.Column="2"
                                        Content="&#x1F5D1; Remover (0)" Background="#C0392B"
                                        Height="30" Padding="14,0" Foreground="White" BorderThickness="0" FontSize="12" FontWeight="SemiBold"
                                        Cursor="Hand" IsEnabled="False" Click="BtnReviewDeleteReg_Click"/>
                            </Grid>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ReviewRegList">
                                <ItemsControl.Resources>
                                    <local:DepthToMarginConverter x:Key="DepthConverter"/>
                                </ItemsControl.Resources>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,4" Margin="0,1" CornerRadius="3" BorderThickness="1"
                                                BorderBrush="#3A3A3A">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#2A2A2A"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsNavigational}" Value="True">
                                                            <Setter Property="Background" Value="#1A1A1A"/>
                                                            <Setter Property="BorderBrush" Value="#2A2A2A"/>
                                                            <Setter Property="Opacity" Value="0.65"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid Margin="{Binding Depth, Converter={StaticResource DepthConverter}}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          VerticalAlignment="Center" Margin="0,0,4,0">
                                                    <CheckBox.Style>
                                                        <Style TargetType="CheckBox">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                                    <Setter Property="Visibility" Value="Hidden"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsNavigational}" Value="True">
                                                                    <Setter Property="Visibility" Value="Hidden"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </CheckBox.Style>
                                                </CheckBox>
                                                <TextBlock Grid.Column="1" Text="{Binding SafetyIcon}"
                                                           FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"
                                                           ToolTip="{Binding SafetyTooltip}"/>
                                                <TextBlock Grid.Column="2" Text="{Binding IconChar}"
                                                           FontSize="14" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <TextBlock Grid.Column="3" Text="{Binding KeepIcon}"
                                                           FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"
                                                           ToolTip="{Binding KeepTooltip}" Cursor="Hand"
                                                           MouseLeftButtonUp="ToggleKeep_Click">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsNavigational}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayPath}" FontSize="13">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="White"/>
                                                                <Setter Property="FontWeight" Value="Normal"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsBold}" Value="True">
                                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsNavigational}" Value="True">
                                                                        <Setter Property="Foreground" Value="#666"/>
                                                                        <Setter Property="FontSize" Value="11"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding FullPath}" FontSize="10"
                                                               Foreground="#888"
                                                               ToolTip="{Binding FullPath}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

            </TabControl>

            <!-- Bottom bar -->
            <Border Grid.Row="3" Background="#252525" CornerRadius="5" Padding="14,10" Margin="0,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="ReviewStatusText" Text="Nenhum item selecionado" FontSize="12" Foreground="#888" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="BtnReviewRestore" Content="↩ Restaurar Backup" Height="32"
                                Background="#7F8C8D" Foreground="White" BorderThickness="0"
                                Padding="12,0" Margin="0,0,8,0" Cursor="Hand"
                                IsEnabled="False" Click="BtnReviewRestore_Click"/>
                        <Button x:Name="BtnReviewCopy" Content="📋 Copiar Tudo" Height="32"
                                Background="#2C3E50" Foreground="White" BorderThickness="0"
                                Padding="12,0" Margin="0,0,8,0" Cursor="Hand"
                                Click="BtnReviewCopy_Click"/>
                        <Button Content="Voltar" Width="90" Height="32"
                                Background="#3E3E3E" Foreground="White" BorderThickness="0"
                                Margin="0,0,8,0" Cursor="Hand" Click="BtnReviewBack_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
