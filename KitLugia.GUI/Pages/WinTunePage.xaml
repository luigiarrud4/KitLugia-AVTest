<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="KitLugia.GUI.Pages.WinTunePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:KitLugia.GUI.Controls"
      Title="WinTune"
      TextElement.FontFamily="Segoe UI Variable Display, Segoe UI, Segoe UI Emoji, Segoe UI Symbol, Arial">

    <Page.Resources>
        <!-- Estilo do ToolTip (Bal&#xE3;o de Informa&#xE7;&#xE3;o) -->
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#FFF"/>
            <Setter Property="BorderBrush" Value="#FFD700"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MaxWidth" Value="400"/>
        </Style>

        <!-- Estilo do Bot&#xE3;o de Informa&#xE7;&#xE3;o (c&#xED;rculo com i) -->
        <Style x:Key="InfoButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Help"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="Transparent" CornerRadius="12" Width="24" Height="24"
                                BorderBrush="#FFD700" BorderThickness="1.5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="#20FFD700"/>
                                <Setter TargetName="bdr" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo do TabItem (Bot&#xF5;es do topo) -->
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" 
                                Background="Transparent" 
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                            <ContentPresenter x:Name="ContentSite" 
                                            ContentSource="Header" 
                                            HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                                <Setter TargetName="Border" Property="Background" Value="#1A1A1A"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                                <Setter TargetName="Border" Property="BorderThickness" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="40,30,40,50" MaxWidth="900" HorizontalAlignment="Left">

            <TextBlock Text="WinTune Optimizations" FontSize="32" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="White"/>
            <TextBlock Text="Ative ou desative cada otimiza&#xE7;&#xE3;o individualmente. Altera&#xE7;&#xF5;es exigem reinicializa&#xE7;&#xE3;o." Foreground="#A0A0A0" Margin="0,0,0,25"/>

            <TabControl x:Name="WinTuneTabControl" Background="Transparent" BorderThickness="0">
                <!-- ABA: SYSTEM -->
                <TabItem Header="Sistema">
                    <StackPanel Margin="0,10,0,0">
                        <!-- Item: GameBar -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Desativar GameBar" FontSize="14" Foreground="White"/>
                            </StackPanel>

                            <Button Grid.Column="1" Style="{StaticResource InfoButtonStyle}" Margin="10,0"
                                   ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                                <Button.ToolTip>
                                    <ToolTip>
                                        <StackPanel>
                                            <TextBlock Text="Desativa a GameBar do Windows" FontWeight="Bold" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x2713; Pr&#xF3;s: Libera recursos do sistema, melhora performance em jogos" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x2717; Contras: Perde recursos de grava&#xE7;&#xE3;o e streaming nativos" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x26A0;&#xFE0F; Riscos: Baixo - pode ser reativado se necess&#xE1;rio" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x1F4A1; Recomenda&#xE7;&#xE3;o: Recomendado para gamers" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </ToolTip>
                                </Button.ToolTip>
                                <TextBlock Text="i" FontSize="15" FontWeight="Bold" Foreground="#FFD700" Opacity="0.8"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>

                            <CheckBox x:Name="ChkDisableGameBar" Grid.Column="2" Style="{StaticResource ToggleSwitchStyle}" Content="" Click="ChkDisableGameBar_Click"/>
                        </Grid>

                        <!-- Item: Auto End Tasks -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Encerrar tarefas automaticamente" FontSize="14" Foreground="White"/>
                            </StackPanel>

                            <Button Grid.Column="1" Style="{StaticResource InfoButtonStyle}" Margin="10,0"
                                   ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                                <Button.ToolTip>
                                    <ToolTip>
                                        <StackPanel>
                                            <TextBlock Text="Encerra automaticamente tarefas em segundo plano" FontWeight="Bold" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x2713; Pr&#xF3;s: Desligamento mais r&#xE1;pido, evita travamentos" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x2717; Contras: Apps podem n&#xE3;o salvar dados corretamente" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x26A0;&#xFE0F; Riscos: M&#xE9;dio - pode causar perda de dados n&#xE3;o salvos" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x1F4A1; Recomenda&#xE7;&#xE3;o: Use com cautela" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </ToolTip>
                                </Button.ToolTip>
                                <TextBlock Text="i" FontSize="15" FontWeight="Bold" Foreground="#FFD700" Opacity="0.8"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>

                            <CheckBox x:Name="ChkAutoEndTasks" Grid.Column="2" Style="{StaticResource ToggleSwitchStyle}" Content="" Click="ChkAutoEndTasks_Click"/>
                        </Grid>
                            <!-- Item: ChkDisableAeDebug -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Desativar AeDebug" FontSize="14" Foreground="White"/>
                            </StackPanel>

                            <Button Grid.Column="1" Style="{StaticResource InfoButtonStyle}" Margin="10,0"
                                   ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                                <Button.ToolTip>
                                    <ToolTip>
                                        <StackPanel>
                                            <TextBlock Text="Desativa o depurador autom&#xE1;tico do Windows" FontWeight="Bold" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x2713; Pr&#xF3;s: Evita interrup&#xE7;&#xF5;es, melhora estabilidade" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x2717; Contras: Dificulta diagn&#xF3;stico de problemas" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x26A0;&#xFE0F; Riscos: M&#xE9;dio - problemas de sistema podem ser mais dif&#xED;ceis de resolver" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x1F4A1; Recomenda&#xE7;&#xE3;o: Recomendado para usu&#xE1;rios avan&#xE7;ados" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </ToolTip>
                                </Button.ToolTip>
                                <TextBlock Text="i" FontSize="15" FontWeight="Bold" Foreground="#FFD700" Opacity="0.8"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>

                            <CheckBox x:Name="ChkDisableAeDebug" Grid.Column="2" Style="{StaticResource ToggleSwitchStyle}" Content="" Click="ChkDisableAeDebug_Click"/>
                        </Grid>
                            <!-- Item: ChkDisableAnimationEffectMaxMin -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Desativar anima&#xE7;&#xF5;es maximizar/minimizar" FontSize="14" Foreground="White"/>
                            </StackPanel>

                            <Button Grid.Column="1" Style="{StaticResource InfoButtonStyle}" Margin="10,0"
                                   ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                                <Button.ToolTip>
                                    <ToolTip>
                                        <StackPanel>
                                            <TextBlock Text="Remove anima&#xE7;&#xF5;es de janelas" FontWeight="Bold" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x2713; Pr&#xF3;s: Resposta mais r&#xE1;pida, sistema mais fluido" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x2717; Contras: Perde efeitos visuais do Windows" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x26A0;&#xFE0F; Riscos: Baixo - apenas est&#xE9;tico" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x1F4A1; Recomenda&#xE7;&#xE3;o: Recomendado para performance" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </ToolTip>
                                </Button.ToolTip>
                                <TextBlock Text="i" FontSize="15" FontWeight="Bold" Foreground="#FFD700" Opacity="0.8"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>

                            <CheckBox x:Name="ChkDisableAnimationEffectMaxMin" Grid.Column="2" Style="{StaticResource ToggleSwitchStyle}" Content="" Click="ChkDisableAnimationEffectMaxMin_Click"/>
                        </Grid>
                            <!-- Item: ChkDisableAutoDefragIdle -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Desativar desfragmenta&#xE7;&#xE3;o autom&#xE1;tica" FontSize="14" Foreground="White"/>
                            </StackPanel>

                            <Button Grid.Column="1" Style="{StaticResource InfoButtonStyle}" Margin="10,0"
                                   ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                                <Button.ToolTip>
                                    <ToolTip>
                                        <StackPanel>
                                            <TextBlock Text="Desativa desfragmenta&#xE7;&#xE3;o autom&#xE1;tica em SSDs" FontWeight="Bold" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x2713; Pr&#xF3;s: Prolonga vida &#xFA;til do SSD, reduz grava&#xE7;&#xF5;es" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x2717; Contras: Nenhum - SSDs n&#xE3;o precisam de desfragmenta&#xE7;&#xE3;o" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x26A0;&#xFE0F; Riscos: Baixo - SSDs usam TRIM em vez de defrag" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x1F4A1; Recomenda&#xE7;&#xE3;o: Altamente recomendado para SSDs" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </ToolTip>
                                </Button.ToolTip>
                                <TextBlock Text="i" FontSize="15" FontWeight="Bold" Foreground="#FFD700" Opacity="0.8"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>

                            <CheckBox x:Name="ChkDisableAutoDefragIdle" Grid.Column="2" Style="{StaticResource ToggleSwitchStyle}" Content="" Click="ChkDisableAutoDefragIdle_Click"/>
                        </Grid>
                            <!-- Item: ChkDisableBackgroundApps -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Desativar apps em segundo plano" FontSize="14" Foreground="White"/>
                            </StackPanel>

                            <Button Grid.Column="1" Style="{StaticResource InfoButtonStyle}" Margin="10,0"
                                   ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                                <Button.ToolTip>
                                    <ToolTip>
                                        <StackPanel>
                                            <TextBlock Text="Desativa apps em segundo plano" FontWeight="Bold" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x2713; Pr&#xF3;s: Economiza recursos, melhora bateria e performance" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x2717; Contras: Apps podem n&#xE3;o funcionar corretamente em background" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x26A0;&#xFE0F; Riscos: M&#xE9;dio - notifica&#xE7;&#xF5;es podem n&#xE3;o chegar" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x1F4A1; Recomenda&#xE7;&#xE3;o: Recomendado para laptops" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </ToolTip>
                                </Button.ToolTip>
                                <TextBlock Text="i" FontSize="15" FontWeight="Bold" Foreground="#FFD700" Opacity="0.8"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>

                            <CheckBox x:Name="ChkDisableBackgroundApps" Grid.Column="2" Style="{StaticResource ToggleSwitchStyle}" Content="" Click="ChkDisableBackgroundApps_Click"/>
                        </Grid>
                            <!-- Item: ChkDisableBootOptimize -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Desativar otimiza&#xE7;&#xE3;o de boot" FontSize="14" Foreground="White"/>
                            </StackPanel>

                            <Button Grid.Column="1" Style="{StaticResource InfoButtonStyle}" Margin="10,0"
                                   ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                                <Button.ToolTip>
                                    <ToolTip>
                                        <StackPanel>
                                            <TextBlock Text="Desativa otimiza&#xE7;&#xE3;o autom&#xE1;tica de boot" FontWeight="Bold" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x2713; Pr&#xF3;s: Reduz tempo de inicializa&#xE7;&#xE3;o" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x2717; Contras: Boot pode ser mais lento ao longo do tempo" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x26A0;&#xFE0F; Riscos: Baixo - pode ser reativado manualmente" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x1F4A1; Recomenda&#xE7;&#xE3;o: Opcional - SSDs n&#xE3;o precisam muito" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </ToolTip>
                                </Button.ToolTip>
                                <TextBlock Text="i" FontSize="15" FontWeight="Bold" Foreground="#FFD700" Opacity="0.8"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>

                            <CheckBox x:Name="ChkDisableBootOptimize" Grid.Column="2" Style="{StaticResource ToggleSwitchStyle}" Content="" Click="ChkDisableBootOptimize_Click"/>
                        </Grid>
                            <!-- Item: ChkDisableCustomInking -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Desativar coleta de tinta personalizada" FontSize="14" Foreground="White"/>
                            </StackPanel>

                            <Button Grid.Column="1" Style="{StaticResource InfoButtonStyle}" Margin="10,0"
                                   ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                                <Button.ToolTip>
                                    <ToolTip>
                                        <StackPanel>
                                            <TextBlock Text="Desativa coleta de dados de tinta" FontWeight="Bold" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x2713; Pr&#xF3;s: Melhora privacidade, menos telemetria" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x2717; Contras: Recursos de tinta podem ser menos precisos" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x26A0;&#xFE0F; Riscos: Baixo - apenas para usu&#xE1;rios de caneta" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x1F4A1; Recomenda&#xE7;&#xE3;o: Recomendado para privacidade" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </ToolTip>
                                </Button.ToolTip>
                                <TextBlock Text="i" FontSize="15" FontWeight="Bold" Foreground="#FFD700" Opacity="0.8"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>

                            <CheckBox x:Name="ChkDisableCustomInking" Grid.Column="2" Style="{StaticResource ToggleSwitchStyle}" Content="" Click="ChkDisableCustomInking_Click"/>
                        </Grid>
                            <!-- Item: ChkDisableCrashAutoReboot -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Desativar rein&#xED;cio autom&#xE1;tico ap&#xF3;s crash" FontSize="14" Foreground="White"/>
                            </StackPanel>

                            <Button Grid.Column="1" Style="{StaticResource InfoButtonStyle}" Margin="10,0"
                                   ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                                <Button.ToolTip>
                                    <ToolTip>
                                        <StackPanel>
                                            <TextBlock Text="Impede rein&#xED;cio autom&#xE1;tico ap&#xF3;s falhas" FontWeight="Bold" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x2713; Pr&#xF3;s: Evita rein&#xED;cios inesperados" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x2717; Contras: Sistema pode n&#xE3;o se recuperar de falhas graves" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x26A0;&#xFE0F; Riscos: Alto - pode deixar sistema inst&#xE1;vel" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x1F4A1; Recomenda&#xE7;&#xE3;o: N&#xE3;o recomendado" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </ToolTip>
                                </Button.ToolTip>
                                <TextBlock Text="i" FontSize="15" FontWeight="Bold" Foreground="#FFD700" Opacity="0.8"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>

                            <CheckBox x:Name="ChkDisableCrashAutoReboot" Grid.Column="2" Style="{StaticResource ToggleSwitchStyle}" Content="" Click="ChkDisableCrashAutoReboot_Click"/>
                        </Grid>
                            <!-- Item: ChkDisableErrorReporting -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Desativar relat&#xF3;rio de erros" FontSize="14" Foreground="White"/>
                            </StackPanel>

                            <Button Grid.Column="1" Style="{StaticResource InfoButtonStyle}" Margin="10,0"
                                   ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                                <Button.ToolTip>
                                    <ToolTip>
                                        <StackPanel>
                                            <TextBlock Text="Desativa envio de relat&#xF3;rios de erros" FontWeight="Bold" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x2713; Pr&#xF3;s: Melhora privacidade, reduz uso de rede" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x2717; Contras: Microsoft n&#xE3;o recebe dados para corrigir bugs" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x26A0;&#xFE0F; Riscos: Baixo - apenas afeta relat&#xF3;rios de erro" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x1F4A1; Recomenda&#xE7;&#xE3;o: Recomendado para privacidade" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </ToolTip>
                                </Button.ToolTip>
                                <TextBlock Text="i" FontSize="15" FontWeight="Bold" Foreground="#FFD700" Opacity="0.8"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>

                            <CheckBox x:Name="ChkDisableErrorReporting" Grid.Column="2" Style="{StaticResource ToggleSwitchStyle}" Content="" Click="ChkDisableErrorReporting_Click"/>
                        </Grid>
                            <!-- Item: ChkDisableGoogleUpdateTask -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Desativar Google Update" FontSize="14" Foreground="White"/>
                            </StackPanel>

                            <Button Grid.Column="1" Style="{StaticResource InfoButtonStyle}" Margin="10,0"
                                   ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                                <Button.ToolTip>
                                    <ToolTip>
                                        <StackPanel>
                                            <TextBlock Text="Desativa Google Update" FontWeight="Bold" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x2713; Pr&#xF3;s: Reduz tarefas em background, economiza recursos" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x2717; Contras: Chrome e apps Google n&#xE3;o atualizam automaticamente" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x26A0;&#xFE0F; Riscos: M&#xE9;dio - pode deixar apps desatualizados" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x1F4A1; Recomenda&#xE7;&#xE3;o: Opcional - atualize manualmente" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </ToolTip>
                                </Button.ToolTip>
                                <TextBlock Text="i" FontSize="15" FontWeight="Bold" Foreground="#FFD700" Opacity="0.8"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>

                            <CheckBox x:Name="ChkDisableGoogleUpdateTask" Grid.Column="2" Style="{StaticResource ToggleSwitchStyle}" Content="" Click="ChkDisableGoogleUpdateTask_Click"/>
                        </Grid>
                            <!-- Item: ChkDisableLockScreen -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="Desativar tela de bloqueio" FontSize="14" Foreground="White"/>
                            </StackPanel>

                            <Button Grid.Column="1" Style="{StaticResource InfoButtonStyle}" Margin="10,0"
                                   ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                                <Button.ToolTip>
                                    <ToolTip>
                                        <StackPanel>
                                            <TextBlock Text="Remove a tela de bloqueio" FontWeight="Bold" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x2713; Pr&#xF3;s: Acesso mais r&#xE1;pido ao sistema" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x2717; Contras: Perde recursos de tela de bloqueio" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x26A0;&#xFE0F; Riscos: Baixo - apenas est&#xE9;tico e funcional" TextWrapping="Wrap"/>
                                            <TextBlock Text="&#x1F4A1; Recomenda&#xE7;&#xE3;o: Recomendado para desktops" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </ToolTip>
                                </Button.ToolTip>
                                <TextBlock Text="i" FontSize="15" FontWeight="Bold" Foreground="#FFD700" Opacity="0.8"
