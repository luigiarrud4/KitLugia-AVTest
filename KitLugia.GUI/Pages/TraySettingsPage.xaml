<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="KitLugia.GUI.Pages.TraySettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:KitLugia.GUI.Controls"
      Title="Monitor de RAM"
      TextElement.FontFamily="Segoe UI Variable Display, Segoe UI, Segoe UI Emoji, Segoe UI Symbol, Arial">
    
    <Page.Resources>
        <Style x:Key="TrayToggle" TargetType="CheckBox">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="toggleBorder" 
                                Background="#3E3E3E" 
                                CornerRadius="12"
                                BorderThickness="1"
                                BorderBrush="#505050">
                            <Ellipse x:Name="toggleCircle" 
                                     Width="14" Height="14"
                                     Fill="#BBBBBB"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Margin="4,0">
                                <Ellipse.Effect>
                                    <DropShadowEffect ShadowDepth="1" BlurRadius="2" Opacity="0.3"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="toggleBorder" Property="Background" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="toggleBorder" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="toggleCircle" Property="Fill" Value="#101010"/>
                                <Setter TargetName="toggleCircle" Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            
            <!-- Header -->
            <TextBlock Text="&#x1F4E1; MONITOR DE RAM" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       Margin="0,0,0,15"
                       Foreground="{StaticResource AccentColor}"/>
            
            <!-- Se&#xE7;&#xE3;o: Estat&#xED;sticas -->
            <Border Style="{StaticResource SubtleCardStyle}" Padding="15" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="ESTAT&#xCD;STICAS" 
                               FontSize="12" 
                               FontWeight="Bold" 
                               Foreground="#666"
                               Margin="0,0,0,10"/>
                    
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <Border Width="80" Height="80" 
                                Background="#252525" 
                                CornerRadius="40" 
                                BorderBrush="{StaticResource AccentColor}" 
                                BorderThickness="3"
                                Grid.Column="0">
                            <TextBlock x:Name="TxtPercentMain" 
                                       Text="--%" 
                                       Foreground="White" 
                                       FontWeight="Bold" 
                                       FontSize="22" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Border>
                        
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0">
                            <TextBlock x:Name="TxtStatusText" 
                                       Text="ESTADO: NORMAL" 
                                       Foreground="#4CAF50" 
                                       FontWeight="Bold" 
                                       FontSize="16"/>
                            <TextBlock x:Name="TxtFreedLast" 
                                       Text="&#xDA;ltima limpeza: --" 
                                       Foreground="#888" 
                                       FontSize="12" 
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>
                    
                    <Separator Background="#333" Margin="0,0,0,10"/>
                    
                    <Grid Margin="0,3">
                        <TextBlock Text="Mem&#xF3;ria Total:" Foreground="#AAA" FontSize="11"/>
                        <TextBlock x:Name="TxtTotalRam" Text="-- GB" Foreground="White" HorizontalAlignment="Right" FontWeight="SemiBold" FontSize="11"/>
                    </Grid>
                    <Grid Margin="0,3">
                        <TextBlock Text="Mem&#xF3;ria Usada:" Foreground="#AAA" FontSize="11"/>
                        <TextBlock x:Name="TxtUsedRam" Text="-- GB" Foreground="White" HorizontalAlignment="Right" FontWeight="SemiBold" FontSize="11"/>
                    </Grid>
                    <Grid Margin="0,3">
                        <TextBlock Text="Mem&#xF3;ria Livre:" Foreground="#AAA" FontSize="11"/>
                        <TextBlock x:Name="TxtFreeRam" Text="-- GB" Foreground="{StaticResource AccentColor}" HorizontalAlignment="Right" FontWeight="Bold" FontSize="11"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Se&#xE7;&#xE3;o: Modo de Limpeza -->
            <Border Style="{StaticResource SubtleCardStyle}" Padding="15" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="MODO DE LIMPEZA" 
                               FontSize="12" 
                               FontWeight="Bold" 
                               Foreground="#666"
                               Margin="0,0,0,10"/>
                    
                    <RadioButton x:Name="ModeLeve" GroupName="CleanMode" IsChecked="False" Style="{StaticResource ModeButtonStyle}" Padding="12,8" Margin="0,3" Click="Mode_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F4A7;" Width="30" FontSize="16" VerticalAlignment="Center" FontFamily="Segoe UI Emoji"/>
                            <TextBlock Text="Leve" FontWeight="Bold" Width="70" FontSize="13"/>
                            <TextBlock Text="(Apenas processos ativos)" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    
                    <RadioButton x:Name="ModeNormal" GroupName="CleanMode" IsChecked="True" Style="{StaticResource ModeButtonStyle}" Padding="12,8" Margin="0,3" Click="Mode_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x26A1;" Width="30" FontSize="16" VerticalAlignment="Center" FontFamily="Segoe UI Emoji"/>
                            <TextBlock Text="Normal" FontWeight="Bold" Width="70" FontSize="13"/>
                            <TextBlock Text="(Padr&#xE3;o recomendado)" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    
                    <RadioButton x:Name="ModeAlta" GroupName="CleanMode" IsChecked="False" Style="{StaticResource ModeButtonStyle}" Padding="12,8" Margin="0,3" Click="Mode_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F525;" Width="30" FontSize="16" VerticalAlignment="Center" FontFamily="Segoe UI Emoji"/>
                            <TextBlock Text="Alta" FontWeight="Bold" Width="70" FontSize="13"/>
                            <TextBlock Text="(Limpa Standby List)" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    
                    <RadioButton x:Name="ModeBruta" GroupName="CleanMode" IsChecked="False" Style="{StaticResource ModeButtonStyle}" Padding="12,8" Margin="0,3" Click="Mode_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F480;" Width="30" FontSize="16" VerticalAlignment="Center" FontFamily="Segoe UI Emoji"/>
                            <TextBlock Text="Bruta" FontWeight="Bold" Width="70" FontSize="13"/>
                            <TextBlock Text="(For&#xE7;a TUDO - trava)" Foreground="#D32F2F" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    
                    <Button Content="LIMPAR AGORA &#x1F680;" 
                            Height="40" 
                            Margin="0,10,0,8" 
                            Background="{StaticResource AccentColor}" 
                            Foreground="Black" 
                            FontWeight="Bold" 
                            FontSize="13"
                            Cursor="Hand" 
                            Click="BtnCleanNow_Click"
                            BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bdr" Property="Opacity" Value="1"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="False">
                                        <Setter TargetName="bdr" Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <Button Content="&#x2699;&#xFE0F; Configurar Limpeza Autom&#xE1;tica" 
                            Height="36" 
                            Margin="0,0,0,0" 
                            Background="Transparent" 
                            Foreground="#888" 
                            FontWeight="SemiBold" 
                            FontSize="11"
                            Cursor="Hand" 
                            Click="BtnConfigureAutoClean_Click"
                            BorderThickness="0"
                            HorizontalAlignment="Center">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bdr" Property="Background" Value="#15FFFFFF"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
            
            <!-- Se&#xE7;&#xE3;o: Automa&#xE7;&#xE3;o -->
            <Border Style="{StaticResource SubtleCardStyle}" Padding="15" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="AUTOMA&#xC7;&#xC3;O" 
                               FontSize="12" 
                               FontWeight="Bold" 
                               Foreground="#666"
                               Margin="0,0,0,10"/>
                    
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="&#xCD;cone na Bandeja" FontWeight="SemiBold" FontSize="13" Foreground="White"/>
                            <TextBlock Text="Mostrar &#xED;cone na bandeja" FontSize="11" Foreground="#888"/>
                        </StackPanel>
                        <CheckBox x:Name="ChkEnableTray" Grid.Column="1" Style="{StaticResource TrayToggle}" IsChecked="True" Click="ChkEnableTray_Click"/>
                    </Grid>
                    
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Auto-Limpeza" FontWeight="SemiBold" FontSize="13" Foreground="White"/>
                            <TextBlock Text="Limpar ao atingir limite" FontSize="11" Foreground="#888"/>
                        </StackPanel>
                        <CheckBox x:Name="ChkAutoClean" Grid.Column="1" Style="{StaticResource TrayToggle}" IsChecked="True" Click="ChkAutoClean_Click"/>
                    </Grid>
                    
                    <TextBlock Text="Limite de Uso" FontSize="11" Foreground="#666" Margin="0,10,0,3"/>
                    <Grid Margin="0,0,0,10">
                        <Slider x:Name="SliderThreshold" Minimum="30" Maximum="95" Value="80" TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center" ValueChanged="SliderThreshold_ValueChanged"/>
                        <TextBlock x:Name="TxtThreshold" Text="80%" Foreground="{StaticResource AccentColor}" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,-20,0,0" FontSize="12"/>
                    </Grid>
                    
                    <TextBlock Text="Intervalo de Monitoramento" FontSize="11" Foreground="#666" Margin="0,0,0,3"/>
                    <Grid Margin="0,0,0,10">
                        <Slider x:Name="SliderInterval" Minimum="5" Maximum="120" Value="30" TickFrequency="1" VerticalAlignment="Center" ValueChanged="SliderInterval_ValueChanged"/>
                        <TextBlock x:Name="TxtInterval" Text="30s" Foreground="{StaticResource AccentColor}" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,-20,0,0" FontSize="12"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Se&#xE7;&#xE3;o: Comportamento ao Fechar -->
            <Border Style="{StaticResource SubtleCardStyle}" Padding="15" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="COMPORTAMENTO AO FECHAR" 
                               FontSize="12" 
                               FontWeight="Bold" 
                               Foreground="#666"
                               Margin="0,0,0,10"/>
                    
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Rodar em segundo plano" FontWeight="SemiBold" FontSize="13" Foreground="White"/>
                            <TextBlock Text="Minimiza ao clicar no X (mant&#xE9;m ativo)" FontSize="11" Foreground="#888"/>
                        </StackPanel>
                        <CheckBox x:Name="ChkCloseToTray" Grid.Column="1" Style="{StaticResource TrayToggle}" Click="ChkBackgroundFeature_Click"/>
                    </Grid>
                    
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Iniciar com Windows" FontWeight="SemiBold" FontSize="13" Foreground="White"/>
                            <TextBlock Text="Carregar minimizado" FontSize="11" Foreground="#888"/>
                        </StackPanel>
                        <CheckBox x:Name="ChkAutoStart" Grid.Column="1" Style="{StaticResource TrayToggle}" Click="ChkAutoStart_Click"/>
                    </Grid>
                    
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Mostrar &#xED;cone na bandeja" FontWeight="SemiBold" FontSize="13" Foreground="White"/>
                            <TextBlock Text="&#xCD;cone na &#xE1;rea de notifica&#xE7;&#xE3;o" FontSize="11" Foreground="#888"/>
                        </StackPanel>
                        <CheckBox x:Name="ChkTrayIcon" Grid.Column="1" Style="{StaticResource TrayToggle}" Click="ChkBackgroundFeature_Click"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Se&#xE7;&#xE3;o: Otimiza&#xE7;&#xF5;es -->
            <Border Style="{StaticResource SubtleCardStyle}" Padding="15" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="OTIMIZA&#xC7;&#xD5;ES EM SEGUNDO PLANO" 
                               FontSize="12" 
                               FontWeight="Bold" 
                               Foreground="#666"
                               Margin="0,0,0,10"/>
                    
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="&#x1F9F9; Standby Clean" FontWeight="SemiBold" FontSize="13" Foreground="White"/>
                            <TextBlock Text="Evita ac&#xFA;mulo de lixo" FontSize="11" Foreground="#888"/>
                        </StackPanel>
                        <CheckBox x:Name="ChkStandbyClean" Grid.Column="1" Style="{StaticResource TrayToggle}" IsChecked="True" Click="ChkBackgroundFeature_Click"/>
                    </Grid>
                    
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="&#x26A1; Turbo Boot" FontWeight="SemiBold" FontSize="13" Foreground="White"/>
                            <TextBlock Text="Ignora delay inicializa&#xE7;&#xE3;o" FontSize="11" Foreground="#888"/>
                        </StackPanel>
                        <CheckBox x:Name="ChkTurboBoot" Grid.Column="1" Style="{StaticResource TrayToggle}" Click="ChkBackgroundFeature_Click"/>
                    </Grid>
                    
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="&#x1F6D1; Turbo Shutdown" FontWeight="SemiBold" FontSize="13" Foreground="White"/>
                            <TextBlock Text="Fecha apps antes de desligar" FontSize="11" Foreground="#888"/>
                        </StackPanel>
                        <CheckBox x:Name="ChkTurboShutdown" Grid.Column="1" Style="{StaticResource TrayToggle}" Click="ChkBackgroundFeature_Click"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Se&#xE7;&#xE3;o: Turbo Boot Apps -->
            <Border Style="{StaticResource SubtleCardStyle}" Padding="15" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="APLICATIVOS NO TURBO BOOT" 
                               FontSize="12" 
                               FontWeight="Bold" 
                               Foreground="#666"
                               Margin="0,0,0,10"/>
                    
                    <ItemsControl x:Name="ListTurboApps">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold" FontSize="11"/>
                                        <TextBlock Text="{Binding FullCommand}" Foreground="#666" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <Button Content="&#x23EA;" Width="24" Height="24" Background="Transparent" Foreground="{StaticResource AccentColor}" BorderThickness="0" Cursor="Hand" Click="BtnRestoreTurboApp_Click" Tag="{Binding Name}" ToolTip="Restaurar">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Opacity" Value="0.7"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Opacity" Value="1"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Content="&#x2715;" Width="24" Height="24" Background="Transparent" Foreground="#D32F2F" BorderThickness="0" Cursor="Hand" Click="BtnRemoveTurboApp_Click" Tag="{Binding Name}" ToolTip="Remover" Margin="4,0,0,0">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Opacity" Value="0.7"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Opacity" Value="1"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock x:Name="TxtEmptyTurbo" Text="Nenhum aplicativo delegado ao Turbo Boot." Foreground="#666" FontSize="11" HorizontalAlignment="Center" Margin="0,8" Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <!-- &#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550; -->
            <!-- Se&#xE7;&#xE3;o: Limitador de RAM por Processo (estilo Firemin)       -->
            <!-- &#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550;&#x2550; -->
            <Border Style="{StaticResource SubtleCardStyle}" Padding="15" Margin="0,0,0,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- T&#xED;tulo + bot&#xE3;o adicionar -->
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="&#x1F4BE; LIMITADOR DE RAM POR PROCESSO"
                                       FontSize="12" FontWeight="Bold" Foreground="#666"/>
                            <TextBlock Text="Monitora e limita o uso de RAM de apps espec&#xED;ficos. Igual ao Firemin."
                                       FontSize="11" Foreground="#555" Margin="0,3,0,0"/>
                        </StackPanel>

                        <!-- Controle de intervalo -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="0,0,8,0">
                            <TextBlock Text="Intervalo:" FontSize="11" Foreground="#666"
                                       VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBox x:Name="TxtRamLimiterInterval" Width="55" Text="3000"
                                     Background="#252525" Foreground="White"
                                     BorderBrush="#444" BorderThickness="1"
                                     Padding="5,4" FontSize="11" VerticalAlignment="Center"
                                     ToolTip="Intervalo em ms entre verifica&#xE7;&#xF5;es (500-30000ms). Menor = mais agressivo."
                                     LostFocus="TxtRamLimiterInterval_LostFocus"/>
                            <TextBlock Text="ms" FontSize="11" Foreground="#555"
                                       VerticalAlignment="Center" Margin="4,0,0,0"/>
                        </StackPanel>

                        <!-- Bot&#xE3;o adicionar por .exe -->
                        <Button Grid.Column="2" Content="&#x1F4C1; Adicionar por Arquivo"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Height="32" FontSize="11" Padding="10,0" Margin="0,0,6,0"
                                ToolTip="Selecionar execut&#xE1;vel manualmente"
                                Click="BtnAddByFile_Click"/>
                        <!-- Bot&#xE3;o principal: abre seletor de processos -->
                        <Button Grid.Column="3" Content="&#x26A1; Selecionar Processo"
                                Style="{StaticResource GoldButtonStyle}"
                                Height="32" FontSize="11" Padding="10,0"
                                ToolTip="Abre lista de processos rodando para selecionar"
                                Click="BtnOpenProcessPicker_Click"/>
                    </Grid>

                    <!-- Atalhos r&#xE1;pidos removidos &#x2014; os apps variam por usu&#xE1;rio -->

                    <!-- Lista de limites configurados (code-behind popula) -->
                    <StackPanel x:Name="ProcessLimitsPanel" Grid.Row="2"/>

                    <TextBlock x:Name="TxtNoLimits" Grid.Row="3"
                               Text="Nenhum limite configurado. Clique em 'Selecionar Processo' para come&#xE7;ar."
                               Foreground="#444" FontSize="11" HorizontalAlignment="Center"
                               Margin="0,8" Visibility="Visible"/>
                </Grid>
            </Border>

            <!-- Overlay do seletor de processos &#x2014; centralizado na tela via MainWindow -->
            <!-- O overlay &#xE9; aberto via code-behind que o injeta no OverlayContainer do MainWindow -->

        </StackPanel>
    </ScrollViewer>
</Page>
