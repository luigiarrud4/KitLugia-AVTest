<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="KitLugia.GUI.Pages.IsoEditorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="1000"
      Title="IsoEditor"
      TextElement.FontFamily="Segoe UI Variable Display, Segoe UI, Segoe UI Emoji, Segoe UI Symbol, Arial">

    <Page.Resources>
    </Page.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
            <TextBlock Text="&#x1F4BF;" FontSize="32" Margin="0,0,15,0" VerticalAlignment="Center"/>
            <StackPanel>
                <TextBlock Text="ISO EDITOR (WINHANCE)" FontSize="26" FontWeight="ExtraBold" Foreground="{StaticResource AccentColor}"/>
                <TextBlock Text="Editor de ISO Profissional - Montagem, Debloat, Features e Redu&#xE7;&#xE3;o de Tamanho" FontSize="12" Foreground="{StaticResource TextMuted}" Opacity="0.8"/>
            </StackPanel>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
            <StackPanel>
                <!-- ISO Selection Card -->
                <Border Background="{StaticResource CardBackground}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="12" Padding="25" Margin="0,0,0,20" Style="{StaticResource SubtleCardStyle}">
                    <StackPanel>
                        <TextBlock Text="&#x1F4C0; IMAGEM ISO" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentColor}" Margin="0,0,0,15"/>
                        <TextBlock Text="Selecione o arquivo ISO de instala&#xE7;&#xE3;o:" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtIsoPath" Height="40" VerticalContentAlignment="Center"
                                     Background="#1A1A1A" Foreground="#FFFFFF" BorderThickness="1" BorderBrush="#444444" Padding="15,0" IsReadOnly="True"
                                     TextChanged="TxtIsoPath_TextChanged"/>
                            <Button Grid.Column="1" Content="BUSCAR ISO" Padding="20,0" Margin="10,0,0,0" Click="BtnSelectIso_Click" Style="{StaticResource SecondaryButtonStyle}"/>
                        </Grid>
                        <TextBlock x:Name="TxtDetectedIsoType" Text="" FontSize="11" Foreground="{StaticResource AccentColor}" Margin="0,5,0,0" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Help Section -->
                <Border Background="#0AFFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,0,20" Style="{StaticResource SubtleCardStyle}">
                    <StackPanel>
                        <TextBlock Text="&#x2754; COMO FUNCIONA O ISO EDITOR" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,10"/>
                        <TextBlock Text="1. Sele&#xE7;&#xE3;o: Escolha o arquivo ISO de instala&#xE7;&#xE3;o do Windows." Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,3"/>
                        <TextBlock Text="2. Montagem: A ISO ser&#xE1; montada automaticamente ao clicar em INICIAR CRIA&#xC7;&#xC3;O." Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,3"/>
                        <TextBlock Text="3. Configura&#xE7;&#xE3;o: Escolha as op&#xE7;&#xF5;es de debloat, features e redu&#xE7;&#xE3;o de tamanho." Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,3"/>
                        <TextBlock Text="4. Cria&#xE7;&#xE3;o: A ISO final ser&#xE1; criada com todas as modifica&#xE7;&#xF5;es aplicadas." Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,0,3"/>
                    </StackPanel>
                </Border>

                <!-- Expandable Detailed Log -->
                <Expander Header="LOG DETALHADO (DIAGN&#xD3;STICO E EXECU&#xC7;&#xC3;O)" Background="Transparent" Foreground="{StaticResource TextMuted}" Margin="0,0,0,20">
                    <Border Background="#05000000" CornerRadius="8" Padding="10" Margin="0,5,0,0" BorderBrush="#11FFFFFF" BorderThickness="1">
                        <TextBox x:Name="TxtLogViewer" Height="150" Background="Transparent" Foreground="#88FFFFFF" 
                                 BorderThickness="0" FontFamily="Consolas" TextWrapping="Wrap" IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto"/>
                    </Border>
                </Expander>

                <!-- Status Monitor -->
                <Border Background="#11D4AF37" BorderBrush="#33D4AF37" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Status:" FontWeight="Bold" Foreground="{StaticResource AccentColor}" Margin="0,0,10,0"/>
                        <TextBlock x:Name="TxtStatus" Text="Aguardando in&#xED;cio..." Foreground="White"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Actions -->
        <Border Grid.Row="2" Background="{StaticResource CardBackground}" Margin="-30,20,-30,-30" Padding="30">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Aten&#xE7;&#xE3;o: Este processo modificar&#xE1; a ISO selecionada." FontSize="11" Foreground="{StaticResource TextMuted}"/>
                    <TextBlock Text="Certifique-se de que possui backup da ISO original." FontSize="11" Foreground="{StaticResource TextMuted}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnCleanup" Content="&#x1F9F9; LIMPAR LIXO" Width="140" Margin="0,0,10,0" Click="BtnCleanup_Click" Background="#2A2A2A" BorderBrush="#FFD700" Foreground="#FFD700" Padding="10" Cursor="Hand"/>
                    <Button x:Name="BtnBack" Content="&#x2190; VOLTAR" Width="120" Margin="0,0,10,0" Click="BtnCancelConfig_Click" Style="{StaticResource SecondaryButtonStyle}"/>
                    <Button x:Name="BtnCreate" Content="&#x1F680; INICIAR CRIA&#xC7;&#xC3;O" Width="180" FontSize="14" Click="BtnCreate_Click" Style="{StaticResource GoldButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Overlay de Configura&#xE7;&#xE3;o -->
        <Border x:Name="OverlayConfig" Grid.Row="0" Grid.RowSpan="2" Background="#CC000000" Visibility="Collapsed">
            <Border Background="#1E1E1E" BorderBrush="#FFD700" BorderThickness="2" CornerRadius="8" MaxWidth="700" MaxHeight="650" Margin="50" VerticalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="10" Opacity="0.5"/>
                </Border.Effect>
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <TextBlock Text="&#x2699;&#xFE0F; CONFIGURAR CRIA&#xC7;&#xC3;O" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>

                    <!-- Info da ISO -->
                    <Border Grid.Row="1" Background="#2A2A2A" Padding="15" CornerRadius="5" Margin="0,0,0,15">
                        <TextBlock x:Name="TxtConfigIsoInfo" Text="ISO n&#xE3;o selecionada" Foreground="#FFD700" FontSize="14" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Checkboxes de Op&#xE7;&#xF5;es (Chris Titus WinUtil) -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <!-- Destino da ISO -->
                            <TextBlock Text="&#x1F4C1; DESTINO DA ISO" FontSize="14" FontWeight="Bold" Foreground="#FFD700" Margin="0,0,0,10"/>
                            <Grid Margin="0,0,0,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtIsoDest" Grid.Column="0" Text="Caminho da ISO final..." Foreground="Gray" IsReadOnly="True" Background="#2A2A2A" BorderBrush="#444" Padding="8"/>
                                <Button x:Name="BtnSelectIsoDest" Grid.Column="1" Content="&#x1F4C2;" Click="BtnSelectIsoDest_Click" Width="40" Margin="10,0,0,0" Background="#2A2A2A" BorderBrush="#FFD700" Foreground="#FFD700" Cursor="Hand"/>
                            </Grid>

                            <TextBlock Text="&#x2699;&#xFE0F; OP&#xC7;&#xD5;ES DO CHRIS TITUS WINUTIL" FontSize="14" FontWeight="Bold" Foreground="#FFD700" Margin="0,0,0,10"/>
                            
                            <!-- Bot&#xF5;es de Sele&#xE7;&#xE3;o R&#xE1;pida -->
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button x:Name="BtnSelectAll" Grid.Column="0" Content="&#x2705; Selecionar Todos" Click="BtnSelectAll_Click" Background="#2A2A2A" BorderBrush="#FFD700" Foreground="#FFD700" Padding="10" Margin="0,0,5,0" Cursor="Hand"/>
                                <Button x:Name="BtnDeselectAll" Grid.Column="1" Content="&#x274C; Desmarcar Todos" Click="BtnDeselectAll_Click" Background="#2A2A2A" BorderBrush="#FFD700" Foreground="#FFD700" Padding="10" Margin="5,0,0,0" Cursor="Hand"/>
                            </Grid>

                            <CheckBox x:Name="ChkInjectDrivers" Content="Injetar Drivers do Sistema Atual" Foreground="White" Margin="0,10"/>
                            <TextBlock Text="Exporta todos os drivers do sistema e injeta na ISO (install.wim e boot.wim)" Foreground="#AAA" FontSize="11" Margin="25,0,0,15"/>

                            <CheckBox x:Name="ChkDebloatPreset" Content="Remover Bloatware (AppX)" Foreground="White" Margin="0,10"/>
                            <TextBlock Text="Remove 20+ apps bloatware: Bing, Solitaire, Sticky Notes, Paint, etc." Foreground="#AAA" FontSize="11" Margin="25,0,0,15"/>

                            <CheckBox x:Name="ChkBypassRequirements" Content="Bypass de Requisitos de Sistema" Foreground="White" Margin="0,10"/>
                            <TextBlock Text="Bypass TPM, CPU, RAM, Secure Boot, Storage checks" Foreground="#AAA" FontSize="11" Margin="25,0,0,15"/>

                            <CheckBox x:Name="ChkDisableSponsoredApps" Content="Desabilitar Apps Patrocinados" Foreground="White" Margin="0,10"/>
                            <TextBlock Text="Desabilita instala&#xE7;&#xE3;o de apps patrocinados e sugest&#xF5;es" Foreground="#AAA" FontSize="11" Margin="25,0,0,15"/>

                            <CheckBox x:Name="ChkDisableTelemetry" Content="Desabilitar Telemetria" Foreground="White" Margin="0,10"/>
                            <TextBlock Text="Desabilita coleta de dados e telemetria do Windows" Foreground="#AAA" FontSize="11" Margin="25,0,0,15"/>

                            <CheckBox x:Name="ChkDisableOneDrive" Content="Desabilitar OneDrive" Foreground="White" Margin="0,10"/>
                            <TextBlock Text="Desabilita backup de pasta e instala&#xE7;&#xE3;o do OneDrive" Foreground="#AAA" FontSize="11" Margin="25,0,0,15"/>

                            <CheckBox x:Name="ChkDisableCopilot" Content="Desabilitar Copilot" Foreground="White" Margin="0,10"/>
                            <TextBlock Text="Desabilita Windows Copilot e sugest&#xF5;es de busca" Foreground="#AAA" FontSize="11" Margin="25,0,0,15"/>

                            <CheckBox x:Name="ChkDisableUpdateOOBE" Content="Desabilitar Windows Update no OOBE" Foreground="White" Margin="0,10"/>
                            <TextBlock Text="Desabilita updates durante a configura&#xE7;&#xE3;o inicial (reativado no primeiro login)" Foreground="#AAA" FontSize="11" Margin="25,0,0,15"/>

                            <CheckBox x:Name="ChkDisableTeams" Content="Prevenir Instala&#xE7;&#xE3;o do Teams" Foreground="White" Margin="0,10"/>
                            <TextBlock Text="Bloqueia instala&#xE7;&#xE3;o autom&#xE1;tica do Microsoft Teams" Foreground="#AAA" FontSize="11" Margin="25,0,0,15"/>

                            <CheckBox x:Name="ChkDisableOutlook" Content="Prevenir Instala&#xE7;&#xE3;o do Novo Outlook" Foreground="White" Margin="0,10"/>
                            <TextBlock Text="Bloqueia instala&#xE7;&#xE3;o autom&#xE1;tica do novo Outlook" Foreground="#AAA" FontSize="11" Margin="25,0,0,15"/>

                            <CheckBox x:Name="ChkDisableBitLocker" Content="Desabilitar BitLocker" Foreground="White" Margin="0,10"/>
                            <TextBlock Text="Desabilita criptografia de dispositivo BitLocker" Foreground="#AAA" FontSize="11" Margin="25,0,0,15"/>

                            <CheckBox x:Name="ChkDisableChat" Content="Desabilitar &#xCD;cone do Chat" Foreground="White" Margin="0,10"/>
                            <TextBlock Text="Remove &#xED;cone do Chat da barra de tarefas" Foreground="#AAA" FontSize="11" Margin="25,0,0,15"/>

                            <CheckBox x:Name="ChkDisableReservedStorage" Content="Desabilitar Reserved Storage" Foreground="White" Margin="0,10"/>
                            <TextBlock Text="Desabilita armazenamento reservado do Windows" Foreground="#AAA" FontSize="11" Margin="25,0,0,15"/>

                            <CheckBox x:Name="ChkCleanupWinSxS" Content="Limpar WinSxS com /ResetBase" Foreground="White" Margin="0,10"/>
                            <TextBlock Text="Remove vers&#xF5;es superadas de componentes. Economia: ~1-2GB" Foreground="#AAA" FontSize="11" Margin="25,0,0,5"/>
                            <TextBlock Text="&#x26A0;&#xFE0F; PODE CAUSAR TRAVAMENTO NA DESMONTAGEM (15+ minutos)" Foreground="#FF6B6B" FontSize="10" FontWeight="Bold" Margin="25,0,0,15"/>

                            <CheckBox x:Name="ChkRemoveSupportFolder" Content="Remover Pasta Support\" Foreground="White" Margin="0,10"/>
                            <TextBlock Text="Remove pasta support\ da ISO (arquivos de suporte)" Foreground="#AAA" FontSize="11" Margin="25,0,0,15"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Bot&#xF5;es -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="CANCELAR" Click="BtnCancelConfig_Click" Background="#FF4444" Foreground="White" FontWeight="Bold" Padding="15,8" Margin="0,0,10,0" Cursor="Hand"/>
                        <Button Content="&#x1F680; INICIAR AGORA" Click="BtnConfirmStart_Click" Style="{StaticResource GoldButtonStyle}" FontWeight="Bold" Padding="15,8" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Border>

        <!-- Loading Overlay -->
        <Border x:Name="OverlayBusy" Grid.RowSpan="3" Background="#CC000000" Visibility="Collapsed" Margin="-30">
            <StackPanel VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="250" Height="4" Foreground="{StaticResource AccentColor}" Background="#111111" BorderThickness="0" Margin="0,0,0,15"/>
                <TextBlock x:Name="TxtBusyStatus" Text="Processando..." Foreground="White" HorizontalAlignment="Center" FontSize="16" FontWeight="SemiBold"/>
                <TextBlock Text="Opera&#xE7;&#xE3;o cr&#xED;tica. N&#xE3;o feche o KitLugia." Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center" FontSize="12" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
