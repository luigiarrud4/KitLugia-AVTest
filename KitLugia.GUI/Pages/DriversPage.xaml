<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="KitLugia.GUI.Pages.DriversPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      Title="Drivers"
      TextElement.FontFamily="Segoe UI Variable Display, Segoe UI, Segoe UI Emoji, Segoe UI Symbol, Arial" d:DesignHeight="700" d:DesignWidth="950">

    <Page.Resources>

        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="0,0,0,3" Margin="0,0,10,0">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentColor}" />
                                <Setter Property="Foreground" Value="{DynamicResource AccentColor}" />
                                <Setter Property="FontWeight" Value="Bold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ContextMenu x:Key="DriverContextMenu" Style="{StaticResource ServiceContextMenu}">
            <MenuItem Header="Desinstalar (For&#xE7;ar Remo&#xE7;&#xE3;o)" Click="CtxUninstall_Click" Style="{StaticResource ServiceMenuItem}" Foreground="#FF6F61" FontWeight="Bold"/>
            <Separator Background="#333"/>
            <MenuItem Header="Copiar Nome" Click="CtxCopyName_Click" Style="{StaticResource ServiceMenuItem}"/>
            <MenuItem Header="Copiar ID de Hardware" Click="CtxCopyId_Click" Style="{StaticResource ServiceMenuItem}"/>
        </ContextMenu>
    </Page.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Gerenciador de Drivers" Foreground="White" FontSize="32" FontWeight="SemiBold" Margin="0,0,0,20"/>

        <TabControl x:Name="MainTabs" Grid.Row="1" Background="Transparent" BorderThickness="0">

            <!-- ABA 1: LISTA DE DRIVERS -->
            <TabItem Header="Drivers Locais">
                <Grid Margin="0,15,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Cards -->
                        <RowDefinition Height="Auto"/>
                        <!-- Filtros -->
                        <RowDefinition Height="*"/>
                        <!-- Tabela -->
                        <RowDefinition Height="Auto"/>
                        <!-- A&#xE7;&#xF5;es -->
                    </Grid.RowDefinitions>

                    <!-- CARDS DE A&#xC7;&#xC3;O -->
                    <Grid Grid.Row="0" Margin="0,0,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="15" MinHeight="140">
                            <StackPanel>
                                <TextBlock Text="&#x1F4E5; Instalar Driver" Foreground="White" FontWeight="Bold" FontSize="15" Margin="0,0,0,5"/>
                                <TextBlock Text="Instala drivers de arquivos CAB, ZIP ou de uma pasta espec&#xED;fica." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" FontSize="12" Margin="0,0,0,15"/>
                                <Button Content="Instalar de Arquivo" Click="BtnInstallFromFolder_Click" Style="{StaticResource SecondaryButtonStyle}" Height="30" VerticalAlignment="Bottom"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="15" BorderBrush="{StaticResource AccentColor}" MinHeight="140">
                            <Border.Effect>
                                <DropShadowEffect Color="#FFD700" BlurRadius="10" Opacity="0.1" ShadowDepth="0"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="&#x1F4BE; Backup Completo" Foreground="{StaticResource AccentColor}" FontWeight="Bold" FontSize="15" Margin="0,0,0,5"/>
                                <TextBlock Text="Cria backup de todos os drivers instalados para restaura&#xE7;&#xE3;o r&#xE1;pida." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" FontSize="12" Margin="0,0,0,15"/>
                                <Button Content="Criar Backup" Click="BtnBackup_Click" Style="{StaticResource GoldButtonStyle}" Height="30" VerticalAlignment="Bottom"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4" Style="{StaticResource CardStyle}" Padding="15" MinHeight="140">
                            <StackPanel>
                                <TextBlock Text="&#x1F4C4; Exportar Lista" Foreground="White" FontWeight="Bold" FontSize="15" Margin="0,0,0,5"/>
                                <TextBlock Text="Exporta a lista de drivers para arquivo TXT para an&#xE1;lise." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" FontSize="12" Margin="0,0,0,15"/>
                                <Button Content="Exportar TXT" Click="BtnExportList_Click" Style="{StaticResource SecondaryButtonStyle}" Height="30" VerticalAlignment="Bottom"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- BARRA DE FERRAMENTAS -->
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Busca e Contador -->
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#20FFFFFF" CornerRadius="4" Height="30" Width="250" Margin="0,0,15,0">
                                <Grid>
                                    <TextBlock Text="&#x1F50D; Filtrar drivers..." Foreground="#888" VerticalAlignment="Center" Margin="10,0" IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=TxtFilter}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBox x:Name="TxtFilter" Background="Transparent" BorderThickness="0" Foreground="White" VerticalAlignment="Center" Margin="5,0" TextChanged="TxtFilter_TextChanged"/>
                                </Grid>
                            </Border>

                            <!-- Contador de Drivers -->
                            <TextBlock x:Name="TxtCount" Text="Carregando..." Foreground="{StaticResource AccentColor}" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>

                        <!-- Status -->
                        <TextBlock x:Name="TxtStatus" Grid.Column="1" Text="Pronto." Foreground="#888" VerticalAlignment="Center" FontSize="12" Margin="0,0,15,0"/>
                    </Grid>

                    <!-- TABELA DE DRIVERS -->
                    <Border Grid.Row="2" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="6" Background="#111">
                        <DataGrid x:Name="GridDrivers" SelectionMode="Extended">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="40" CanUserResize="False" CanUserSort="False">
                                    <DataGridTemplateColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="&#x2611;" FontSize="16" Foreground="{DynamicResource AccentColor}" ToolTip="Selecionar" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.HeaderTemplate>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" 
                                                      HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Width="40" CanUserSort="False">
                                    <DataGridTemplateColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.HeaderTemplate>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Icon}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Fabricante" Binding="{Binding Provider}" Width="140" IsReadOnly="True" SortMemberPath="Provider">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Dispositivo" Binding="{Binding DeviceName}" Width="*" IsReadOnly="True" SortMemberPath="DeviceName">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Vers&#xE3;o" Binding="{Binding Version}" Width="120" IsReadOnly="True" SortMemberPath="Version">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Data" Binding="{Binding Date}" Width="100" IsReadOnly="True" SortMemberPath="DateAsDateTime">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="Status" Width="140" IsReadOnly="True" SortMemberPath="UpdateStatus">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding UpdateStatus}" VerticalAlignment="Center" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#777"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding UpdateStatus}" Value="Atualizado">
                                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding UpdateStatus}" Value="Antigo">
                                                                <Setter Property="Foreground" Value="#FF6F61"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>

                            <!-- Menu de Contexto para Drivers -->
                            <DataGrid.ContextMenu>
                                <ContextMenu Style="{StaticResource ServiceContextMenu}">
                                    <MenuItem Header="Desinstalar (For&#xE7;ar Remo&#xE7;&#xE3;o)" Click="CtxUninstall_Click" Style="{StaticResource ServiceMenuItem}" Foreground="#FF6F61" FontWeight="Bold"/>
                                    <Separator Background="#333"/>
                                    <MenuItem Header="Copiar Nome" Click="CtxCopyName_Click" Style="{StaticResource ServiceMenuItem}"/>
                                    <MenuItem Header="Copiar ID de Hardware" Click="CtxCopyId_Click" Style="{StaticResource ServiceMenuItem}"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ABA 2: DIAGN&#xD3;STICO (BSOD / VERIFIER) -->
            <TabItem Header="Diagn&#xF3;stico (BSOD)">
                <Grid Margin="0,15,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Cards -->
                        <RowDefinition Height="Auto"/>
                        <!-- Conte&#xFA;do -->
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- CARDS DE A&#xC7;&#xC3;O -->
                    <Grid Grid.Row="0" Margin="0,0,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="15" BorderBrush="#FF5555" MinHeight="140">
                            <Border.Effect>
                                <DropShadowEffect Color="#FF5555" BlurRadius="10" Opacity="0.15" ShadowDepth="0"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="&#x26A0;&#xFE0F; ATIVAR VERIFIER" Foreground="#FF5555" FontWeight="Bold" FontSize="15" Margin="0,0,0,5"/>
                                <TextBlock Text="For&#xE7;a o Windows a travar (BSOD) se encontrar erro no driver. Use apenas para diagnosticar telas azuis." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" FontSize="12" Margin="0,0,0,15"/>
                                <Button Content="ATIVAR (Estresse)" Click="BtnEnableVerifier_Click" Style="{StaticResource SecondaryButtonStyle}" Height="30" Foreground="#FF5555" BorderBrush="#FF5555" VerticalAlignment="Bottom"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="15" BorderBrush="{StaticResource AccentColor}" MinHeight="140">
                            <Border.Effect>
                                <DropShadowEffect Color="#FFD700" BlurRadius="10" Opacity="0.1" ShadowDepth="0"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="&#x2705; DESATIVAR / RESETAR" Foreground="{StaticResource AccentColor}" FontWeight="Bold" FontSize="15" Margin="0,0,0,5"/>
                                <TextBlock Text="Desativa o Verifier e restaura o boot normal. Use se o PC entrar em loop de reinicializa&#xE7;&#xE3;o." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" FontSize="12" Margin="0,0,0,15"/>
                                <Button Content="DESATIVAR" Click="BtnDisableVerifier_Click" Style="{StaticResource GoldButtonStyle}" Height="30" VerticalAlignment="Bottom"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- CONTE&#xDA;DO DO DIAGN&#xD3;STICO -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="350"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,30,0">
                            <TextBlock Text="Estado Atual do Driver Verifier" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
                            
                            <Border Background="#1A1A1A" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="6" Padding="20" Margin="0,0,0,20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#x2139;&#xFE0F;" FontSize="30" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Status:" Foreground="#888" FontSize="12"/>
                                        <TextBlock x:Name="TxtVerifierStatus" Text="DESCONHECIDO" Foreground="White" FontWeight="Bold" FontSize="16"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <TextBlock Text="&#x26A0;&#xFE0F; AVISO IMPORTANTE" Foreground="#FF5555" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>
                            <TextBlock Text="O Driver Verifier &#xE9; uma ferramenta avan&#xE7;ada que pode causar instabilidade no sistema. Se o PC entrar em boot loop:" Foreground="#CCC" TextWrapping="Wrap" FontSize="13" Margin="0,0,0,10"/>
                            <TextBlock Text="1. Entre em Modo de Seguran&#xE7;a (F8 ou Shift+Restart)" Foreground="#AAA" FontSize="12" Margin="0,0,0,5"/>
                            <TextBlock Text="2. Volte aqui e clique em DESATIVAR" Foreground="#AAA" FontSize="12" Margin="0,0,0,5"/>
                            <TextBlock Text="3. Reinicie o PC normalmente" Foreground="#AAA" FontSize="12"/>
                        </StackPanel>

                        <!-- Dicas Laterais -->
                        <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="20" VerticalAlignment="Top">
                            <StackPanel>
                                <TextBlock Text="Como Usar" FontWeight="Bold" Foreground="{StaticResource AccentColor}" FontSize="14" Margin="0,0,0,15"/>

                                <TextBlock Text="1. Ative o Verifier" Foreground="White" Margin="0,0,0,5"/>
                                <TextBlock Text="O Windows pedir&#xE1; reinicializa&#xE7;&#xE3;o." Foreground="#777" FontSize="11" Margin="0,0,0,15"/>

                                <TextBlock Text="2. Use o PC normalmente" Foreground="White" Margin="0,0,0,5"/>
                                <TextBlock Text="Execute tarefas at&#xE9; o BSOD ocorrer." Foreground="#777" FontSize="11" Margin="0,0,0,15"/>

                                <TextBlock Text="3. Anote o erro" Foreground="White" Margin="0,0,0,5"/>
                                <TextBlock Text="Nome do arquivo (ex: nvlddmkm.sys)." Foreground="#777" FontSize="11" Margin="0,0,0,15"/>

                                <TextBlock Text="4. Desative o Verifier" Foreground="White" Margin="0,0,0,5"/>
                                <TextBlock Text="Volte aqui e clique em DESATIVAR." Foreground="#777" FontSize="11"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Loading Overlay -->
        <Grid x:Name="LoadingOverlay" Grid.Row="0" Grid.RowSpan="2" Background="#D9000000" Visibility="Collapsed" Panel.ZIndex="99">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="&#x2699;&#xFE0F;" FontSize="40" HorizontalAlignment="Center" Foreground="{StaticResource AccentColor}"/>
                <TextBlock x:Name="TxtLoadingMsg" Text="Processando..." Foreground="White" Margin="0,10,0,0" FontSize="16"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>