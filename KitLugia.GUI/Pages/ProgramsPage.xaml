<Page x:Class="KitLugia.GUI.Pages.ProgramsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="1000"
      Background="#1E1E1E"
      TextElement.FontFamily="Segoe UI Variable Display, Segoe UI, Segoe UI Emoji, Segoe UI Symbol, Arial">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Gerenciador de Programas" FontSize="28" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock x:Name="ProgramCountText" Text="Programas: 0" FontSize="14" Foreground="#FFD700" Margin="15,8,0,0" FontWeight="SemiBold"/>
            </StackPanel>
            <TextBlock Text="Programas instalados no Windows. Gerencie instala&#xE7;&#xF5;es normais." Foreground="#AAA" Margin="0,5,0,0"/>
            <TextBlock Text="Baseado em Bulk Crap Uninstaller (BCU) - Licen&#xE7;a Apache 2.0" Foreground="#FF6F61" FontSize="11" Margin="0,5,0,0"/>
            
            <!-- Barra de Pesquisa -->
            <TextBox x:Name="TxtSearch" TextChanged="TxtSearch_TextChanged" 
                     Background="#252525" 
                     Foreground="White" 
                     BorderBrush="#333" 
                     BorderThickness="1" 
                     Padding="10,8" 
                     Margin="0,15,0,0" 
                     FontSize="14"/>
        </StackPanel>

        <!-- Loading Panel -->
        <Border x:Name="LoadingPanel" Grid.Row="1" Panel.ZIndex="99" Background="#CC000000" Visibility="Visible" CornerRadius="8">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Ellipse Width="40" Height="40" Stroke="#FFD700" StrokeThickness="3" Fill="Transparent" RenderTransformOrigin="0.5,0.5" StrokeDashArray="70 30">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="SpinnerRotate"/>
                    </Ellipse.RenderTransform>
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                   From="0" To="360" Duration="0:0:1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
                <TextBlock Text="Carregando programas..." Foreground="White" Margin="0,15,0,0" FontSize="14" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <!-- Programs List -->
        <Border Grid.Row="1" Background="#252525" BorderBrush="#333" BorderThickness="1" CornerRadius="8" Padding="10">
            <ListView x:Name="ProgramsList" 
                      Background="Transparent" 
                      BorderThickness="0"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Margin" Value="0,2"/>
                        <Setter Property="Padding" Value="8"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#333"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#444"/>
                                <Setter Property="BorderBrush" Value="#FFD700"/>
                                <Setter Property="BorderThickness" Value="1"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <!-- Checkbox para sele&#xE7;&#xE3;o m&#xFA;ltipla -->
                            <CheckBox Grid.Column="0" 
                                      IsChecked="{Binding IsSelected, Mode=TwoWay}" 
                                      VerticalAlignment="Center" 
                                      Margin="0,0,8,0"/>

                            <!-- &#xCD;cone do Programa -->
                            <Image Grid.Column="1" 
                                   Width="32" 
                                   Height="32" 
                                   Source="{Binding Icon}" 
                                   Stretch="Uniform"
                                   VerticalAlignment="Center"/>

                            <!-- Informa&#xE7;&#xF5;es do Programa -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="8,0,0,0">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Publisher}" FontSize="11" Foreground="#666" TextTrimming="CharacterEllipsis" Margin="0,1,0,0"/>
                            </StackPanel>

                            <!-- Vers&#xE3;o -->
                            <TextBlock Grid.Column="3" 
                                       Text="{Binding DisplayVersion}" 
                                       FontSize="11" 
                                       Foreground="#555" 
                                       VerticalAlignment="Center" 
                                       TextTrimming="CharacterEllipsis"/>

                            <!-- Bot&#xE3;o Remover -->
                            <Button Grid.Column="4" Height="28" FontSize="10" Cursor="Hand" Click="BtnRemove_Click" Tag="{Binding}" Content="REMOVER">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="#C42B1C"/>
                                        <Setter Property="Foreground" Value="#FF6F61"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bdr" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bdr" Property="Background" Value="#C42B1C"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Remover Selecionados" Click="BtnRemoveSelected_Click" Height="35" Width="140" 
                    Background="#C42B1C" Foreground="White" BorderThickness="0" Margin="0,0,10,0"
                    Style="{StaticResource GoldButtonStyle}"/>
            <Button Content="Atualizar Lista" Click="BtnRefresh_Click" Height="35" Width="120" 
                    Background="#333" Foreground="White" BorderThickness="0"
                    Style="{StaticResource SecondaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Page>
