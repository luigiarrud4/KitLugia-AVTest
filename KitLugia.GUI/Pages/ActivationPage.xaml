<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="KitLugia.GUI.Pages.ActivationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Microsoft Activation Scripts (MAS)"
      TextElement.FontFamily="Segoe UI Variable Display, Segoe UI, Segoe UI Emoji, Segoe UI Symbol, Arial"
      Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel Margin="30" MaxWidth="950">

            <!-- HEADER -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                <TextBlock Text="&#x1F511;" FontSize="32" Margin="0,0,15,0" VerticalAlignment="Center"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Microsoft Activation Scripts" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AccentColor}"/>
                    <TextBlock Text="Baseado em MAS por massgrave.dev" FontSize="12" Foreground="{StaticResource TextSecondary}"/>
                </StackPanel>
            </StackPanel>

            <!-- BOT&#xC3;O PRINCIPAL: EXECUTAR MAS -->
            <Border Background="{StaticResource CardBackground}" CornerRadius="8" Padding="25"
                    BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Margin="0,0,0,25" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="&#x26A1; Executar Ativa&#xE7;&#xE3;o" FontSize="18" FontWeight="Bold" 
                               Foreground="{StaticResource AccentColor}" Margin="0,0,0,10"/>
                    <TextBlock Text="Clique no bot&#xE3;o abaixo para abrir o Microsoft Activation Scripts. O script ser&#xE1; executado em uma janela de terminal separada com privil&#xE9;gios de administrador."
                               Foreground="{StaticResource TextSecondary}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,15"/>
                    
                    <Button Content="&#x1F680;  EXECUTAR MAS" 
                            Style="{StaticResource GoldButtonStyle}" 
                            Height="50" FontSize="16" FontWeight="Bold"
                            Click="BtnExecutarMAS_Click"/>
                </StackPanel>
            </Border>

            <!-- STATUS DO WINDOWS -->
            <Border Background="{StaticResource CardBackground}" CornerRadius="8" Padding="20"
                    BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Margin="0,0,0,25" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <Grid Margin="0,0,0,15">
                        <TextBlock Text="&#x1FA9F; Status do Windows" FontSize="18" FontWeight="Bold" 
                                   Foreground="{StaticResource AccentColor}" VerticalAlignment="Center"/>
                        <Button Content="&#x1F504; Atualizar" Style="{StaticResource SecondaryButtonStyle}" 
                                HorizontalAlignment="Right" Height="30" Width="120"
                                Click="BtnRefresh_Click"/>
                    </Grid>

                    <Grid Margin="0,5,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Produto:" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Grid.Column="1" x:Name="TxtWindowsProduct" Text="Carregando..." Foreground="{StaticResource TextSecondary}"/>
                    </Grid>
                    <Grid Margin="0,5,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Status:" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Grid.Column="1" x:Name="TxtWindowsStatus" Text="Carregando..." Foreground="{StaticResource TextSecondary}"/>
                    </Grid>
                    <Grid Margin="0,5,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Chave Parcial:" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Grid.Column="1" x:Name="TxtPartialKey" Text="..." Foreground="{StaticResource TextSecondary}"/>
                    </Grid>
                    <Grid Margin="0,5,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="M&#xE9;todo:" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
                        <TextBlock Grid.Column="1" x:Name="TxtActivationMethod" Text="..." Foreground="{StaticResource TextSecondary}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- A&#xC7;&#xD5;ES EXTRAS -->
            <Border Background="{StaticResource CardBackground}" CornerRadius="8" Padding="20"
                    BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Margin="0,0,0,25">
                <StackPanel>
                    <TextBlock Text="&#x1F527; A&#xE7;&#xF5;es Extras" FontSize="18" FontWeight="Bold" 
                               Foreground="{StaticResource AccentColor}" Margin="0,0,0,15"/>
                    <WrapPanel>
                        <Button Content="&#x1F4D6; Documenta&#xE7;&#xE3;o MAS" Style="{StaticResource SecondaryButtonStyle}" 
                                Width="180" Height="35" Margin="0,0,10,10"
                                Click="BtnDocumentation_Click"/>
                        <Button Content="&#x1F310; Verificar Internet" Style="{StaticResource SecondaryButtonStyle}" 
                                Width="180" Height="35" Margin="0,0,10,10"
                                Click="BtnCheckInternet_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- INFO -->
            <Border Background="{StaticResource CardBackground}" CornerRadius="8" Padding="20" 
                    BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="&#x2139;&#xFE0F; Sobre o MAS" FontSize="16" FontWeight="Bold" 
                               Foreground="{StaticResource AccentColor}" Margin="0,0,0,10"/>
                    <TextBlock Text="&#x2022; HWID Activation (Permanente)&#x0a;&#x2022; Ohook Activation (Office)&#x0a;&#x2022; Online KMS Activation&#x0a;&#x2022; TSforge Activation Method&#x0a;&#x2022; Windows/Office Edition Changer" 
                               FontSize="12" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
