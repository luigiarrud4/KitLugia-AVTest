<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="KitLugia.GUI.Pages.PartitionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:converters="clr-namespace:KitLugia.GUI.Converters"
      mc:Ignorable="d" 
      d:DesignHeight="750" d:DesignWidth="1050"
      Title="Gerenciador de Discos">
    
    <Page.Resources>
        <converters:StarWidthConverter x:Key="StarWidthConverter"/>
        <converters:StringToColorConverter x:Key="StringToColorConverter"/>

        <!-- ESTILO CORRIGIDO PARA COMBOBOX ESCURO -->
        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="{x:Type ToggleButton}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="30" />
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" CornerRadius="4" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" />
                <Path x:Name="Arrow" Grid.Column="1" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M0,0 L4,4 L8,0" IsHitTestVisible="False"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#333333" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="DarkComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton Name="ToggleButton" Template="{StaticResource ComboBoxToggleButton}" Grid.Column="2" Focusable="false" IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"/>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="10,0,30,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#1A1A1A" BorderThickness="1" BorderBrush="#444444"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ANIMAÇÕES CORRIGIDAS (Loop Suave) -->
        <Storyboard x:Key="LivePulseStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1.0" To="0.2" Duration="0:0:0.8" AutoReverse="True" RepeatBehavior="Forever" />
        </Storyboard>

        <!-- CORREÇÃO MATEMÁTICA: To="-24" (Múltiplo de 8 para loop perfeito) -->
        <Storyboard x:Key="MarchingAntsRightStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="StrokeDashOffset" From="0" To="-24" Duration="0:0:1" RepeatBehavior="Forever" />
        </Storyboard>

        <Storyboard x:Key="MarchingAntsLeftStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="StrokeDashOffset" From="0" To="24" Duration="0:0:1" RepeatBehavior="Forever" />
        </Storyboard>

        <Storyboard x:Key="GlowPulseStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.4" To="1.0" Duration="0:0:1" AutoReverse="True" RepeatBehavior="Forever" />
        </Storyboard>

        <Storyboard x:Key="MonitorDotStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1.0" To="0.4" Duration="0:0:1.2" AutoReverse="True" RepeatBehavior="Forever" />
        </Storyboard>
    </Page.Resources>

    <Grid Margin="25,20,25,15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="*"/>     <!-- Main -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="GERENCIADOR DE PARTIÇÕES" FontSize="26" FontWeight="ExtraBold" Foreground="{StaticResource AccentColor}"/>
                <TextBlock Text="Visualize e gerencie seus discos e volumes com facilidade e segurança." Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,2,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="🔃 ATUALIZAR" Click="BtnRefresh_Click" Style="{StaticResource SecondaryButtonStyle}" Width="120" Height="36" FontSize="12" Margin="0,0,8,0" FontWeight="Bold"/>
                <Button Content="↩ Voltar" Click="BtnBack_Click" Style="{StaticResource SecondaryButtonStyle}" Width="85" Height="32" FontSize="12" BorderBrush="Transparent" Foreground="{StaticResource TextMuted}"/>
            </StackPanel>
        </Grid>

        <!-- ═══ MAIN CONTENT ═══ -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>    <!-- Disk Selection & Map -->
                <RowDefinition Height="*"/>       <!-- Table & Actions -->
            </Grid.RowDefinitions>

            <!-- TOP: DISK VISUAL MAP -->
            <Border Grid.Row="0" Style="{StaticResource SubtleCardStyle}" Padding="20,15" Margin="0,0,0,15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Info -->
                        <RowDefinition Height="Auto"/>  <!-- Bar -->
                        <RowDefinition Height="Auto"/>  <!-- Legend -->
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="DISCO ATUAL:" FontWeight="Bold" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,12,0" FontSize="11"/>
                        <ComboBox x:Name="CmbDisk" Grid.Column="1" Width="380" Height="34" FontSize="13" Style="{StaticResource DarkComboBoxStyle}" SelectionChanged="CmbDisk_SelectionChanged"/>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Orientation="Horizontal">
                           <Border x:Name="BdrLiveBadge" Background="#33FFD600" BorderBrush="#FFD600" BorderThickness="1" CornerRadius="4" Padding="6,2" Visibility="Collapsed" Margin="0,0,10,0">
                               <StackPanel Orientation="Horizontal">
                                   <Ellipse Width="6" Height="6" Fill="#FFD600" VerticalAlignment="Center" Margin="0,0,6,0">
                                       <Ellipse.Style>
                                           <Style TargetType="Ellipse">
                                               <Style.Triggers>
                                                   <EventTrigger RoutedEvent="Loaded">
                                                       <BeginStoryboard>
                                                           <Storyboard>
                                                               <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.2" Duration="0:0:0.8" AutoReverse="True" RepeatBehavior="Forever"/>
                                                           </Storyboard>
                                                       </BeginStoryboard>
                                                   </EventTrigger>
                                               </Style.Triggers>
                                           </Style>
                                       </Ellipse.Style>
                                   </Ellipse>
                                   <TextBlock Text="MONITORAMENTO LIVE" Foreground="#FFD600" FontSize="10" FontWeight="Bold"/>
                               </StackPanel>
                           </Border>
                           <TextBlock x:Name="TxtDiskInfo" Text="Select a disk..." Foreground="{StaticResource TextMuted}" FontSize="12"/>
                        </StackPanel>
                    </Grid>

                    <!-- Partition Bar Map -->
                    <Border Grid.Row="1" Background="#0A0A0A" BorderBrush="#333" BorderThickness="1" CornerRadius="8" Height="75" ClipToBounds="True" Margin="0,5,0,12">
                        <Grid x:Name="PanelPartBar"/>
                    </Border>

                    <!-- Legend -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Border Width="12" Height="12" Background="#2962FF" CornerRadius="2" Margin="0,0,6,0"/>
                        <TextBlock Text="Sistema" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,0,18,0"/>
                        <Border Width="12" Height="12" Background="#FFD600" CornerRadius="2" Margin="0,0,6,0"/>
                        <TextBlock Text="Winboot" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,0,18,0"/>
                        <Border Width="12" Height="12" Background="#00C853" CornerRadius="2" Margin="0,0,6,0"/>
                        <TextBlock Text="Dados" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,0,18,0"/>
                        <Border Width="12" Height="12" Background="#37474F" CornerRadius="2" Margin="0,0,6,0"/>
                        <TextBlock Text="Não Alocado" FontSize="11" Foreground="{StaticResource TextMuted}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ BOTTOM: TABLE + SIDEBAR ═══ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="230"/>
                </Grid.ColumnDefinitions>

                <!-- Partition Table -->
                <Border Style="{StaticResource SubtleCardStyle}" Padding="2" Margin="0,0,15,0">
                    <DataGrid x:Name="GridPartitions"
                              AutoGenerateColumns="False"
                              Background="Transparent"
                              BorderThickness="0"
                              Foreground="White"
                              RowBackground="Transparent"
                              AlternatingRowBackground="#05FFFFFF"
                              GridLinesVisibility="None"
                              CanUserAddRows="False"
                              CanUserResizeRows="False"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="True"
                              SelectionMode="Extended"
                              SelectionChanged="GridPartitions_SelectionChanged"
                              FontSize="13"
                              VirtualizingStackPanel.IsVirtualizing="True"
                              VirtualizingStackPanel.VirtualizationMode="Recycling"
                              EnableRowVirtualization="True">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#111"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
                                <Setter Property="Padding" Value="12,10"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#333"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridColumnHeader">
                                            <Grid>
                                                <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="12,0">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ContentPresenter Grid.Column="0" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                                                        <Path x:Name="SortArrow" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="8" Height="6" Margin="5,0,0,0" Stretch="Fill" Fill="{StaticResource AccentColor}" RenderTransformOrigin="0.5,0.5" Visibility="Collapsed" Data="M0,0 L10,0 L5,10 z"/>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#1A1A1A"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                                <Trigger Property="SortDirection" Value="Ascending">
                                                    <Setter TargetName="SortArrow" Property="Visibility" Value="Visible" />
                                                    <Setter TargetName="SortArrow" Property="RenderTransform">
                                                        <Setter.Value>
                                                            <RotateTransform Angle="180" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                                <Trigger Property="SortDirection" Value="Descending">
                                                    <Setter TargetName="SortArrow" Property="Visibility" Value="Visible" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="12,8"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            </Style>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Height" Value="42"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#1AD4AF37"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="40">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Icon}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="LETRA" Binding="{Binding DriveLetter, Mode=OneWay}" Width="60" FontWeight="Bold"/>
                            <DataGridTextColumn Header="SISTEMA" Binding="{Binding FileSystem, Mode=OneWay}" Width="100"/>
                            <DataGridTemplateColumn Header="USO (%)" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid Margin="10,0" VerticalAlignment="Center" Height="20">
                                            <Border Background="#1AFFFFFF" CornerRadius="10" BorderBrush="#33FFFFFF" BorderThickness="1"/>
                                            <Grid Margin="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="{Binding UsedPercent, Converter={StaticResource StarWidthConverter}, FallbackValue=*}" />
                                                    <ColumnDefinition Width="{Binding FreePercent, Converter={StaticResource StarWidthConverter}, FallbackValue=*}" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" CornerRadius="8">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#CCFFFFFF" Offset="0.0"/>
                                                            <GradientStop Color="{Binding BarColor, Converter={StaticResource StringToColorConverter}}" Offset="0.3"/>
                                                            <GradientStop Color="{Binding BarColor, Converter={StaticResource StringToColorConverter}}" Offset="0.7"/>
                                                            <GradientStop Color="#44000000" Offset="1.0"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="{Binding BarColor, Converter={StaticResource StringToColorConverter}}" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                                                    </Border.Effect>
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="{Binding UsedPercentText}" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold" IsHitTestVisible="False"/>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="ESPAÇO LIVRE" Binding="{Binding FreeSpaceString, Mode=OneWay}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="TAMANHO" Binding="{Binding SizeString, Mode=OneWay}" Width="100" FontWeight="Bold"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Sidebar Actions -->
                <Border Grid.Column="1" Style="{StaticResource SubtleCardStyle}" Padding="15">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="AÇÕES" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentColor}" Margin="0,0,0,15"/>
                            
                            <!-- Monitoramento Automático -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <CheckBox x:Name="ChkAutoRefresh" Content="Atualização automática (10s)" IsChecked="True" Foreground="{StaticResource TextPrimary}" FontSize="12"/>
                                <TextBlock Text="🔄" FontSize="14" Margin="5,2,0,0" Foreground="{StaticResource AccentColor}"/>
                            </StackPanel>
                            
                            <!-- Partition Specific -->
                            <Button x:Name="BtnFormat" Content="🔳 FORMATAR / CRIAR" Click="BtnFormat_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,8" Height="36" IsEnabled="False"/>
                            <Button x:Name="BtnResize" Content="📐 REDUZIR TAMANHO" Click="BtnResize_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,8" Height="36" IsEnabled="False"/>
                            <Button x:Name="BtnMove" Content="↔️ MOVER" Click="BtnMove_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,8" Height="36" IsEnabled="False" ToolTip="Move a partição para o lado do espaço não alocado (usa DISM Imaging)"/>
                            <Button x:Name="BtnExtend" Content="🚀 ESTENDER VOLUME" Click="BtnExtend_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,8" Height="36" IsEnabled="False"/>
                            <Button x:Name="BtnDelete" Content="❌ DELETAR" Click="BtnDelete_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,8" Height="36" IsEnabled="False"/>
                            <Button x:Name="BtnAssignLetter" Content="🔠 ALTERAR LETRA" Click="BtnAssignLetter_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,8" Height="36" IsEnabled="False"/>
                            <Button x:Name="BtnCheckFS" Content="🛡️ VERIFICAR ERROS" Click="BtnCheckFS_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,8" Height="36" IsEnabled="False"/>
                            <Button x:Name="BtnSetActive" Content="🏁 MARCAR ATIVA" Click="BtnSetActive_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,15" Height="36" IsEnabled="False" Visibility="Collapsed"/>

                            <Separator Background="#222" Margin="0,5,0,15"/>

                            <!-- Disk Level -->
                            <TextBlock Text="DISCO" FontSize="12" FontWeight="Bold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,10"/>
                            <Button x:Name="BtnCleanDisk" Content="🧹 LIMPAR DISCO" Click="BtnCleanDisk_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,8" Height="36" BorderBrush="#44FF0000" Foreground="#FFFF5555"/>
                            <Button x:Name="BtnConvert" Content="🔄 CONVERTER GPT/MBR" Click="BtnConvert_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,8" Height="36"/>
                            <Button x:Name="BtnDiskDetail" Content="📄 DETALHES DO DISCO" Click="BtnDiskDetail_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,15" Height="36"/>

                            <Border Background="#11D4AF37" BorderBrush="#33D4AF37" BorderThickness="1" CornerRadius="8" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="💡 Dica de Segurança" Foreground="{StaticResource AccentColor}" FontWeight="Bold" FontSize="12" Margin="0,0,0,4"/>
                                    <TextBlock Text="Partições críticas (C:, EFI, Recuperação) são protegidas contra formatação e exclusão acidental." 
                                              Foreground="{StaticResource TextMuted}" FontSize="10" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <!-- ═══ STATUS BAR ═══ -->
        <Border Grid.Row="2" Margin="0,10,0,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse x:Name="DotLiveMonitor" Width="8" Height="8" Fill="#FF0000" Margin="0,0,10,0" Opacity="0" Visibility="Collapsed"/>
                    <TextBlock x:Name="TxtStatusBar" Text="Pronto" Foreground="#888" FontSize="11"/>
                </StackPanel>
        </Border>

        <!-- ═══ ACTION OVERLAY (EaseUS Style) ═══ -->
        <Grid x:Name="OverlayAction" Grid.RowSpan="3" Background="#EE000000" Visibility="Collapsed" Margin="-25,-20,-25,-15">
            <Border Background="{StaticResource CardBackground}" BorderBrush="{StaticResource AccentColor}" BorderThickness="1" CornerRadius="15" 
                    Width="600" MaxHeight="550" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30" Effect="{DynamicResource DropShadowEffect}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Title -->
                    <TextBlock Grid.Row="0" x:Name="TxtOpTitle" Text="EXECUTANDO OPERAÇÃO" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentColor}" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                    
                    <!-- Scrollable Content Area -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="380" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock x:Name="TxtOpDesc" Text="Aguarde enquanto as alterações são aplicadas..." Foreground="White" FontSize="13" FontFamily="Consolas" Margin="0,0,0,15" TextWrapping="Wrap"/>
                        
                            <!-- Progress Section -->
                            <Grid x:Name="PanelProgress" Margin="0,0,0,15">
                                <ProgressBar x:Name="ProgOp" IsIndeterminate="True" Height="6" Foreground="{StaticResource AccentColor}" Background="#1A1A1A" BorderThickness="0" Minimum="0" Maximum="100"/>
                            </Grid>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <!-- Rotating Processing Icon -->
                                <TextBlock Text="⚙️" Foreground="{StaticResource AccentColor}" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform x:Name="RotationTransform" Angle="0"/>
                                    </TextBlock.RenderTransform>
                                    <TextBlock.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="RotationTransform" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:2" RepeatBehavior="Forever"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </TextBlock.Triggers>
                                </TextBlock>
                                <TextBlock x:Name="TxtOpStatus" Text="Status: Processando..." Foreground="{StaticResource TextMuted}" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </StackPanel>

                            <!-- Safety Warning -->
                            <Border x:Name="BdrSafetyWarning" Background="#22FF3D00" BorderBrush="#88FF3D00" BorderThickness="1" CornerRadius="8" Padding="15,10" Margin="0,0,0,10" Visibility="Visible">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="⚠️" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="AÇÃO CRÍTICA: NÃO FECHE O APP OU DESLIGUE O PC AGORA!" Foreground="#FFFF3D00" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Footer Buttons (Always at bottom, outside ScrollViewer) -->
                    <StackPanel Grid.Row="2" x:Name="PanelOpFooter" Orientation="Horizontal" HorizontalAlignment="Center" Visibility="Collapsed" Margin="0,5,0,0">
                        <Button Content="✅ FECHAR" Click="BtnCloseOverlay_Click" Style="{StaticResource GoldButtonStyle}" Width="180" Height="42" FontWeight="Bold" FontSize="14"/>
                    </StackPanel>

                    <!-- Live Aesthetic Log (Corner Pinned) -->
                    <StackPanel Grid.Row="2" x:Name="PanelLiveActivity" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="0,0,0,-20">
                        <!-- Pulsing Red Dot -->
                        <Ellipse Width="6" Height="6" Fill="#FFFF3D00" Margin="0,0,6,0" VerticalAlignment="Center">
                            <Ellipse.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard Storyboard="{StaticResource LivePulseStoryboard}"/>
                                </EventTrigger>
                            </Ellipse.Triggers>
                        </Ellipse>
                        <TextBlock x:Name="TxtLiveActivity" Text="..." Foreground="{StaticResource TextMuted}" FontSize="9" FontFamily="Consolas" 
                                   VerticalAlignment="Center" Opacity="0.5" TextTrimming="CharacterEllipsis" MaxWidth="350"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══ INPUT OVERLAY (Integrated Dialog) ═══ -->
        <Grid x:Name="OverlayInput" Grid.RowSpan="3" Background="#CC000000" Visibility="Collapsed" Margin="-25,-20,-25,-15">
            <Border Background="{StaticResource CardBackground}" BorderBrush="{StaticResource AccentColor}" BorderThickness="1" CornerRadius="15" 
                    Width="420" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="25" Effect="{StaticResource DropShadowEffect}">
                <StackPanel>
                    <TextBlock x:Name="TxtInputTitle" Text="ENTRADA DE DADOS" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentColor}" Margin="0,0,0,10"/>
                    <TextBlock x:Name="TxtInputMessage" Text="Por favor, insira o valor desejado:" Foreground="White" FontSize="14" Margin="0,0,0,20" TextWrapping="Wrap"/>
                    
                    <TextBox x:Name="TxtInputField" Style="{StaticResource DarkTextBoxStyle}" FontSize="16" Padding="12,10" Margin="0,0,0,25" KeyDown="TxtInputField_KeyDown"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="CANCELAR" Click="BtnCancelInput_Click" Style="{StaticResource SecondaryButtonStyle}" Width="110" Height="36" Margin="0,0,10,0"/>
                        <Button Content="CONFIRMAR" Click="BtnConfirmInput_Click" Style="{StaticResource GoldButtonStyle}" Width="130" Height="38"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══ EXTEND OVERLAY (EaseUS Style) ═══ -->
        <Grid x:Name="OverlayExtend" Grid.RowSpan="3" Background="#CC000000" Visibility="Collapsed" Margin="-25,-20,-25,-15">
            <Border Background="{StaticResource CardBackground}" BorderBrush="{StaticResource AccentColor}" BorderThickness="1" CornerRadius="15" 
                    Width="480" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="25" Effect="{StaticResource DropShadowEffect}">
                <StackPanel>
                    <TextBlock x:Name="TxtExtendTitle" Text="ESTENDER VOLUME" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentColor}" Margin="0,0,0,10"/>
                    
                    <Border Background="#11D4AF37" BorderThickness="0,0,0,1" BorderBrush="#33D4AF37" Padding="0,0,0,15" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Selecione de onde deseja extrair espaço para crescer esta partição." Foreground="{StaticResource TextMuted}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10"/>
                            <StackPanel x:Name="PanelExtendSources">
                                <RadioButton x:Name="RadioUnallocatedRight" Content="Espaço Não Alocado Adjacente" Foreground="White" IsChecked="True" GroupName="ExtendSource"/>
                                <RadioButton x:Name="RadioNeighborRight" Content="Puxar da Partição Vizinha" Foreground="White" GroupName="ExtendSource" Margin="0,8,0,0"/>
                                <CheckBox x:Name="ChkMergeMode" Content="Mesclar (DISM) - Melhor opção (Move tudo e usa 100%)" Foreground="{StaticResource AccentColor}" Margin="20,10,0,0" Visibility="Collapsed" IsChecked="True" ToolTip="Engine principal: DISM Imaging (tolerante a arquivos em uso / limitações do Windows). Fallback automático: Robocopy /B."/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="VALOR A ADICIONAR:" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtExtendMb" Style="{StaticResource DarkTextBoxStyle}" FontSize="16" Padding="12,10" Text="0"/>
                        <TextBlock Grid.Column="1" Text="MB" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{StaticResource TextMuted}"/>
                    </Grid>

                    <!-- Predefined Buttons -->
                    <UniformGrid Columns="4" Margin="0,0,0,25">
                        <Button Content="25%" Click="BtnExtendPercent_Click" Tag="25" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,5,0" Height="32"/>
                        <Button Content="50%" Click="BtnExtendPercent_Click" Tag="50" Style="{StaticResource SecondaryButtonStyle}" Margin="5,0,5,0" Height="32"/>
                        <Button Content="75%" Click="BtnExtendPercent_Click" Tag="75" Style="{StaticResource SecondaryButtonStyle}" Margin="5,0,5,0" Height="32"/>
                        <Button Content="MÁX." Click="BtnExtendMax_Click" Style="{StaticResource GoldButtonStyle}" Margin="5,0,0,0" Height="34" FontWeight="Bold"/>
                    </UniformGrid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="CANCELAR" Click="BtnCancelExtend_Click" Style="{StaticResource SecondaryButtonStyle}" Width="110" Height="38" Margin="0,0,10,0"/>
                        <Button Content="ESTENDER AGORA" Click="BtnConfirmExtend_Click" Style="{StaticResource GoldButtonStyle}" Width="160" Height="40" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ═══ SHRINK OVERLAY (EaseUS Style) ═══ -->
        <Grid x:Name="OverlayShrink" Grid.RowSpan="3" Background="#CC000000" Visibility="Collapsed" Margin="-25,-20,-25,-15">
            <Border Background="{StaticResource CardBackground}" BorderBrush="{StaticResource AccentColor}" BorderThickness="1" CornerRadius="15" 
                    Width="450" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="25" Effect="{StaticResource DropShadowEffect}">
                <StackPanel>
                    <TextBlock x:Name="TxtShrinkTitle" Text="REDUZIR TAMANHO" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentColor}" Margin="0,0,0,10"/>
                    
                    <Border Background="#11D4AF37" BorderThickness="0,0,0,1" BorderBrush="#33D4AF37" Padding="0,0,0,15" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="A partição será reduzida, liberando espaço não alocado no final." Foreground="{StaticResource TextMuted}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10"/>
                            <TextBlock x:Name="TxtMaxShrinkInfo" Text="Máximo reduzível: 0 MB" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock x:Name="TxtShrinkWarning" Text="⚠️ Mesmo offline, DiskPart tem limitações (tamanho mínimo do volume). Use valores conservadores." Foreground="#FFA500" FontSize="10" TextWrapping="Wrap" Margin="0,5,0,0" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="QUANTIDADE A RETIRAR:" FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,10"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtShrinkMb" Style="{StaticResource DarkTextBoxStyle}" FontSize="16" Padding="12,10" Text="0"/>
                        <TextBlock Grid.Column="1" Text="MB" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{StaticResource TextMuted}"/>
                    </Grid>

                    <!-- Predefined Buttons -->
                    <UniformGrid Columns="4" Margin="0,0,0,25">
                        <Button Content="25%" Click="BtnShrinkPercent_Click" Tag="25" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,5,0" Height="32"/>
                        <Button Content="50%" Click="BtnShrinkPercent_Click" Tag="50" Style="{StaticResource SecondaryButtonStyle}" Margin="5,0,5,0" Height="32"/>
                        <Button Content="75%" Click="BtnShrinkPercent_Click" Tag="75" Style="{StaticResource SecondaryButtonStyle}" Margin="5,0,5,0" Height="32"/>
                        <Button Content="MÁX." Click="BtnShrinkMax_Click" Style="{StaticResource GoldButtonStyle}" Margin="5,0,0,0" Height="34" FontWeight="Bold"/>
                    </UniformGrid>

                    <!-- Emergency Pre-Boot Option (WinRE) -->
                    <Border Background="#11FF3D00" BorderBrush="#33FF3D00" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,10,0,15">
                        <StackPanel>
                            <CheckBox x:Name="ChkEmergencyPreBoot" Content="🚨 Emergency Pre-Boot (WinRE + DISM)"
                                      Foreground="#FFFF5555" FontWeight="Bold" FontSize="13" Margin="0,0,0,8" Checked="ChkEmergencyPreBoot_Checked" Unchecked="ChkEmergencyPreBoot_Unchecked"/>
                            <TextBlock x:Name="TxtEmergencyWarning" Text="Usa WinRE modificado via DISM para reduzir sem as limitações do Windows. ⚠️ O sistema será REINICIADO automaticamente."
                                      Foreground="{StaticResource TextMuted}" FontSize="10" TextWrapping="Wrap" Margin="20,0,0,0" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="CANCELAR" Click="BtnCancelShrink_Click" Style="{StaticResource SecondaryButtonStyle}" Width="110" Height="38" Margin="0,0,10,0"/>
                        <Button Content="REDUZIR AGORA" Click="BtnConfirmShrink_Click" Style="{StaticResource GoldButtonStyle}" Width="160" Height="40" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
