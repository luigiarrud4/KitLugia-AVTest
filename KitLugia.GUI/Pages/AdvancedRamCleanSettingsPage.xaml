<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="KitLugia.GUI.Pages.AdvancedRamCleanSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Configura&#xE7;&#xF5;es Avan&#xE7;adas de Limpeza de RAM"
      TextElement.FontFamily="Segoe UI Variable Display, Segoe UI, Segoe UI Emoji, Segoe UI Symbol, Arial">
    
    <Page.Resources>
        <Style x:Key="AdvancedToggle" TargetType="CheckBox">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="toggleBorder" 
                                Background="#3E3E3E" 
                                CornerRadius="12"
                                BorderThickness="1"
                                BorderBrush="#505050">
                            <Ellipse x:Name="toggleCircle" 
                                     Width="14" Height="14"
                                     Fill="#BBBBBB"
                                     HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Margin="4,0">
                                <Ellipse.Effect>
                                    <DropShadowEffect ShadowDepth="1" BlurRadius="2" Opacity="0.3"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="toggleBorder" Property="Background" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="toggleBorder" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="toggleCircle" Property="Fill" Value="#101010"/>
                                <Setter TargetName="toggleCircle" Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="#E0000000">
        <Border Background="#1A1A1A" 
                CornerRadius="12" 
                BorderBrush="#333" 
                BorderThickness="1"
                MaxWidth="600"
                MaxHeight="700"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Padding="0">
            <Grid>
                <!-- Header com X para fechar -->
                <Grid Height="50" VerticalAlignment="Top">
                    <Border Background="#252525" CornerRadius="12,12,0,0">
                        <Grid Margin="15,0,0,0">
                            <TextBlock Text="&#x2699;&#xFE0F; CONFIGURA&#xC7;&#xD5;ES AVAN&#xC7;ADAS DE LIMPEZA DE RAM" 
                                       FontSize="16" 
                                       FontWeight="Bold" 
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource AccentColor}"/>
                            
                            <Button x:Name="BtnClose"
                                    Content="&#x2715;" 
                                    Width="36" Height="36"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,0,0"
                                    Background="Transparent" 
                                    Foreground="#888" 
                                    FontWeight="Bold" 
                                    FontSize="18"
                                    Cursor="Hand" 
                                    Click="BtnClose_Click"
                                    BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="18">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bdr" Property="Background" Value="#FF4444"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
                
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,50,0,0">
                    <StackPanel Margin="20">
            
            <!-- Se&#xE7;&#xE3;o: &#xC1;reas de Limpeza -->
            <Border Style="{StaticResource CardStyle}" Padding="15" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="&#xC1;REAS DE LIMPEZA" 
                               FontSize="12" 
                               FontWeight="Bold" 
                               Foreground="#666"
                               Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Selecione quais &#xE1;reas de mem&#xF3;ria limpar. Baseado no MemReduct." 
                               FontSize="11" 
                               Foreground="#888"
                               Margin="0,0,0,10"/>
                    
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Working Set (0x01)" FontWeight="SemiBold" FontSize="13" Foreground="White"/>
                            <TextBlock Text="Mem&#xF3;ria ativa dos processos em execu&#xE7;&#xE3;o. Limpar pode liberar mem&#xF3;ria mas pode afetar performance." FontSize="10" Foreground="#888" TextWrapping="Wrap"/>
                        </StackPanel>
                        <CheckBox x:Name="ChkWorkingSet" Grid.Column="1" Style="{StaticResource AdvancedToggle}" IsChecked="True"/>
                    </Grid>
                    
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="System File Cache (0x02)" FontWeight="SemiBold" FontSize="13" Foreground="White"/>
                            <TextBlock Text="Cache do sistema de arquivos. Limpar pode acelerar o sistema mas pode desacelerar leituras futuras." FontSize="10" Foreground="#888" TextWrapping="Wrap"/>
                        </StackPanel>
                        <CheckBox x:Name="ChkSystemFileCache" Grid.Column="1" Style="{StaticResource AdvancedToggle}" IsChecked="True"/>
                    </Grid>
                    
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Standby List (sem prioridade) (0x04)" FontWeight="SemiBold" FontSize="13" Foreground="White"/>
                            <TextBlock Text="P&#xE1;ginas em cache sem prioridade. Seguro de limpar, libera mem&#xF3;ria cacheada do sistema." FontSize="10" Foreground="#888" TextWrapping="Wrap"/>
                        </StackPanel>
                        <CheckBox x:Name="ChkStandbyPriority0" Grid.Column="1" Style="{StaticResource AdvancedToggle}" IsChecked="True"/>
                    </Grid>
                    
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Standby List (com prioridade) (0x08)" FontWeight="SemiBold" FontSize="13" Foreground="White"/>
                            <TextBlock Text="P&#xE1;ginas em cache com prioridade 0-7. Limpar pode liberar mais mem&#xF3;ria mas pode afetar apps em uso." FontSize="10" Foreground="#888" TextWrapping="Wrap"/>
                        </StackPanel>
                        <CheckBox x:Name="ChkStandbyList" Grid.Column="1" Style="{StaticResource AdvancedToggle}" IsChecked="False"/>
                    </Grid>
                    
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Modified Page List (0x10)" FontWeight="SemiBold" FontSize="13" Foreground="#D32F2F"/>
                            <TextBlock Text="&#x26A0;&#xFE0F; P&#xE1;ginas modificadas aguardando grava&#xE7;&#xE3;o em disco. PERIGOSO - pode causar travamentos e perda de dados." FontSize="10" Foreground="#D32F2F" TextWrapping="Wrap"/>
                        </StackPanel>
                        <CheckBox x:Name="ChkModifiedList" Grid.Column="1" Style="{StaticResource AdvancedToggle}" IsChecked="False"/>
                    </Grid>
                    
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Combine Memory Lists (0x20)" FontWeight="SemiBold" FontSize="13" Foreground="White"/>
                            <TextBlock Text="Combina listas de mem&#xF3;ria para limpeza mais eficiente. Apenas Windows 10+." FontSize="10" Foreground="#888" TextWrapping="Wrap"/>
                        </StackPanel>
                        <CheckBox x:Name="ChkCombineLists" Grid.Column="1" Style="{StaticResource AdvancedToggle}" IsChecked="True"/>
                    </Grid>
                    
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Registry Cache (0x40)" FontWeight="SemiBold" FontSize="13" Foreground="White"/>
                            <TextBlock Text="Cache do registro do Windows. Limpar pode liberar mem&#xF3;ria mas pode desacelerar opera&#xE7;&#xF5;es do registro." FontSize="10" Foreground="#888" TextWrapping="Wrap"/>
                        </StackPanel>
                        <CheckBox x:Name="ChkRegistryCache" Grid.Column="1" Style="{StaticResource AdvancedToggle}" IsChecked="True"/>
                    </Grid>
                    
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Modified File Cache (0x80)" FontWeight="SemiBold" FontSize="13" Foreground="White"/>
                            <TextBlock Text="Cache de arquivos modificados. Limpar libera mem&#xF3;ria mas pode desacelerar grava&#xE7;&#xF5;es futuras." FontSize="10" Foreground="#888" TextWrapping="Wrap"/>
                        </StackPanel>
                        <CheckBox x:Name="ChkModifiedFileCache" Grid.Column="1" Style="{StaticResource AdvancedToggle}" IsChecked="True"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Se&#xE7;&#xE3;o: Configura&#xE7;&#xF5;es de Limite -->
            <Border Style="{StaticResource CardStyle}" Padding="15" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="CONFIGURA&#xC7;&#xD5;ES DE LIMITE" 
                               FontSize="12" 
                               FontWeight="Bold" 
                               Foreground="#666"
                               Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Limite de Auto-Reduct (%)" FontSize="11" Foreground="#888" Margin="0,0,0,3"/>
                    <Grid Margin="0,0,0,10">
                        <Slider x:Name="SliderAutoReductLimit" Minimum="50" Maximum="95" Value="90" TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtAutoReductLimit" Text="90%" Foreground="{StaticResource AccentColor}" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,-20,0,0" FontSize="12"/>
                    </Grid>
                    
                    <TextBlock Text="Intervalo de Auto-Reduct (segundos)" FontSize="11" Foreground="#888" Margin="0,0,0,3"/>
                    <Grid Margin="0,0,0,10">
                        <Slider x:Name="SliderAutoReductInterval" Minimum="5" Maximum="120" Value="30" TickFrequency="5" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtAutoReductInterval" Text="30s" Foreground="{StaticResource AccentColor}" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,-20,0,0" FontSize="12"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Se&#xE7;&#xE3;o: N&#xED;veis de Alerta -->
            <Border Style="{StaticResource CardStyle}" Padding="15" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="N&#xCD;VEIS DE ALERTA" 
                               FontSize="12" 
                               FontWeight="Bold" 
                               Foreground="#666"
                               Margin="0,0,0,10"/>
                    
                    <TextBlock Text="N&#xED;vel de Aviso (%)" FontSize="11" Foreground="#888" Margin="0,0,0,3"/>
                    <Grid Margin="0,0,0,10">
                        <Slider x:Name="SliderWarningLevel" Minimum="50" Maximum="85" Value="70" TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtWarningLevel" Text="70%" Foreground="#FFA500" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,-20,0,0" FontSize="12"/>
                    </Grid>
                    
                    <TextBlock Text="N&#xED;vel de Perigo (%)" FontSize="11" Foreground="#888" Margin="0,0,0,3"/>
                    <Grid Margin="0,0,0,10">
                        <Slider x:Name="SliderDangerLevel" Minimum="70" Maximum="95" Value="90" TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtDangerLevel" Text="90%" Foreground="#D32F2F" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,-20,0,0" FontSize="12"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Se&#xE7;&#xE3;o: Presets -->
            <Border Style="{StaticResource CardStyle}" Padding="15" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="PRESETS" 
                               FontSize="12" 
                               FontWeight="Bold" 
                               Foreground="#666"
                               Margin="0,0,0,10"/>
                    
                    <Button Content="&#x1F504; Restaurar Padr&#xE3;o MemReduct" 
                            Height="38" 
                            Margin="0,0,0,8" 
                            Background="Transparent" 
                            Foreground="#888" 
                            FontWeight="SemiBold" 
                            FontSize="12"
                            Cursor="Hand" 
                            Click="BtnRestoreDefault_Click"
                            BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="6" BorderBrush="#444" BorderThickness="1">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bdr" Property="Background" Value="#15FFFFFF"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <Button Content="&#x26A0;&#xFE0F; Modo Agressivo (Mais Mem&#xF3;ria)" 
                            Height="38" 
                            Margin="0,0,0,0" 
                            Background="Transparent" 
                            Foreground="#D32F2F" 
                            FontWeight="SemiBold" 
                            FontSize="12"
                            Cursor="Hand" 
                            Click="BtnAggressiveMode_Click"
                            BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="6" BorderBrush="#D32F2F" BorderThickness="1">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bdr" Property="Background" Value="#15FFFFFF"/>
                                        <Setter Property="Foreground" Value="#D32F2F"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
            
            <!-- Bot&#xF5;es de A&#xE7;&#xE3;o -->
            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Button Content="&#x274C; CANCELAR" 
                        Grid.Column="0"
                        Height="42" 
                        Background="Transparent" 
                        Foreground="#888" 
                        FontWeight="Bold" 
                        FontSize="13"
                        Cursor="Hand" 
                        Click="BtnClose_Click"
                        BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="6" BorderBrush="#444" BorderThickness="1">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bdr" Property="Background" Value="#15FFFFFF"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
                <Button Content="&#x1F4BE; SALVAR" 
                        Grid.Column="2"
                        Height="42" 
                        Background="{StaticResource AccentColor}" 
                        Foreground="Black" 
                        FontWeight="Bold" 
                        FontSize="13"
                        Cursor="Hand" 
                        Click="BtnSave_Click"
                        BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bdr" Property="Opacity" Value="1"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="False">
                                    <Setter TargetName="bdr" Property="Opacity" Value="0.9"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
            
        </StackPanel>
    </ScrollViewer>
    </Grid>
    </Border>
    </Grid>
</Page>
