<Page x:Class="KitLugia.GUI.Pages.AllTweaksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Todos os Tweaks"
      TextElement.FontFamily="Segoe UI Variable Display, Segoe UI, Segoe UI Emoji, Segoe UI Symbol, Arial">

    <Grid Margin="35,25,35,25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITULO -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Todos os Tweaks" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}"/>
            <TextBlock x:Name="TxtSubtitle" Text="Navegue por todos os tweaks dispon&#xED;veis no sistema" FontSize="13" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- FILTROS -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="160"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1E1E1E" BorderBrush="#333" BorderThickness="1" CornerRadius="6" Padding="10,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#x1F50D;" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="TxtSearch" Grid.Column="1" Text="" Background="Transparent" BorderThickness="0" 
                             Foreground="White" FontSize="13" VerticalAlignment="Center"
                             TextChanged="TxtSearch_TextChanged">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <Button x:Name="BtnClearSearch" Grid.Column="2" Content="&#x2716;" Background="Transparent" 
                            BorderThickness="0" Foreground="#666" Cursor="Hand" Visibility="Collapsed"
                            Click="BtnClearSearch_Click" FontSize="12" Width="24" Height="24"/>
                </Grid>
            </Border>

            <TextBlock Grid.Column="1" x:Name="TxtCount" Text="0 tweaks" FontSize="12" 
                       Foreground="{StaticResource AccentColor}" VerticalAlignment="Center" FontWeight="SemiBold"/>

            <ComboBox x:Name="CmbCategory" Grid.Column="3" Height="32" SelectedIndex="0"
                      SelectionChanged="CmbCategory_SelectionChanged">
                <ComboBoxItem Content="Todas as Categorias" IsSelected="True" Foreground="White"/>
                <ComboBoxItem Content="Seguran&#xE7;a Cr&#xED;tica" Foreground="White"/>
                <ComboBoxItem Content="Defesa e Antiv&#xED;rus" Foreground="White"/>
                <ComboBoxItem Content="Restri&#xE7;&#xF5;es do Sistema" Foreground="White"/>
                <ComboBoxItem Content="Performance (CPU)" Foreground="White"/>
                <ComboBoxItem Content="Performance (Mem&#xF3;ria)" Foreground="White"/>
                <ComboBoxItem Content="Performance (GPU)" Foreground="White"/>
                <ComboBoxItem Content="Performance (Disco)" Foreground="White"/>
                <ComboBoxItem Content="Rede e Lat&#xEA;ncia" Foreground="White"/>
                <ComboBoxItem Content="Privacidade e Telemetria" Foreground="White"/>
                <ComboBoxItem Content="Explorer e Interface" Foreground="White"/>
                <ComboBoxItem Content="Servi&#xE7;os do Windows" Foreground="White"/>
                <ComboBoxItem Content="Energia e Suspens&#xE3;o" Foreground="White"/>
                <ComboBoxItem Content="Windows Update" Foreground="White"/>
                <ComboBoxItem Content="Outros" Foreground="White"/>
            </ComboBox>
        </Grid>

        <!-- LISTA DE TWEAKS -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ListTweaks">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#1A1A1A" BorderBrush="#2A2A2A" BorderThickness="1" 
                                CornerRadius="6" Padding="12,10" Margin="0,0,0,6"
                                Tag="{Binding Category}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Indicador de status (bolinha) -->
                                <Ellipse Grid.Column="0" Width="8" Height="8" 
                                         Fill="{Binding StatusColor}" 
                                         VerticalAlignment="Center" Margin="0,0,10,0"/>

                                <!-- Nome + Descri&#xE7;&#xE3;o + Fonte -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" 
                                                   Foreground="White" VerticalAlignment="Center"/>
                                        <Border Grid.Column="1" Background="#222" BorderBrush="#444" BorderThickness="1" 
                                                CornerRadius="3" Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Source}" FontSize="9" Foreground="#888"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{DynamicResource TextMuted}" 
                                               Margin="0,3,0,0" TextWrapping="Wrap" MaxHeight="40"/>
                                </StackPanel>

                                <!-- Toggle switch -->
                                <Border Grid.Column="2" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#333"/>
                                            <Setter Property="CornerRadius" Value="4"/>
                                            <Setter Property="Padding" Value="10,6"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                    <Setter Property="Background" Value="#1B5E20"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Button Content="{Binding ToggleLabel}" FontSize="11" FontWeight="Bold"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="{Binding ToggleForeground}"
                                            Cursor="Hand"
                                            Tag="{Binding .}"
                                            Click="BtnToggle_Click"
                                            MinWidth="55" Height="24"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
