<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="KitLugia.GUI.Pages.GameBoostPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Title="GameBoost Pro">

    <Page.Resources>
        <!-- ESTILO CORRIGIDO PARA COMBOBOX (baseado no PartitionsPage) -->
        <ControlTemplate x:Key="GameBoostComboBoxToggleButton" TargetType="{x:Type ToggleButton}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="30" />
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" CornerRadius="5" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" />
                <Path x:Name="Arrow" Grid.Column="1" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M0,0 L4,4 L8,0" IsHitTestVisible="False"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#333333" />
                    <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentColor}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="DarkComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#222222"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton Name="ToggleButton" Template="{StaticResource GameBoostComboBoxToggleButton}" Grid.Column="2" Focusable="false" IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Cursor="Hand"/>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="10,0,30,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide" StaysOpen="False">
                                <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#222222" BorderThickness="1" BorderBrush="#444444" CornerRadius="5"/>
                                    <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#222"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#333"/>
                    <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#444"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 🔥 ESTILO DO TOGGLE (copiado do SettingsPage) -->
        <Style x:Key="GoldToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="#444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="13"
                                BorderBrush="{StaticResource AccentColor}"
                                BorderThickness="1">
                            <Grid>
                                <Ellipse x:Name="ToggleCircle" 
                                         Width="20" Height="20"
                                         Fill="White"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center"
                                         Margin="3,0,0,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="ToggleCircle" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="ToggleCircle" Property="Margin" Value="0,0,3,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="30,20,30,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Header Fixo -->
                    <RowDefinition Height="Auto"/>  <!-- Card 1: Status Toggle -->
                    <RowDefinition Height="Auto"/>  <!-- Card 2: Configurações do Sistema -->
                    <RowDefinition Height="Auto"/>  <!-- Card 3: Comportamento ao Fechar -->
                    <RowDefinition Height="Auto"/>  <!-- Card 4: Motor Selection -->
                    <RowDefinition Height="Auto"/>  <!-- Conteúdo -->
                </Grid.RowDefinitions>
                
                <!-- HEADER FIXO -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text=" GameBoost Pro" FontSize="32" FontWeight="Bold" 
                               Foreground="{StaticResource AccentColor}" Margin="0,0,0,5">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#FFD700" BlurRadius="10" ShadowDepth="0" Opacity="0.4"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="Algoritmo Inteligente de Otimização de Processos - Inspirado no Process Lasso ProBalance" 
                               FontSize="13" Foreground="#888" Margin="0,0,0,15"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusIndicator" Width="20" Height="20" Fill="#00FF00" 
                             Stroke="#FFFFFF" StrokeThickness="2" Margin="0,0,15,0">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="#00FF00" BlurRadius="15" ShadowDepth="0" Opacity="0.8"/>
                        </Ellipse.Effect>
                    </Ellipse>
                </StackPanel>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="GameBoost Pro" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="TxtStatus" Text="Ativo e monitorando processos" FontSize="13" Foreground="#AAA"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <ToggleButton x:Name="TglGameBoost" Width="60" Height="30" 
                                  Checked="TglGameBoost_Checked" Unchecked="TglGameBoost_Unchecked">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="border" Background="#444" CornerRadius="15" BorderBrush="#666" BorderThickness="1">
                                    <Grid>
                                        <Ellipse x:Name="thumb" Fill="White" Width="24" Height="24" HorizontalAlignment="Left" Margin="2"/>
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="{StaticResource AccentColor}"/>
                                        <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 🔥 CARD 2: CONFIGURAÇÕES DO SISTEMA (FORA DO SCROLLVIEWER) -->
        <Border Grid.Row="2" Background="{StaticResource CardBackground}" CornerRadius="10" BorderBrush="{StaticResource CardBorder}" 
                BorderThickness="1" Padding="20" Margin="30,10,30,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="⚙️ Configurações do Sistema" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                    <TextBlock Text="Ícone de bandeja e inicialização automática" FontSize="12" Foreground="#AAA" TextWrapping="Wrap"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="MOSTRAR ÍCONE" Foreground="#AAA" FontSize="11" 
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ToggleButton x:Name="ChkTrayIcon" Style="{StaticResource GoldToggleStyle}"
                                      Checked="ChkTrayIcon_Click" Unchecked="ChkTrayIcon_Click"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="INICIAR COM WINDOWS" Foreground="#AAA" FontSize="11" 
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <ToggleButton x:Name="ChkStartWithWindows" Style="{StaticResource GoldToggleStyle}"
                                      Checked="ChkStartWithWindows_Click" Unchecked="ChkStartWithWindows_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- CARD 3: COMPORTAMENTO AO FECHAR -->
        <Border Grid.Row="3" Background="{StaticResource CardBackground}" CornerRadius="10" BorderBrush="{StaticResource CardBorder}" 
                BorderThickness="1" Padding="20" Margin="30,10,30,15">
            <StackPanel>
                <TextBlock Text="COMPORTAMENTO AO FECHAR" Foreground="#666" FontSize="12" FontWeight="Bold" Margin="0,0,0,15"/>
                
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Rodar em segundo plano" FontWeight="SemiBold" FontSize="13" Foreground="White"/>
                        <TextBlock Text="Minimiza ao clicar no X (mantém ativo)" FontSize="11" Foreground="#888"/>
                    </StackPanel>
                    <ToggleButton x:Name="ChkCloseToTray" Grid.Column="1" Style="{StaticResource GoldToggleStyle}"
                                  Checked="ChkCloseToTray_Click" Unchecked="ChkCloseToTray_Click"/>
                </Grid>
                
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="ProBalance" FontWeight="SemiBold" FontSize="13" Foreground="White"/>
                        <TextBlock Text="Gerenciamento de processos background" FontSize="11" Foreground="#888"/>
                        <TextBlock Text="⚠️ Instável - Em testes. Se tiver problemas, desative imediatamente." 
                                   FontSize="13" Foreground="#FF6B6B" Margin="0,3,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtProBalanceStatus" Grid.Column="1" Text="ATIVADO" 
                               FontSize="11" FontWeight="Bold" 
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ToggleButton x:Name="ChkProBalance" Grid.Column="2" Style="{StaticResource GoldToggleStyle}"
                                  Checked="ChkProBalance_Click" Unchecked="ChkProBalance_Click"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- 🔥 CARD 4: SELEÇÃO DE MOTOR (FORA DO SCROLLVIEWER) -->
        <Border Grid.Row="4" Background="{StaticResource CardBackground}" CornerRadius="10" BorderBrush="{StaticResource CardBorder}" 
                BorderThickness="1" Padding="20" Margin="30,0,30,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="🎮 Motor do GameBoost" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                    <TextBlock x:Name="TxtEngineDescription" 
                               Text="🟢 V1 - ORIGINAL: Mesmo comportamento da versão antiga (PADRÃO) - Seguro e estável" 
                               FontSize="12" Foreground="#AAA" Margin="0,5,0,0" TextWrapping="Wrap"/>
                </StackPanel>
                
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                    <ComboBox x:Name="CmbEngine" Width="220" Height="38" FontSize="13"
                              MaxDropDownHeight="150"
                              IsEnabled="True"
                              IsHitTestVisible="True"
                              Focusable="True"
                              SelectionChanged="CmbEngine_SelectionChanged"
                              Style="{StaticResource DarkComboBoxStyle}"
                              ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"
                              Cursor="Hand">
                        <ComboBoxItem Content="🟢 V1 - ORIGINAL (Balanceado)" Tag="1" IsSelected="True"/>
                        <ComboBoxItem Content="🟡 V2 - FPS Estável" Tag="2"/>
                        <ComboBoxItem Content="🔴 V3 - Extremo (Rede+)" Tag="3"/>
                        <ComboBoxItem Content="⚙️ Personalizado..." Tag="custom"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTEÚDO -->
        <StackPanel Grid.Row="5" Margin="30,0,30,30">

            <!-- ALGORITMO INFO -->
            <TextBlock Text="⚙️ Algoritmo ProBalance Style" FontSize="18" FontWeight="Bold" 
                       Foreground="White" Margin="0,0,0,15"/>
            
            <Grid Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- CARD 1 -->
                <Border Grid.Column="0" Background="{StaticResource CardBackground}" CornerRadius="8" 
                        BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Padding="20" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="🔺" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Foreground Boost" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentColor}"
                                   TextAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock Text="App ativo recebe prioridade High automaticamente" FontSize="11" Foreground="#888"
                                   TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                
                <!-- CARD 2 -->
                <Border Grid.Column="1" Background="{StaticResource CardBackground}" CornerRadius="8" 
                        BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Padding="20" Margin="5,0,5,0">
                    <StackPanel>
                        <TextBlock Text="🔻" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Background Throttle" FontSize="14" FontWeight="Bold" Foreground="#FF6B6B"
                                   TextAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock Text="Processos background CPU-intensive são reduzidos (Below Normal)" FontSize="11" Foreground="#888"
                                   TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                
                <!-- CARD 3 -->
                <Border Grid.Column="2" Background="{StaticResource CardBackground}" CornerRadius="8" 
                        BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Padding="20" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="⚡" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Otimizações Avançadas" FontSize="14" FontWeight="Bold" Foreground="#4ECDC4"
                                   TextAlignment="Center" Margin="0,0,0,5"/>
                        <TextBlock Text="EcoQoS + Thread Memory Priority + Timer Resolution (0.5ms)" FontSize="11" Foreground="#888"
                                   TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- PROCESSOS MONITORADOS -->
            <Border Background="{StaticResource CardBackground}" CornerRadius="10" BorderBrush="{StaticResource CardBorder}" 
                    BorderThickness="1" Padding="25" Margin="0,0,0,20">
                <StackPanel>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="📊 Processos em Tempo Real" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                            <TextBlock Text="Monitoramento de CPU e prioridade de processos ativos" FontSize="12" Foreground="#888"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="🔄 Atualizar" Click="BtnRefresh_Click" 
                                Width="100" Height="32" FontSize="11" FontWeight="SemiBold"
                                Background="#2D2D2D" Foreground="White" BorderBrush="#444" BorderThickness="1"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3D3D3D"/>
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                    
                    <!-- Header da Tabela -->
                    <Border Background="#1E1E1E" CornerRadius="6" Padding="12,8" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Processo" FontWeight="SemiBold" Foreground="#AAA" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="PID" FontWeight="SemiBold" Foreground="#AAA" FontSize="11" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="CPU %" FontWeight="SemiBold" Foreground="#AAA" FontSize="11" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="Prioridade" FontWeight="SemiBold" Foreground="#AAA" FontSize="11" HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>
                    
                    <ListView x:Name="LstProcesses" Background="Transparent" BorderThickness="0" 
                              ScrollViewer.VerticalScrollBarVisibility="Auto" MaxHeight="300"
                              MouseRightButtonUp="LstProcesses_MouseRightButtonUp">
                        <ListView.ContextMenu>
                            <ContextMenu x:Name="ProcessContextMenu">
                                <MenuItem x:Name="MenuSetHigh" Header="🔺 Definir como High" Click="MenuSetHigh_Click"/>
                                <MenuItem x:Name="MenuSetNormal" Header="⚪ Definir como Normal" Click="MenuSetNormal_Click"/>
                                <MenuItem x:Name="MenuSetLow" Header="🔻 Definir como Below Normal" Click="MenuSetLow_Click"/>
                                <Separator/>
                                <MenuItem x:Name="MenuAddException" Header="⭐ Adicionar às Exceções" Click="MenuAddException_Click"/>
                                <MenuItem x:Name="MenuRemoveException" Header="❌ Remover das Exceções" Click="MenuRemoveException_Click"/>
                                <Separator/>
                                <MenuItem x:Name="MenuRefresh" Header="🔄 Atualizar Lista" Click="BtnRefresh_Click"/>
                            </ContextMenu>
                        </ListView.ContextMenu>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#252525" CornerRadius="6" Padding="12,8" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="White" FontSize="11" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Pid}" Foreground="#888" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding CpuUsage}" Foreground="{Binding CpuColor}" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <Border Grid.Column="3" Background="{Binding PriorityColor}" CornerRadius="4" Padding="6,3"
                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Priority}" Foreground="White" FontSize="9" FontWeight="Bold"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <!-- ESTATÍSTICAS -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" Background="{StaticResource CardBackground}" CornerRadius="8" 
                        BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Padding="15" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock x:Name="TxtTotalBoosted" Text="0" FontSize="24" FontWeight="Bold" 
                                   Foreground="{StaticResource AccentColor}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Apps Otimizados" FontSize="11" Foreground="#888" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="1" Background="{StaticResource CardBackground}" CornerRadius="8" 
                        BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Padding="15" Margin="4,0,4,0">
                    <StackPanel>
                        <TextBlock x:Name="TxtThrottled" Text="0" FontSize="24" FontWeight="Bold" 
                                   Foreground="#FF6B6B" HorizontalAlignment="Center"/>
                        <TextBlock Text="Processos Reduzidos" FontSize="11" Foreground="#888" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="2" Background="{StaticResource CardBackground}" CornerRadius="8" 
                        BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Padding="15" Margin="4,0,4,0">
                    <StackPanel>
                        <TextBlock x:Name="TxtActiveForeground" Text="-" FontSize="24" FontWeight="Bold" 
                                   Foreground="#4ECDC4" HorizontalAlignment="Center"/>
                        <TextBlock Text="App em Foco" FontSize="11" Foreground="#888" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="3" Background="{StaticResource CardBackground}" CornerRadius="8" 
                        BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Padding="15" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock x:Name="TxtAvgResponse" Text="0ms" FontSize="24" FontWeight="Bold" 
                                   Foreground="#00FF00" HorizontalAlignment="Center"/>
                        <TextBlock Text="Tempo de Resposta" FontSize="11" Foreground="#888" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- BOTÕES DE AÇÃO -->
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                <Button x:Name="BtnRefresh" Content="🔄 Atualizar Lista" Click="BtnRefresh_Click"
                        Style="{StaticResource GoldButtonStyle}" Width="150" Height="40" Margin="0,0,10,0"/>
            </StackPanel>

            <!-- FOOTER INFO -->
            <TextBlock Text="💡 GameBoost Pro usa o algoritmo ProBalance (estilo Process Lasso): aumenta prioridade do app ativo e reduz processos background CPU-intensive" 
                       FontSize="11" Foreground="#666" TextWrapping="Wrap" Margin="0,30,0,0" TextAlignment="Center"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>

    <!-- 🔥 OVERLAY: Configuração de Motor Personalizado -->
    <Grid x:Name="OverlayCustomMotor" Visibility="Collapsed" Panel.ZIndex="1000">
        <Grid Background="#CC000000"/>
        <Border Width="550" Height="650" Background="#1E1E1E" BorderBrush="#D4AF37" BorderThickness="2" 
                CornerRadius="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="⚙️ Configurar Motor Personalizado" FontSize="20" FontWeight="Bold" 
                                   Foreground="#D4AF37" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                        
                        <!-- Nome do Perfil -->
                        <TextBlock Text="Nome do Perfil:" Foreground="#DDD" Margin="0,0,0,5"/>
                        <TextBox x:Name="TxtCustomProfileName" Text="Meu Motor Personalizado" 
                                 Background="#2D2D2D" Foreground="White" BorderBrush="#555" 
                                 Padding="8" Margin="0,0,0,15"/>
                        
                        <!-- CPU Priority -->
                        <TextBlock Text="🎯 Prioridade da CPU:" Foreground="#DDD" Margin="0,0,0,5"/>
                        <TextBlock Text="Define a prioridade de processamento para o jogo em primeiro plano" 
                                   FontSize="11" Foreground="#888" Margin="0,0,0,5"/>
                        <ComboBox x:Name="CmbCpuPriority" SelectedIndex="1" 
                                  Style="{StaticResource DarkComboBoxStyle}" Margin="0,0,0,15">
                            <ComboBoxItem Content="Normal (Padrão do Windows)" Background="#2D2D2D" Foreground="White"/>
                            <ComboBoxItem Content="High (Recomendado para games)" Background="#2D2D2D" Foreground="White"/>
                            <ComboBoxItem Content="RealTime (Máxima prioridade - CUIDADO)" Background="#2D2D2D" Foreground="White"/>
                        </ComboBox>
                        
                        <!-- I/O Priority -->
                        <TextBlock Text="💾 Prioridade de I/O (Disco):" Foreground="#DDD" Margin="0,0,0,5"/>
                        <TextBlock Text="Controla a velocidade de acesso ao disco/SSD" 
                                   FontSize="11" Foreground="#888" Margin="0,0,0,5"/>
                        <ComboBox x:Name="CmbIoPriority" SelectedIndex="1" 
                                  Style="{StaticResource DarkComboBoxStyle}" Margin="0,0,0,15">
                            <ComboBoxItem Content="Normal (Prioridade padrão)" Background="#2D2D2D" Foreground="White"/>
                            <ComboBoxItem Content="High (Prioridade alta para carregamentos)" Background="#2D2D2D" Foreground="White"/>
                            <ComboBoxItem Content="Critical (Máxima - use com cautela)" Background="#2D2D2D" Foreground="White"/>
                        </ComboBox>
                        
                        <!-- Page Priority -->
                        <TextBlock Text="📄 Page Priority (Memória Virtual):" Foreground="#DDD" Margin="0,0,0,5"/>
                        <TextBlock Text="Prioridade de memória virtual quando há pouca RAM" 
                                   FontSize="11" Foreground="#888" Margin="0,0,0,5"/>
                        <ComboBox x:Name="CmbPagePriority" SelectedIndex="1" 
                                  Style="{StaticResource DarkComboBoxStyle}" Margin="0,0,0,15">
                            <ComboBoxItem Content="Normal (Swap padrão)" Background="#2D2D2D" Foreground="White"/>
                            <ComboBoxItem Content="Maximum (Mínimo swap, máxima performance)" Background="#2D2D2D" Foreground="White"/>
                        </ComboBox>
                        
                        <!-- Thread Memory Priority -->
                        <TextBlock Text="🧵 Thread Memory Priority:" Foreground="#DDD" Margin="0,0,0,5"/>
                        <TextBlock Text="Prioridade de memória para threads do processo" 
                                   FontSize="11" Foreground="#888" Margin="0,0,0,5"/>
                        <ComboBox x:Name="CmbThreadMemory" SelectedIndex="0" 
                                  Style="{StaticResource DarkComboBoxStyle}" Margin="0,0,0,15">
                            <ComboBoxItem Content="Normal (Balanceado)" Background="#2D2D2D" Foreground="White"/>
                            <ComboBoxItem Content="Maximum (Máxima performance de threads)" Background="#2D2D2D" Foreground="White"/>
                        </ComboBox>
                        
                        <!-- Toggles Grid -->
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Timer Resolution -->
                            <Border Grid.Column="0" Grid.Row="0" Margin="0,0,10,10" Background="#2D2D2D" CornerRadius="8" Padding="10">
                                <StackPanel>
                                    <ToggleButton x:Name="TglTimerResolution" 
                                                  Checked="ToggleButton_Checked" Unchecked="ToggleButton_Unchecked"
                                                  Background="#444" Foreground="#DDD" Padding="8,12" FontSize="11"
                                                  IsChecked="False" HorizontalContentAlignment="Center"
                                                  BorderBrush="#555" BorderThickness="1"/>
                                    <TextBlock x:Name="TxtTimerResolutionStatus" Text="⏱️ Timer Resolution - DESATIVADO" 
                                               FontSize="10" Foreground="#FF6B6B" TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                    <TextBlock Text="Melhora precisão de timers (para games que precisam)" 
                                               FontSize="9" Foreground="#888" TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- EcoQoS -->
                            <Border Grid.Column="1" Grid.Row="0" Margin="10,0,0,10" Background="#2D2D2D" CornerRadius="8" Padding="10">
                                <StackPanel>
                                    <ToggleButton x:Name="TglEcoQoS" 
                                                  Checked="ToggleButton_Checked" Unchecked="ToggleButton_Unchecked"
                                                  Background="#444" Foreground="#DDD" Padding="8,12" FontSize="11"
                                                  IsChecked="False" HorizontalContentAlignment="Center"
                                                  BorderBrush="#555" BorderThickness="1"/>
                                    <TextBlock x:Name="TxtEcoQoSStatus" Text="🌱 EcoQoS - DESATIVADO" 
                                               FontSize="10" Foreground="#FF6B6B" TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                    <TextBlock Text="Windows 11+ Remove limitador de energia em notebooks!" 
                                               FontSize="9" Foreground="#D4AF37" TextWrapping="Wrap" TextAlignment="Center" FontWeight="Bold" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Network Boost -->
                            <Border Grid.Column="0" Grid.Row="1" Margin="0,0,10,0" Background="#2D2D2D" CornerRadius="8" Padding="10">
                                <StackPanel>
                                    <ToggleButton x:Name="TglNetworkBoost" 
                                                  Checked="ToggleButton_Checked" Unchecked="ToggleButton_Unchecked"
                                                  Background="#444" Foreground="#DDD" Padding="8,12" FontSize="11"
                                                  IsChecked="False" HorizontalContentAlignment="Center"
                                                  BorderBrush="#555" BorderThickness="1"/>
                                    <TextBlock x:Name="TxtNetworkBoostStatus" Text="🌐 Network Boost - DESATIVADO" 
                                               FontSize="10" Foreground="#FF6B6B" TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                    <TextBlock Text="Prioridade de pacotes de rede (experimental)" 
                                               FontSize="9" Foreground="#888" TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- ProBalance -->
                            <Border Grid.Column="1" Grid.Row="1" Margin="10,0,0,0" Background="#2D2D2D" CornerRadius="8" Padding="10">
                                <StackPanel>
                                    <ToggleButton x:Name="TglProBalance" 
                                                  Checked="ToggleButton_Checked" Unchecked="ToggleButton_Unchecked"
                                                  Background="#444" Foreground="#DDD" Padding="8,12" FontSize="11"
                                                  IsChecked="True" HorizontalContentAlignment="Center"
                                                  BorderBrush="#555" BorderThickness="1"/>
                                    <TextBlock x:Name="TxtProBalanceStatusCustom" Text="⚖️ ProBalance - ATIVADO" 
                                               FontSize="10" Foreground="#4ECDC4" TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                    <TextBlock Text="Reduz prioridade de processos em background" 
                                               FontSize="9" Foreground="#888" TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        
                        <!-- ProBalance Threshold -->
                        <StackPanel Margin="0,15,0,0" IsEnabled="{Binding ElementName=TglProBalance, Path=IsChecked}">
                            <TextBlock Text="📊 ProBalance Threshold (% CPU):" Foreground="#DDD" Margin="0,0,0,5"/>
                            <TextBlock Text="Processos background com mais que esta % de CPU serão reduzidos" 
                                       FontSize="11" Foreground="#888" Margin="0,0,0,5"/>
                            <Slider x:Name="SliderProBalance" Minimum="1" Maximum="30" Value="5" 
                                    TickFrequency="1" IsSnapToTickEnabled="True" 
                                    Background="#2D2D2D" Foreground="#D4AF37"
                                    ValueChanged="SliderProBalance_ValueChanged"/>
                            <TextBlock x:Name="TxtProBalanceValue" Text="5%" Foreground="#D4AF37" 
                                       HorizontalAlignment="Center" FontWeight="Bold"/>
                        </StackPanel>
                        
                        <!-- Botões -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25,0,0">
                            <Button x:Name="BtnSaveCustomMotor" Content="💾 Salvar Perfil" 
                                    Style="{StaticResource GoldButtonStyle}" Width="150" Height="45" 
                                    Margin="0,0,15,0" Click="BtnSaveCustomMotor_Click"/>
                            <Button x:Name="BtnCancelCustomMotor" Content="❌ Cancelar" 
                                    Style="{StaticResource SecondaryButtonStyle}" Width="150" Height="45"
                                    Click="BtnCancelCustomMotor_Click"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

    <!-- 🔥 OVERLAY: Confirmação de Exclusão -->
    <Grid x:Name="OverlayConfirmDelete" Visibility="Collapsed" Panel.ZIndex="1001">
        <Grid Background="#CC000000"/>
        <Border Width="350" Height="200" Background="#1E1E1E" BorderBrush="#DC143C" BorderThickness="2" 
                CornerRadius="10" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Margin="20" VerticalAlignment="Center">
                <TextBlock Text="🗑️ Confirmar Exclusão" FontSize="18" FontWeight="Bold" 
                           Foreground="#DC143C" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                <TextBlock Text="Deseja excluir o perfil:" Foreground="#DDD" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtDeleteProfileName" FontWeight="Bold" Foreground="#D4AF37" 
                           HorizontalAlignment="Center" Margin="0,5,0,20"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="BtnConfirmDelete" Content="🗑️ Excluir" 
                            Background="#DC143C" Foreground="White" Width="120" Height="40" 
                            Margin="0,0,10,0" Click="BtnConfirmDelete_Click"/>
                    <Button x:Name="BtnCancelDelete" Content="❌ Cancelar" 
                            Background="#444" Foreground="White" Width="120" Height="40"
                            Click="BtnCancelDelete_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
