<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="KitLugia.GUI.Pages.BloatwarePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Bloatware"
      TextElement.FontFamily="Segoe UI Variable Display, Segoe UI, Segoe UI Emoji, Segoe UI Symbol, Arial">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Removedor de Bloatware" FontSize="28" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock x:Name="IconProgressText" Text="&#xCD;cones carregados: 0/0" FontSize="14" Foreground="#FFD700" Margin="15,8,0,0" FontWeight="SemiBold"/>
            </StackPanel>
            <TextBlock Text="Aplicativos nativos do Windows. Gerencie instala&#xE7;&#xF5;es padr&#xE3;o." Foreground="#AAA" Margin="0,5,0,0"/>
            <TextBlock Text="Deep Uninstall ativado: Remove app, arquivos residuais e registro." Foreground="#FF6F61" FontSize="11" Margin="0,5,0,0"/>
            
            <!-- Barra de Pesquisa -->
            <TextBox x:Name="TxtSearch" TextChanged="TxtSearch_TextChanged" 
                     Style="{StaticResource FocusStyle}"
                     Margin="0,15,0,0"/>
        </StackPanel>

        <Border x:Name="LoadingPanel" Grid.Row="1" Panel.ZIndex="99" Background="#CC000000" Visibility="Visible" CornerRadius="8">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Ellipse Width="40" Height="40" Stroke="#FFD700" StrokeThickness="3" Fill="Transparent" RenderTransformOrigin="0.5,0.5" StrokeDashArray="70 30">
                    <Ellipse.RenderTransform>
                        <RotateTransform x:Name="SpinnerRotate"/>
                    </Ellipse.RenderTransform>
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation Storyboard.TargetName="SpinnerRotate" Storyboard.TargetProperty="Angle" From="0" To="360" Duration="0:0:1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
                <TextBlock Text="Analisando..." Foreground="White" FontSize="16" Margin="0,15,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <ListView x:Name="AppsList" Background="Transparent" BorderThickness="0" Foreground="White" VirtualizingStackPanel.IsVirtualizing="True" VirtualizingStackPanel.VirtualizationMode="Recycling">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Margin" Value="0,1"/>
                        <Setter Property="Padding" Value="15,10"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="4" Padding="0">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <ColorAnimation Storyboard.TargetName="bdr" Storyboard.TargetProperty="Background.Color" To="#252525" Duration="0:0:0.15">
                                                            <ColorAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseOut"/>
                                                            </ColorAnimation.EasingFunction>
                                                        </ColorAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <ColorAnimation Storyboard.TargetName="bdr" Storyboard.TargetProperty="Background.Color" To="Transparent" Duration="0:0:0.15">
                                                            <ColorAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseOut"/>
                                                            </ColorAnimation.EasingFunction>
                                                        </ColorAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="48"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <!-- Checkbox para sele&#xE7;&#xE3;o m&#xFA;ltipla -->
                            <CheckBox Grid.Column="0" 
                                      IsChecked="{Binding IsSelected, Mode=TwoWay}" 
                                      VerticalAlignment="Center" 
                                      Margin="8,0,0,0"/>

                            <!-- &#xCD;cone do App ou Spinner de Carregamento -->
                            <Grid Grid.Column="1" Width="32" Height="32" Margin="8,0" VerticalAlignment="Center">
                                <Image Source="{Binding Icon}" Width="32" Height="32" Stretch="Uniform"/>
                                <!-- Spinner pulsante quando &#xED;cone &#xE9; null -->
                                <Ellipse Width="24" Height="24" Stroke="#FFD700" StrokeThickness="2" Fill="Transparent" StrokeDashArray="4 2" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Setter Property="Opacity" Value="1"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Icon}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard RepeatBehavior="Forever">
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.3" Duration="0:0:0.5" AutoReverse="True"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                            </Grid>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding PackageName}" FontSize="11" Foreground="#666" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                            </StackPanel>

                            <Button Grid.Column="3" Height="32" FontSize="11" Cursor="Hand" Click="BtnAction_Click" Tag="{Binding}" Content="REMOVER">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="#C42B1C"/>
                                        <Setter Property="Foreground" Value="#FF6F61"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bdr" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bdr" Property="Background" Value="#C42B1C"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Remover Selecionados" Click="BtnRemoveSelected_Click" Height="35" Width="140" 
                    Background="#C42B1C" Foreground="White" BorderThickness="0" Margin="0,0,10,0"
                    Style="{StaticResource GoldButtonStyle}"/>
            <Button Content="Atualizar Lista" Click="BtnRefresh_Click" Height="35" Width="120" 
                    Background="#333" Foreground="White" BorderThickness="0"
                    Style="{StaticResource SecondaryButtonStyle}"/>
        </StackPanel>

        <!-- Overlay de confirmação não-bloqueante -->
        <Border x:Name="ConfirmOverlay" Grid.RowSpan="3" Panel.ZIndex="100" 
                Background="#CC000000" Visibility="Collapsed" CornerRadius="8">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" 
                    Background="#2A2A2A" BorderBrush="#FFD700" BorderThickness="1" CornerRadius="8" 
                    Width="450" Padding="20">
                <StackPanel>
                    <TextBlock x:Name="ConfirmTitle" FontSize="16" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="ConfirmMessage" FontSize="13" Foreground="#CCC" Margin="0,10,0,0" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button x:Name="BtnConfirmNo" Content="Cancelar" Click="BtnConfirmNo_Click"
                                Width="100" Height="32" Margin="0,0,10,0"
                                Background="#444" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                        <Button x:Name="BtnConfirmYes" Content="Sim" Click="BtnConfirmYes_Click"
                                Width="100" Height="32"
                                Background="#C42B1C" Foreground="White" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Page>