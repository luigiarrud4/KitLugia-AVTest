<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="KitLugia.GUI.Controls.InteractiveTerminal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">

    <Border Background="#0C0C0C" BorderBrush="#00FF00" BorderThickness="2" CornerRadius="4">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
                <!-- Barra de T&#xED;tulo -->
                <RowDefinition Height="*"/>
                <!-- &#xC1;rea de Texto -->
                <RowDefinition Height="Auto"/>
                <!-- Input -->
            </Grid.RowDefinitions>

            <!-- 1. BARRA DE T&#xCD;TULO RETR&#xD4; -->
            <Border Grid.Row="0" Background="#00FF00">
                <Grid Margin="5,0">
                    <TextBlock Text="KIT LUGIA LEGACY CONSOLE [ADMINISTRATOR]" 
                               FontFamily="Consolas" FontWeight="Bold" 
                               Foreground="Black" VerticalAlignment="Center"/>

                    <Button Content="[X]" Click="BtnClose_Click" HorizontalAlignment="Right"
                            Background="Transparent" BorderThickness="0" 
                            FontFamily="Consolas" FontWeight="Bold" Foreground="Black" 
                            Cursor="Hand"/>
                </Grid>
            </Border>

            <!-- 2. &#xC1;REA DE SA&#xCD;DA (Output) -->
            <ScrollViewer x:Name="ConsoleScroller" Grid.Row="1" Background="Transparent" 
                          VerticalScrollBarVisibility="Hidden" Margin="5">
                <TextBlock x:Name="TxtOutput" 
                           FontFamily="Consolas" FontSize="16" 
                           Foreground="#00FF00" TextWrapping="Wrap" 
                           Text="Inicializando sistema..."/>
            </ScrollViewer>

            <!-- 3. &#xC1;REA DE ENTRADA (Input) -->
            <Border Grid.Row="2" Background="Transparent" Padding="5,0,5,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- O Prompt piscante -->
                    <TextBlock Text="C:\Lugia>" FontFamily="Consolas" FontSize="16" 
                               Foreground="#00FF00" VerticalAlignment="Center" Margin="0,0,5,0"/>

                    <!-- Onde voc&#xEA; digita -->
                    <TextBox x:Name="TxtInput" Grid.Column="1" 
                             Background="Transparent" BorderThickness="0" 
                             FontFamily="Consolas" FontSize="16" Foreground="White"
                             CaretBrush="White"
                             KeyDown="TxtInput_KeyDown"
                             IsEnabled="False"/>
                    <!-- Come&#xE7;a desativado, o VirtualTerminal ativa quando precisa -->
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>