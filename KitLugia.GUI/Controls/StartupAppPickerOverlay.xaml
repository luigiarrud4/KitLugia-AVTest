<UserControl x:Class="KitLugia.GUI.Controls.StartupAppPickerOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#AA000000">
    <Border HorizontalAlignment="Center" VerticalAlignment="Center"
            Background="#1e1e1e" BorderBrush="#444" BorderThickness="1"
            CornerRadius="8" Width="420" MaxHeight="500"
            Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="&#x1F4CB; Apps de Inicialização" 
                       FontSize="16" FontWeight="Bold" Foreground="White"
                       Margin="0,0,0,12"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="AppList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#252525" CornerRadius="6" Padding="10,7" Margin="0,0,0,5"
                                    Cursor="Hand">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#333"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding SelectCommand}"/>
                                </Border.InputBindings>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold" FontSize="12"/>
                                        <TextBlock Text="{Binding FullCommand}" Foreground="#666" FontSize="10" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="&#x2795;" Foreground="{StaticResource AccentColor}" 
                                               FontSize="16" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Button Grid.Row="2" Content="Fechar" Height="32" Margin="0,10,0,0"
                    Background="#444" Foreground="White" BorderThickness="0"
                    FontSize="12" Cursor="Hand" Click="BtnClose_Click"/>
        </Grid>
    </Border>
</UserControl>
