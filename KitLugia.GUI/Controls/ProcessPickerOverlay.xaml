<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="KitLugia.GUI.Controls.ProcessPickerOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed">

    <!-- Fundo escurecido -->
    <Grid Background="#CC000000">
        <!-- Painel central -->
        <Border Background="#1A1A1A" BorderBrush="#FFD700" BorderThickness="1"
                CornerRadius="10" Width="580" MaxHeight="640"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#FFD700" BlurRadius="20" ShadowDepth="0" Opacity="0.15"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="#111111" CornerRadius="10,10,0,0" Padding="18,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="&#x1F4BE; Selecionar Processo para Monitorar"
                                       FontSize="15" FontWeight="Bold" Foreground="#FFD700"/>
                            <TextBlock Text="Escolha um processo. O KitLugia aplicar&#xE1; EmptyWorkingSet quando exceder o limite."
                                       FontSize="11" Foreground="#888" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="&#x2715;" Width="28" Height="28"
                                Background="Transparent" Foreground="#666" BorderThickness="0"
                                FontSize="14" Cursor="Hand" Click="BtnClose_Click"
                                VerticalAlignment="Top"/>
                    </Grid>
                </Border>

                <!-- Barra de pesquisa + bot&#xF5;es -->
                <Border Grid.Row="1" Padding="14,10" Background="#141414">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="38"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="TxtSearch"
                                 Background="#252525" Foreground="White"
                                 BorderBrush="#444" BorderThickness="1"
                                 Padding="10,7" FontSize="12"
                                 TextChanged="TxtSearch_TextChanged"/>

                        <Button Grid.Column="1" Content="&#x1F504;" Height="34" Margin="6,0,0,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                ToolTip="Atualizar lista de processos"
                                Click="BtnRefresh_Click"/>

                        <Button Grid.Column="2" Content="&#x1F4C1; Selecionar .exe" Height="34"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="6,0,0,0" Padding="10,0"
                                ToolTip="Adicionar processo manualmente pelo arquivo .exe"
                                Click="BtnBrowseExe_Click"/>
                    </Grid>
                </Border>

                <!-- Lista de processos (code-behind popula) -->
                <Border Grid.Row="2" Margin="10,4,10,4">
                    <ScrollViewer x:Name="ProcessScroller" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ProcessListPanel"/>
                    </ScrollViewer>
                </Border>

                <!-- Footer: limite + confirmar -->
                <Border Grid.Row="3" Background="#111111" CornerRadius="0,0,10,10" Padding="14,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="TxtSelectedProcess"
                                       Text="Nenhum processo selecionado"
                                       Foreground="#888" FontSize="12"/>
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                <TextBlock Text="Limite de RAM:" Foreground="#666"
                                           FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox x:Name="TxtLimitMB" Text="500" Width="70"
                                         Background="#252525" Foreground="White"
                                         BorderBrush="#444" BorderThickness="1"
                                         Padding="6,4" FontSize="12" VerticalAlignment="Center"/>
                                <TextBlock Text=" MB" Foreground="#666" FontSize="11"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1" Content="Cancelar"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Width="90" Height="36" Margin="0,0,8,0"
                                Click="BtnClose_Click"/>

                        <Button Grid.Column="2" x:Name="BtnConfirm"
                                Content="&#x2705; Adicionar Limite"
                                Style="{StaticResource GoldButtonStyle}"
                                Width="145" Height="36" IsEnabled="False"
                                Click="BtnConfirm_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
