<UserControl x:Class="KitLugia.GUI.Controls.ProcessEngineConfigOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed"
             TextElement.FontFamily="Segoe UI Variable Display, Segoe UI, Segoe UI Emoji, Segoe UI Symbol, Arial">

    <Grid Background="#CC000000">
        <Border Background="#1A1A1A" BorderBrush="#FFD700" BorderThickness="1"
                CornerRadius="10" Width="480" MaxHeight="560"
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#FFD700" BlurRadius="20" ShadowDepth="0" Opacity="0.15"/>
            </Border.Effect>
            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="&#x2699;&#xFE0F; Configurações do Processo"
                               FontSize="16" FontWeight="Bold" Foreground="#FFD700"
                               Margin="0,0,0,12"/>
                    <Button Grid.Column="1" Content="&#x2715;" Width="28" Height="28"
                            Background="Transparent" Foreground="#666" BorderThickness="0"
                            FontSize="14" Cursor="Hand" Click="BtnClose_Click"
                            VerticalAlignment="Top"/>
                </Grid>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="CPU" Foreground="#888" FontSize="11" FontWeight="Bold" Margin="0,8,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Prioridade CPU" Foreground="#CCC" FontSize="12" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" x:Name="CboCpuPriority" SelectedIndex="4"
                                      Background="#2d2d2d" Foreground="White" BorderBrush="#555"
                                      Height="28" FontSize="12">
                                <ComboBoxItem Content="Idle"/>
                                <ComboBoxItem Content="BelowNormal"/>
                                <ComboBoxItem Content="Normal"/>
                                <ComboBoxItem Content="AboveNormal"/>
                                <ComboBoxItem Content="High"/>
                                <ComboBoxItem Content="RealTime"/>
                            </ComboBox>
                        </Grid>

                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Efficiency Mode" Foreground="#CCC" FontSize="12" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" x:Name="CboEfficiencyMode" SelectedIndex="0"
                                      Background="#2d2d2d" Foreground="White" BorderBrush="#555"
                                      Height="28" FontSize="12">
                                <ComboBoxItem Content="P-Cores (Performance)"/>
                                <ComboBoxItem Content="E-Cores (Efficiency)"/>
                            </ComboBox>
                        </Grid>

                        <TextBlock Text="I/O e Memória" Foreground="#888" FontSize="11" FontWeight="Bold" Margin="0,12,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Prioridade I/O" Foreground="#CCC" FontSize="12" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" x:Name="CboIoPriority" SelectedIndex="1"
                                      Background="#2d2d2d" Foreground="White" BorderBrush="#555"
                                      Height="28" FontSize="12">
                                <ComboBoxItem Content="Baixa (0)"/>
                                <ComboBoxItem Content="Normal (1)"/>
                                <ComboBoxItem Content="Alta (2)"/>
                                <ComboBoxItem Content="Critical (3)"/>
                            </ComboBox>
                        </Grid>

                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Prioridade Página" Foreground="#CCC" FontSize="12" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" x:Name="CboPagePriority" SelectedIndex="0"
                                      Background="#2d2d2d" Foreground="White" BorderBrush="#555"
                                      Height="28" FontSize="12">
                                <ComboBoxItem Content="Normal (0)"/>
                                <ComboBoxItem Content="Acima do Normal (1)"/>
                            </ComboBox>
                        </Grid>

                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Memory Priority" Foreground="#CCC" FontSize="12" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="1" x:Name="CboMemoryPriority" SelectedIndex="0"
                                      Background="#2d2d2d" Foreground="White" BorderBrush="#555"
                                      Height="28" FontSize="12">
                                <ComboBoxItem Content="Normal (0)"/>
                                <ComboBoxItem Content="Baixa (1)"/>
                                <ComboBoxItem Content="Média (2)"/>
                                <ComboBoxItem Content="Alta (3)"/>
                            </ComboBox>
                        </Grid>

                        <TextBlock Text="Boosts" Foreground="#888" FontSize="11" FontWeight="Bold" Margin="0,12,0,4"/>
                        <CheckBox x:Name="ChkTimerBoost" Content="Timer Boost (1ms resolution)" Foreground="#CCC" FontSize="12" Margin="0,3"/>
                        <CheckBox x:Name="ChkNetworkBoost" Content="Network Boost (prioridade rede)" Foreground="#CCC" FontSize="12" Margin="0,3"/>

                        <TextBlock Text="ProBalance" Foreground="#888" FontSize="11" FontWeight="Bold" Margin="0,12,0,4"/>
                        <CheckBox x:Name="ChkProBalance" Content="ProBalance (controle CPU em bg)" Foreground="#CCC" FontSize="12" Margin="0,3" Checked="ChkProBalance_Checked" Unchecked="ChkProBalance_Checked"/>
                        <Grid Margin="20,4,0,0" x:Name="PanelProBalanceThreshold">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Limite CPU (%)" Foreground="#CCC" FontSize="12" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" x:Name="TxtProBalanceThreshold" Text="5"
                                     Background="#2d2d2d" Foreground="White" BorderBrush="#555"
                                     Height="28" FontSize="12" Padding="6,0"/>
                        </Grid>

                        <TextBlock Text="Recursos Adicionais" Foreground="#888" FontSize="11" FontWeight="Bold" Margin="0,12,0,4"/>
                        <CheckBox x:Name="ChkGameClass" Content="Game Class Info (sinalizar como jogo)" Foreground="#CCC" FontSize="12" Margin="0,3" IsChecked="True"/>
                        <CheckBox x:Name="ChkWin32Priority" Content="Win32 Priority Separation (registry)" Foreground="#CCC" FontSize="12" Margin="0,3" IsChecked="True"/>
                        <CheckBox x:Name="ChkEcoQoS" Content="EcoQoS (economia energia)" Foreground="#CCC" FontSize="12" Margin="0,3"/>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="2" Background="#111111" CornerRadius="0,0,10,10" Padding="14,12" Margin="-18,-12,-18,-18">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="BtnCancel" Content="Cancelar" Width="100" Height="34"
                                Margin="0,0,10,0" Click="BtnCancel_Click"
                                Background="#444" Foreground="White" BorderThickness="0"
                                FontSize="12" Cursor="Hand"/>
                        <Button x:Name="BtnSave" Content="Salvar" Width="100" Height="34"
                                Background="#FFD700" Foreground="Black" BorderThickness="0"
                                FontSize="12" FontWeight="Bold" Cursor="Hand"
                                Click="BtnSave_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
