<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="KitLugia.GUI.Controls.LugiaToast"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="350" Margin="0,0,0,8" 
             Cursor="Hand"
             Background="Transparent">

    <UserControl.Resources>
        <!-- &#x1F4CD; ANIMA&#xC7;&#xC3;O 4: Slide do LugiaToast (0.3-0.4s) - LugiaToast.xaml linha ~11-27 -->
        <!-- BlurRadius j&#xE1; otimizado em 10 (razo&#xE1;vel) -->
        <Storyboard x:Key="SlideInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" From="40" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="SlideOutAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="40" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="TypeTransitionAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0.6" To="1" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource SlideInAnimation}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Border Name="ToastBorder" CornerRadius="6" BorderThickness="1" ClipToBounds="True">
        <Border.RenderTransform>
            <TranslateTransform X="0"/>
        </Border.RenderTransform>

        <Border.Style>
            <Style TargetType="Border">
                <!-- Estado Padr&#xE3;o (INFO / AGUARDE) -->
                <Setter Property="BorderBrush" Value="#66FFD700"/>
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#CC2A2010" Offset="0"/>
                            <GradientStop Color="#F00A0A0A" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#FFD700" BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
                    </Setter.Value>
                </Setter>

                <Style.Triggers>
                    <!-- SUCESSO (Verde) -->
                    <DataTrigger Binding="{Binding ToastType}" Value="Success">
                        <Setter Property="BorderBrush" Value="#664CAF50"/>
                        <Setter Property="Background">
                            <Setter.Value>
                                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                    <GradientStop Color="#CC1B3320" Offset="0"/>
                                    <GradientStop Color="#F00A0A0A" Offset="1"/>
                                </LinearGradientBrush>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#4CAF50" BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>

                    <!-- ERRO (Vermelho) -->
                    <DataTrigger Binding="{Binding ToastType}" Value="Error">
                        <Setter Property="BorderBrush" Value="#66C42B1C"/>
                        <Setter Property="Background">
                            <Setter.Value>
                                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                    <GradientStop Color="#CC3E1010" Offset="0"/>
                                    <GradientStop Color="#F00A0A0A" Offset="1"/>
                                </LinearGradientBrush>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#C42B1C" BlurRadius="10" ShadowDepth="2" Opacity="0.4"/>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Barra Lateral Colorida -->
            <Rectangle Grid.Column="0">
                <Rectangle.Style>
                    <Style TargetType="Rectangle">
                        <Setter Property="Fill" Value="{DynamicResource AccentColor}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ToastType}" Value="Success">
                                <Setter Property="Fill" Value="{DynamicResource NotificationSuccessBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ToastType}" Value="Error">
                                <Setter Property="Fill" Value="{DynamicResource NotificationErrorBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Rectangle.Style>
            </Rectangle>

            <!-- &#xCD;cone Emoji -->
            <TextBlock Grid.Column="1" FontSize="18" Margin="10,0,10,0" VerticalAlignment="Center" FontFamily="Segoe UI Emoji">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="&#x2139;&#xFE0F;"/>
                        <!-- Padr&#xE3;o Info -->
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ToastType}" Value="Success">
                                <Setter Property="Text" Value="&#x2705;"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ToastType}" Value="Error">
                                <Setter Property="Text" Value="&#x26A0;&#xFE0F;"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- T&#xED;tulo e Texto -->
            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,12,5,12">
                <TextBlock x:Name="TxtTitle" Text="T&#xCD;TULO" FontWeight="Bold" FontSize="13" Margin="0,0,0,3">
                    <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ToastType}" Value="Success">
                                <Setter Property="Foreground" Value="{DynamicResource NotificationSuccessBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ToastType}" Value="Error">
                                <Setter Property="Foreground" Value="{DynamicResource NotificationErrorBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock x:Name="TxtMessage" Text="Mensagem de notifica&#xE7;&#xE3;o..." TextWrapping="Wrap" 
                           Foreground="#DDDDDD" FontSize="12" LineHeight="16"/>
            </StackPanel>

            <!-- CONTADOR DE DUPLICATAS (x2, x10...) -->
            <Border x:Name="BadgeCounter" Grid.Column="3" Background="#40FFFFFF" CornerRadius="10" 
                    Height="20" MinWidth="20" Margin="0,0,5,0" VerticalAlignment="Center"
                    Visibility="Collapsed">
                <TextBlock x:Name="TxtCount" Text="x1" Foreground="White" FontSize="11" FontWeight="Bold" 
                           HorizontalAlignment="Center" VerticalAlignment="Center" Padding="5,0"/>
            </Border>

            <Button Grid.Column="4" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center"
                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                    Click="BtnClose_Click">
                <TextBlock Text="&#x2716;" FontSize="10" Foreground="#888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

        </Grid>
    </Border>
</UserControl>