<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="KitLugia.GUI.Controls.ValorantDiagnosticOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">
    
    <Grid Background="#CC000000">
        <Border Background="#1A1A1A" 
                CornerRadius="16" 
                BorderBrush="#FFD700" 
                BorderThickness="2"
                Width="650"
                MaxHeight="550"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Padding="0">
            <Grid>
                <!-- Header com X para fechar -->
                <Grid Height="60" VerticalAlignment="Top">
                    <Border Background="#252525" CornerRadius="16,16,0,0">
                        <Grid Margin="20,0,20,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#x1F3AE;" FontSize="28" Margin="0,0,15,0" VerticalAlignment="Center"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="DIAGN&#xD3;STICO VALORANT" FontSize="20" FontWeight="ExtraBold" Foreground="#FFD700"/>
                                    <TextBlock Text="Verifica&#xE7;&#xE3;o UEFI, TPM 2.0 e VBS/HVCI (VAN9005)" FontSize="12" Foreground="#AAA" Opacity="0.8"/>
                                </StackPanel>
                            </StackPanel>

                            <Button x:Name="BtnClose"
                                    Content="&#x2715;"
                                    Width="40" Height="40"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    Foreground="#AAA"
                                    FontWeight="Bold"
                                    FontSize="20"
                                    Cursor="Hand"
                                    Click="BtnClose_Click"
                                    BorderThickness="0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="20">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bdr" Property="Background" Value="#FF4444"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Conte&#xFA;do -->
                <ScrollViewer x:Name="ContentScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              Margin="0,60,0,0">
                    <StackPanel Margin="25,25,25,25">
                        <!-- Status Checks Grid -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- UEFI -->
                            <Border Grid.Row="0" Grid.Column="0" Background="#252525" BorderBrush="#333" BorderThickness="1" CornerRadius="10" Padding="18" Margin="0,0,12,12">
                                <StackPanel>
                                    <TextBlock Text="&#x2699;&#xFE0F;" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock Text="Modo UEFI" Foreground="White" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtUEFIStatus" Text="Verificando..." Foreground="#AAA" FontSize="11" HorizontalAlignment="Center" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- TPM 2.0 -->
                            <Border Grid.Row="0" Grid.Column="1" Background="#252525" BorderBrush="#333" BorderThickness="1" CornerRadius="10" Padding="18" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="&#x1F510;" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock Text="TPM 2.0" Foreground="White" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtTPMStatus" Text="Verificando..." Foreground="#AAA" FontSize="11" HorizontalAlignment="Center" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- VBS -->
                            <Border Grid.Row="1" Grid.Column="0" Background="#252525" BorderBrush="#333" BorderThickness="1" CornerRadius="10" Padding="18" Margin="0,0,12,0">
                                <StackPanel>
                                    <TextBlock Text="&#x1F6E1;&#xFE0F;" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock Text="VBS" Foreground="White" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtVBSStatus" Text="Verificando..." Foreground="#AAA" FontSize="11" HorizontalAlignment="Center" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <!-- HVCI -->
                            <Border Grid.Row="1" Grid.Column="1" Background="#252525" BorderBrush="#333" BorderThickness="1" CornerRadius="10" Padding="18" Margin="0,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="&#x26A1;" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock Text="HVCI" Foreground="White" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtHVCIStatus" Text="Verificando..." Foreground="#AAA" FontSize="11" HorizontalAlignment="Center" Margin="0,8,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Overall Status -->
                        <Border x:Name="BorderValorantStatus" Background="#333" CornerRadius="10" Padding="18" Margin="0,15,0,0">
                            <TextBlock x:Name="TxtValorantOverallStatus" Text="Aguardando verifica&#xE7;&#xE3;o..."
                                       TextWrapping="Wrap" Foreground="White" FontSize="12" LineHeight="20"/>
                        </Border>

                        <!-- Buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                            <Button x:Name="BtnApplyValorantRepair" Content="Aplicar Reparo"
                                    Background="#FFD700" Foreground="#1E1E1E" BorderThickness="0"
                                    Padding="28,12" FontSize="13" FontWeight="Bold" Cursor="Hand"
                                    Click="BtnApplyValorantRepair_Click" IsEnabled="False">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#FFED4E"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.5"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
