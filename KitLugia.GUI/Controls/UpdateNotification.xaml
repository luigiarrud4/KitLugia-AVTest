<UserControl x:Class="KitLugia.GUI.Controls.UpdateNotification"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="320">

    <UserControl.Resources>
        <Storyboard x:Key="SlideInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" From="40" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="SlideOutAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="40" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource SlideInAnimation}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Border CornerRadius="8" BorderThickness="1" BorderBrush="#66FFD700" ClipToBounds="True"
            Effect="{DynamicResource CardGlow}">
        <Border.RenderTransform>
            <TranslateTransform X="0"/>
        </Border.RenderTransform>
        <Border.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#CC2A2010" Offset="0"/>
                <GradientStop Color="#F00A0A0A" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="16,14,16,8" MinHeight="40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="&#x2728;" FontSize="20" VerticalAlignment="Top" Margin="0,0,10,0" FontFamily="Segoe UI Emoji"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtTitle" Text="ATUALIZADO" FontWeight="Bold" FontSize="13"
                               Foreground="{DynamicResource AccentColor}" Margin="0,0,0,4"/>
                    <TextBlock x:Name="TxtMessage" TextWrapping="Wrap" Foreground="#DDDDDD" FontSize="12" LineHeight="16"/>
                </StackPanel>

                <Button x:Name="BtnClose" Grid.Column="2" Width="20" Height="20" Margin="0,0,0,0" VerticalAlignment="Top"
                        Background="Transparent" BorderThickness="0" Cursor="Hand" Click="BtnClose_Click">
                    <TextBlock Text="&#x2716;" FontSize="10" Foreground="#888" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="1"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="False">
                                    <Setter Property="Opacity" Value="0.4"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <Border Grid.Row="1" Height="1" Background="#22FFD700" Margin="16,0"/>

            <!-- Versão antiga → nova -->
            <Border x:Name="VersionBorder" Grid.Row="2" Margin="16,10,16,0" Visibility="Collapsed"
                    Background="#151515" CornerRadius="6" Padding="10"
                    BorderBrush="#33FFD700" BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="TxtVersionLine" Text="0.0.0  --->  0.0.0"
                               FontSize="14" FontWeight="Bold" Foreground="{DynamicResource AccentColor}"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TxtReinstallLabel" Text=""
                               FontSize="10" Foreground="#FFD700" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Changelog -->
            <Border x:Name="ChangelogBorder" Grid.Row="3" Margin="16,10,16,0"
                    Background="#111" CornerRadius="6" Padding="10"
                    BorderBrush="#22FFD700" BorderThickness="1"
                    Visibility="Collapsed" MaxHeight="100">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="TxtChangelog" Text="" FontSize="10" Foreground="#CCCCCC"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>

            <Button x:Name="BtnOk" Grid.Row="4" Height="36" Margin="16,10,16,12" Cursor="Hand" Click="BtnOk_Click"
                    BorderThickness="0">
                <Button.Background>
                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                        <GradientStop Color="#FFD700" Offset="0"/>
                        <GradientStop Color="#FFA500" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
                <TextBlock x:Name="TxtOkBtn" Text="ENTENDIDO" FontWeight="Bold" FontSize="12" Foreground="#1A1A1A" HorizontalAlignment="Center"/>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="5"
                                BorderThickness="0" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="bdr"
                                                Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                To="1.03" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="bdr"
                                                Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                To="1.03" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="bdr"
                                                Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                To="1" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="bdr"
                                                Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                To="1" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter TargetName="bdr" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Border>
</UserControl>
