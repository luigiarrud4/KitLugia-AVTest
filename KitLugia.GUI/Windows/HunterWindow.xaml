<Window x:Class="KitLugia.GUI.Windows.HunterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="KitLugia Spy" Height="600" Width="560"
        WindowStartupLocation="CenterScreen"
        TextElement.FontFamily="Segoe UI Variable Display, Segoe UI, Consolas, Segoe UI Emoji"
        TextElement.Foreground="White"
        Background="#0F0F0F"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="bdr" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource CardHover}"/>
                                <Setter TargetName="bdr" Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{DynamicResource AccentColor}"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bdr" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" GlassFrameThickness="0" CornerRadius="0" UseAeroCaptionButtons="False" ResizeBorderThickness="4"/>
    </WindowChrome.WindowChrome>
    <Border BorderBrush="#FFD700" BorderThickness="1">
        <Grid Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="24"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Drag handle -->
            <Border Grid.Row="0" Background="#1A1A1A" Cursor="SizeAll"
                    MouseDown="DragBar_MouseDown">
                <Grid>
                    <TextBlock Text="KitLugia Spy" FontSize="11" Foreground="#555"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock x:Name="BtnClose" Text="&#x2715;" FontSize="12" Foreground="#666"
                               HorizontalAlignment="Right" VerticalAlignment="Center"
                               Cursor="Hand" Margin="0,0,6,0"
                               MouseDown="BtnClose_MouseDown"/>
                </Grid>
            </Border>

            <!-- Crosshair bar -->
            <Border Grid.Row="1" Background="#1A1A1A" CornerRadius="4" Padding="8" Margin="0,4,0,8"
                    BorderBrush="#333" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <Border x:Name="FinderButton" Width="32" Height="32"
                            Background="#2255AA" CornerRadius="4"
                            BorderBrush="#4488CC" BorderThickness="1"
                            Cursor="Cross" MouseDown="Finder_MouseDown">
                        <TextBlock Text="&#x1F3AF;" FontSize="16"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Arraste a mira sobre qualquer janela" VerticalAlignment="Center"
                               Foreground="#888" Margin="10,0,0,0"/>
                    <Button x:Name="BtnAutoRefresh" Content="Auto"
                            Margin="10,0,0,0" Padding="8,2" FontSize="11"
                            Background="#252525" Foreground="#888" BorderBrush="#555" BorderThickness="1"
                            Cursor="Hand" Click="BtnAutoRefresh_Click"/>
                    <TextBlock x:Name="TxtStatus" Text="Pronto" VerticalAlignment="Center"
                               Foreground="#4CAF50" FontSize="11" Margin="10,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- Info area -->
            <Border Grid.Row="2" Background="#0A0A0A" CornerRadius="4"
                    BorderBrush="#222" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">

                    <!-- Handle -->
                    <Label Content="Handle" FontWeight="SemiBold" Foreground="#FFD700" Padding="0,6,0,2"/>
                    <TextBox x:Name="TxtHwnd" IsReadOnly="True"
                             FontFamily="Consolas" FontSize="12"
                             Background="#1A1A1A" Foreground="#CCCCCC"
                             BorderBrush="#333" BorderThickness="1" Padding="4"
                             Text="-"/>

                    <!-- PID -->
                    <Label Content="PID" FontWeight="SemiBold" Foreground="#FFD700" Padding="0,6,0,2"/>
                    <TextBox x:Name="TxtPid" IsReadOnly="True"
                             FontFamily="Consolas" FontSize="12"
                             Background="#1A1A1A" Foreground="#CCCCCC"
                             BorderBrush="#333" BorderThickness="1" Padding="4"
                             Text="-"/>

                    <!-- Title -->
                    <Label Content="Título" FontWeight="SemiBold" Foreground="#FFD700" Padding="0,6,0,2"/>
                    <TextBox x:Name="TxtTitle" IsReadOnly="True"
                             FontSize="12"
                             Background="#1A1A1A" Foreground="#CCCCCC"
                             BorderBrush="#333" BorderThickness="1" Padding="4"
                             Text="-"/>

                    <!-- Class -->
                    <Label Content="Classe" FontWeight="SemiBold" Foreground="#FFD700" Padding="0,6,0,2"/>
                    <TextBox x:Name="TxtClass" IsReadOnly="True"
                             FontFamily="Consolas" FontSize="12"
                             Background="#1A1A1A" Foreground="#CCCCCC"
                             BorderBrush="#333" BorderThickness="1" Padding="4"
                             Text="-"/>

                    <!-- Rectangle -->
                    <Label Content="Retângulo" FontWeight="SemiBold" Foreground="#FFD700" Padding="0,6,0,2"/>
                    <TextBox x:Name="TxtRect" IsReadOnly="True"
                             FontFamily="Consolas" FontSize="12"
                             Background="#1A1A1A" Foreground="#CCCCCC"
                             BorderBrush="#333" BorderThickness="1" Padding="4"
                             Text="-"/>

                    <!-- Processo -->
                    <Label Content="Processo" FontWeight="SemiBold" Foreground="#FFD700" Padding="0,6,0,2"/>
                    <TextBox x:Name="TxtProcess" IsReadOnly="True"
                             FontSize="12"
                             Background="#1A1A1A" Foreground="#CCCCCC"
                             BorderBrush="#333" BorderThickness="1" Padding="4"
                             Text="-"/>
                    <TextBox x:Name="TxtPath" IsReadOnly="True"
                             FontSize="11" Foreground="#858585"
                             Background="#151515" BorderBrush="#222" BorderThickness="1" Padding="4"
                             Text="" Margin="0,2,0,0"/>

                    <!-- Visibility & Parent -->
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Visível" FontSize="11" Padding="0,2,4,2" Foreground="#888"/>
                        <TextBox x:Name="TxtVisible" Grid.Column="1" IsReadOnly="True"
                                 FontFamily="Consolas" FontSize="11"
                                 Background="#1A1A1A" Foreground="#CCCCCC" BorderBrush="#333" BorderThickness="1"
                                 Padding="2" Text="-" Margin="0,0,8,0"/>
                        <Label Grid.Column="2" Content="Parent" FontSize="11" Padding="0,2,4,2" Foreground="#888"/>
                        <TextBox x:Name="TxtParent" Grid.Column="3" IsReadOnly="True"
                                 FontFamily="Consolas" FontSize="11"
                                 Background="#1A1A1A" Foreground="#CCCCCC" BorderBrush="#333" BorderThickness="1"
                                 Padding="2" Text="-"/>
                    </Grid>

                    <!-- Styles -->
                    <Label Content="Estilos WS" FontWeight="SemiBold" Foreground="#FFD700" Padding="0,6,0,2"/>
                    <TextBox x:Name="TxtStyles" IsReadOnly="True" TextWrapping="Wrap"
                             FontFamily="Consolas" FontSize="11" MaxHeight="60"
                             Background="#1A1A1A" Foreground="#CCCCCC"
                             BorderBrush="#333" BorderThickness="1" Padding="4"
                             Text="-" VerticalScrollBarVisibility="Auto"/>

                    <!-- Extended Styles -->
                    <Label Content="Estilos WS_EX" FontWeight="SemiBold" Foreground="#FFD700" Padding="0,6,0,2"/>
                    <TextBox x:Name="TxtExStyles" IsReadOnly="True" TextWrapping="Wrap"
                             FontFamily="Consolas" FontSize="11" MaxHeight="60"
                             Background="#1A1A1A" Foreground="#CCCCCC"
                             BorderBrush="#333" BorderThickness="1" Padding="4"
                             Text="-" VerticalScrollBarVisibility="Auto"/>

                    <!-- Child windows -->
                    <Label Content="Janelas Filhas" FontWeight="SemiBold" Foreground="#FFD700" Padding="0,6,0,2"/>
                    <ListBox x:Name="ListChildren" MinHeight="80" MaxHeight="120"
                             Background="#1A1A1A" BorderBrush="#333" BorderThickness="1"
                             Foreground="#CCCCCC" FontFamily="Consolas" FontSize="11"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Action buttons -->
            <Border Grid.Row="3" Background="#1A1A1A" CornerRadius="4" Padding="6" Margin="0,8,0,0"
                    BorderBrush="#333" BorderThickness="1">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="BtnUninstall" Content="Desinstalar" Padding="12,6" Margin="4,0"
                            Background="#C42B1C" Foreground="White" BorderThickness="0"
                            Cursor="Hand" IsEnabled="False" Click="BtnUninstall_Click"/>
                    <Button x:Name="BtnKill" Content="Matar" Padding="12,6" Margin="4,0"
                            Background="#252525" Foreground="#E0E0E0" BorderBrush="#555" BorderThickness="1"
                            Cursor="Hand" IsEnabled="False" Click="BtnKill_Click"/>
                    <Button x:Name="BtnKillDel" Content="Matar + Deletar" Padding="12,6" Margin="4,0"
                            Background="#252525" Foreground="#E0E0E0" BorderBrush="#555" BorderThickness="1"
                            Cursor="Hand" IsEnabled="False" Click="BtnKillDel_Click"/>
                    <Button x:Name="BtnOpenFolder" Content="Abrir Pasta" Padding="12,6" Margin="4,0"
                            Background="#252525" Foreground="#E0E0E0" BorderBrush="#555" BorderThickness="1"
                            Cursor="Hand" IsEnabled="False" Click="BtnOpenFolder_Click"/>
                    <Button x:Name="BtnProperties" Content="Propriedades" Padding="12,6" Margin="4,0"
                            Background="#252525" Foreground="#E0E0E0" BorderBrush="#555" BorderThickness="1"
                            Cursor="Hand" IsEnabled="False" Click="BtnProperties_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
