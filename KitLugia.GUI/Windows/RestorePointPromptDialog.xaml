<Window x:Class="KitLugia.GUI.Windows.RestorePointPromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ponto de Restauração" 
        Height="350" 
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#1E1E1E"
        WindowStyle="SingleBorderWindow"
        ShowInTaskbar="False">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="&#x1F4CB; Ponto de Restauração" FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentColor}"/>
            <TextBlock x:Name="AppNameText" Text="" FontSize="14" Foreground="#CCC" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- Icon + Main message -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="&#x26A0;&#xFE0F;" FontSize="48" VerticalAlignment="Top" Margin="0,0,16,0"/>
            <StackPanel>
                <TextBlock Text="Deseja criar um Ponto de Restauração do Windows" FontSize="16" FontWeight="SemiBold" Foreground="#EEE" TextWrapping="Wrap"/>
                <TextBlock Text="antes de desinstalar este programa?" FontSize="16" FontWeight="SemiBold" Foreground="#EEE" TextWrapping="Wrap" Margin="0,2,0,0"/>
                <TextBlock Text="Isso permite desfazer alterações no sistema caso algo dê errado." FontSize="13" Foreground="#999" Margin="0,8,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </StackPanel>

        <!-- Checkboxes -->
        <StackPanel Grid.Row="2" VerticalAlignment="Center" Margin="0,0,0,16">
            <CheckBox x:Name="ChkCreateRestorePoint" IsChecked="True"
                      Content="Sim, criar um Ponto de Restauração agora"
                      Foreground="#EEE" FontSize="14" Margin="0,0,0,12"/>
            <CheckBox x:Name="ChkRememberChoice" IsChecked="False"
                      Content="Lembrar minha escolha e não perguntar novamente"
                      Foreground="#888" FontSize="13" Margin="0,0,0,0"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnNo" Content="Não" Width="90" Height="36"
                    Background="#3A3A3A" Foreground="#CCC"
                    BorderThickness="0" Cursor="Hand"
                    FontWeight="SemiBold" FontSize="13"
                    Click="BtnNo_Click" Margin="0,0,8,0"/>
            <Button x:Name="BtnYes" Content="Sim" Width="120" Height="36"
                    Background="{StaticResource AccentColor}" Foreground="White"
                    BorderThickness="0" Cursor="Hand"
                    FontWeight="Bold" FontSize="14"
                    Click="BtnYes_Click"/>
        </StackPanel>
    </Grid>
</Window>
