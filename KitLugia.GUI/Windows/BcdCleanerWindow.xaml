<Window x:Class="KitLugia.GUI.Windows.BcdCleanerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Limpeza de Entradas BCD - KitLugia" 
        Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#1e1e1e">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="&#x1F9F9; Limpeza de Entradas BCD" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
            <TextBlock Text="Selecione as entradas que deseja remover:" FontSize="14" Foreground="#aaaaaa" Margin="0,0,0,5"/>
            <TextBlock Text="&#x26A0;&#xFE0F; Entradas marcadas em VERMELHO s&#xE3;o cr&#xED;ticas do sistema e N&#xC3;O devem ser removidas" FontSize="12" Foreground="#ff6b6b" Margin="0,0,0,10"/>
        </StackPanel>

        <!-- Lista de Entradas -->
        <Border Grid.Row="1" BorderBrush="#3a3a3a" BorderThickness="1" Background="#252525" CornerRadius="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="EntriesList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#3a3a3a" BorderThickness="0,0,0,1" Padding="15,12" Background="Transparent">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#2a2a2a"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Checkbox -->
                                    <CheckBox x:Name="EntryCheckbox" 
                                              Grid.Column="0" 
                                              IsChecked="True" 
                                              Margin="0,0,15,0"
                                              VerticalAlignment="Center"
                                              Foreground="White"/>

                                    <!-- Info -->
                                    <StackPanel Grid.Column="1">
                                        <TextBlock x:Name="GuidText" Text="{Binding Guid}" FontSize="12" Foreground="#888888" Margin="0,0,0,5"/>
                                        <TextBlock x:Name="DescriptionText" Text="{Binding Description}" FontSize="14" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,5"/>
                                        <TextBlock x:Name="ReasonText" Text="{Binding Reason}" FontSize="12" Foreground="#4ecdc4" Margin="0,0,0,5"/>
                                        <TextBlock x:Name="TypeText" Text="{Binding Type}" FontSize="11" Foreground="#aaaaaa"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Bot&#xF5;es -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="BtnSelectAll" Content="Selecionar Todas" Width="120" Height="35" Margin="0,0,10,0" 
                    Background="#3a3a3a" Foreground="White" BorderBrush="#555" FontSize="13" Click="BtnSelectAll_Click"/>
            <Button x:Name="BtnDeselectAll" Content="Desmarcar Todas" Width="120" Height="35" Margin="0,0,10,0" 
                    Background="#3a3a3a" Foreground="White" BorderBrush="#555" FontSize="13" Click="BtnDeselectAll_Click"/>
            <Button x:Name="BtnCancel" Content="Cancelar" Width="100" Height="35" Margin="0,0,10,0" 
                    Background="#3a3a3a" Foreground="White" BorderBrush="#555" FontSize="13" Click="BtnCancel_Click"/>
            <Button x:Name="BtnRemove" Content="&#x1F5D1;&#xFE0F; Remover Selecionadas" Width="160" Height="35" 
                    Background="#e74c3c" Foreground="White" BorderBrush="Transparent" FontSize="13" FontWeight="SemiBold" Click="BtnRemove_Click"/>
        </StackPanel>
    </Grid>
</Window>
